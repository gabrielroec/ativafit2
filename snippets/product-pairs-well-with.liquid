{% comment %}
  "Pairs well with" — lista vertical de cards (sem carrossel, sem View all).
  Até 5 produtos via blocos `pairs_well_with_product`.
{% endcomment %}

{%- if section.settings.show_pairs_well_with -%}
  {%- assign product_count = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'pairs_well_with_product' and block.settings.product != blank -%}
      {%- assign selected_product = all_products[block.settings.product] -%}
      {%- if selected_product != blank -%}
        {%- assign product_count = product_count | plus: 1 -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if product_count > 0 -%}
    <div class="pairs-well-with_new" id="pairs-well-with-{{ section.id }}">
      {%- if section.settings.pairs_well_with_title != blank -%}
        <div class="pairs-well-with-head_new">
          <h2 class="pairs-well-with-title_new">{{ section.settings.pairs_well_with_title }}</h2>
        </div>
      {%- endif -%}

      <div class="pairs-well-with-stack_new">
        {%- for block in section.blocks -%}
          {%- if block.type == 'pairs_well_with_product' and block.settings.product != blank -%}
            {%- assign slide_product = all_products[block.settings.product] -%}
            {%- if slide_product != blank -%}
              {% render 'pairs-well-with-slide', product: slide_product, section: section, block: block %}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  <style>
    .pairs-well-with_new {
      margin-top: 28px;
      width: 100%;
      max-width: 1200px;
      margin-left: auto;
      margin-right: auto;
    }

    .pairs-well-with-head_new {
      margin-bottom: 16px;
    }

    .pairs-well-with-title_new {
      margin: 0;
      font-family: "Barlow", "Barlow Fallback", sans-serif;
      font-size: 15px !important;
      font-weight: 700 !important;
      color: #111827 !important;
      text-align: left;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      line-height: 1.3;
    }

    .pairs-well-with-stack_new {
      display: flex;
      flex-direction: column;
      gap: 14px;
      width: 100%;
    }

    .pairs-well-with-card_new {
      border: 1px solid #eb701f;
      border-radius: 2px;
      padding: 16px 18px;
      background: transparent;
      box-sizing: border-box;
    }

    .pairs-well-with-content_new {
      display: flex;
      flex-direction: row;
      gap: 20px;
      align-items: center;
    }

    .pairs-well-with-image-wrapper_new {
      flex-shrink: 0;
    }

    .pairs-well-with-image-link_new {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 120px;
      height: 120px;
      background: transparent;
      border-radius: 4px;
      overflow: hidden;
    }

    .pairs-well-with-image_new {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
      padding: 6px;
    }

    .pairs-well-with-image-placeholder_new {
      width: 120px;
      height: 120px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: transparent;
    }

    .pairs-well-with-info-wrapper_new {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 0;
      align-items: flex-start;
    }

    .pairs-well-with-product-title_new {
      margin: 0 !important;
      font-family: "Barlow", "Barlow Fallback", sans-serif;
      font-size: 17px !important;
      font-weight: 700 !important;
      line-height: 1.25 !important;
    }

    .pairs-well-with-product-title_new a {
      color: #111827;
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .pairs-well-with-product-title_new a:hover {
      color: #eb701f;
    }

    .pairs-well-with-price_new {
      display: flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 10px;
    }

    .pairs-well-with-price-current_new {
      font-family: "Barlow", "Barlow Fallback", sans-serif;
      font-size: 22px !important;
      font-weight: 700 !important;
      color: #eb701f !important;
    }

    .pairs-well-with-price-original_new {
      font-size: 15px !important;
      color: #9ca3af;
      text-decoration: line-through;
    }

    .pairs-well-with-form_new {
      margin: 4px 0 0;
      width: 100%;
    }

    .pairs-well-with-add-btn_new {
      width: 100%;
      max-width: 220px;
      padding: 12px 24px !important;
      background: #111827;
      color: #fff !important;
      border: none;
      border-radius: 2px;
      font-family: "Barlow", "Barlow Fallback", sans-serif;
      font-size: 13px !important;
      font-weight: 700 !important;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.2s ease, opacity 0.2s ease;
    }

    .pairs-well-with-add-btn_new:hover:not(:disabled) {
      background: #1f2937;
    }

    .pairs-well-with-add-btn_new:disabled {
      background: #d1d5db;
      color: #6b7280 !important;
      cursor: not-allowed;
    }

    /* Mobile / coluna estreita: imagem à esquerda, texto e CTA à direita (poupa altura) */
    @media (max-width: 1024px) {
      .pairs-well-with_new {
        padding: 0 2px;
      }

      .pairs-well-with-stack_new {
        gap: 10px;
      }

      .pairs-well-with-card_new {
        padding: 10px 12px;
      }

      .pairs-well-with-content_new {
        flex-direction: row;
        align-items: center;
        gap: 12px;
        text-align: left;
      }

      .pairs-well-with-image-wrapper_new {
        flex-shrink: 0;
      }

      .pairs-well-with-image-link_new,
      .pairs-well-with-image-placeholder_new {
        width: 76px;
        height: 76px;
        max-width: none;
        margin: 0;
      }

      .pairs-well-with-info-wrapper_new {
        align-items: flex-start;
        width: auto;
        min-width: 0;
        flex: 1;
      }

      #pairs-well-with-{{ section.id }} .pairs-well-with-product-title_new {
        font-size: 14px !important;
        line-height: 1.25 !important;
      }

      .pairs-well-with-price_new {
        justify-content: flex-start;
        gap: 8px;
      }

      .pairs-well-with-price-current_new {
        font-size: 17px !important;
      }

      .pairs-well-with-price-original_new {
        font-size: 12px !important;
      }

      .pairs-well-with-form_new {
        margin-top: 6px;
        width: 100%;
        max-width: 100%;
      }

      .pairs-well-with-add-btn_new {
        width: 100%;
        max-width: 100%;
        padding: 8px 12px !important;
        font-size: 11px !important;
      }
    }
  </style>
{%- endif -%}
