                </div>
                <div class="rivyoReviewRatingIcon">
                  <svg fill="#ffcf47" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" version="1.1" id="Capa_1" x="0px" y="0px" width="20px" height="20px" viewBox="0 0 475.075 475.075" style="enable-background:new 0 0 475.075 475.075;" xml:space="preserve"><g><path d="M475.075,186.573c0-7.043-5.328-11.42-15.992-13.135L315.766,152.6L251.529,22.694c-3.614-7.804-8.281-11.704-13.99-11.704   c-5.708,0-10.372,3.9-13.989,11.704L159.31,152.6L15.986,173.438C5.33,175.153,0,179.53,0,186.573c0,3.999,2.38,8.567,7.139,13.706   l103.924,101.068L86.51,444.096c-0.381,2.666-0.57,4.575-0.57,5.712c0,3.997,0.998,7.374,2.996,10.136   c1.997,2.766,4.993,4.142,8.992,4.142c3.428,0,7.233-1.137,11.42-3.423l128.188-67.386l128.197,67.386   c4.004,2.286,7.81,3.423,11.416,3.423c3.819,0,6.715-1.376,8.713-4.142c1.992-2.758,2.991-6.139,2.991-10.136   c0-2.471-0.096-4.374-0.287-5.712l-24.555-142.749l103.637-101.068C472.604,195.33,475.075,190.76,475.075,186.573z"></path></g></svg>
                </div>
                <div class="rivyoReviewRatingIcon">
                  <svg fill="#ffcf47" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" version="1.1" id="Capa_1" x="0px" y="0px" width="20px" height="20px" viewBox="0 0 475.075 475.075" style="enable-background:new 0 0 475.075 475.075;" xml:space="preserve"><g><path d="M475.075,186.573c0-7.043-5.328-11.42-15.992-13.135L315.766,152.6L251.529,22.694c-3.614-7.804-8.281-11.704-13.99-11.704   c-5.708,0-10.372,3.9-13.989,11.704L159.31,152.6L15.986,173.438C5.33,175.153,0,179.53,0,186.573c0,3.999,2.38,8.567,7.139,13.706   l103.924,101.068L86.51,444.096c-0.381,2.666-0.57,4.575-0.57,5.712c0,3.997,0.998,7.374,2.996,10.136   c1.997,2.766,4.993,4.142,8.992,4.142c3.428,0,7.233-1.137,11.42-3.423l128.188-67.386l128.197,67.386   c4.004,2.286,7.81,3.423,11.416,3.423c3.819,0,6.715-1.376,8.713-4.142c1.992-2.758,2.991-6.139,2.991-10.136   c0-2.471-0.096-4.374-0.287-5.712l-24.555-142.749l103.637-101.068C472.604,195.33,475.075,190.76,475.075,186.573z"></path></g></svg>
                </div>
                <div class="rivyoReviewRatingIcon">
                  <svg fill="#ffcf47" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" version="1.1" id="Capa_1" x="0px" y="0px" width="20px" height="20px" viewBox="0 0 475.075 475.075" style="enable-background:new 0 0 475.075 475.075;" xml:space="preserve"><g><path d="M475.075,186.573c0-7.043-5.328-11.42-15.992-13.135L315.766,152.6L251.529,22.694c-3.614-7.804-8.281-11.704-13.99-11.704   c-5.708,0-10.372,3.9-13.989,11.704L159.31,152.6L15.986,173.438C5.33,175.153,0,179.53,0,186.573c0,3.999,2.38,8.567,7.139,13.706   l103.924,101.068L86.51,444.096c-0.381,2.666-0.57,4.575-0.57,5.712c0,3.997,0.998,7.374,2.996,10.136   c1.997,2.766,4.993,4.142,8.992,4.142c3.428,0,7.233-1.137,11.42-3.423l128.188-67.386l128.197,67.386   c4.004,2.286,7.81,3.423,11.416,3.423c3.819,0,6.715-1.376,8.713-4.142c1.992-2.758,2.991-6.139,2.991-10.136   c0-2.471-0.096-4.374-0.287-5.712l-24.555-142.749l103.637-101.068C472.604,195.33,475.075,190.76,475.075,186.573z"></path></g></svg>
                </div>
                <div class="rivyoReviewRatingIcon">
                    <svg fill="#ffcf47" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" version="1.1" id="Capa_1" x="0px" y="0px" width="20px" height="20px" viewBox="0 0 475.075 475.075" style="enable-background:new 0 0 475.075 475.075;" xml:space="preserve"><g><path d="M475.075,186.573c0-7.043-5.328-11.42-15.992-13.135L315.766,152.6L251.529,22.694c-3.614-7.804-8.281-11.704-13.99-11.704   c-5.708,0-10.372,3.9-13.989,11.704L159.31,152.6L15.986,173.438C5.33,175.153,0,179.53,0,186.573c0,3.999,2.38,8.567,7.139,13.706   l103.924,101.068L86.51,444.096c-0.381,2.666-0.57,4.575-0.57,5.712c0,3.997,0.998,7.374,2.996,10.136   c1.997,2.766,4.993,4.142,8.992,4.142c3.428,0,7.233-1.137,11.42-3.423l128.188-67.386l128.197,67.386   c4.004,2.286,7.81,3.423,11.416,3.423c3.819,0,6.715-1.376,8.713-4.142c1.992-2.758,2.991-6.139,2.991-10.136   c0-2.471-0.096-4.374-0.287-5.712l-24.555-142.749l103.637-101.068C472.604,195.33,475.075,190.76,475.075,186.573z"></path></g></svg>
                </div>
              </div>
              
              <span class="rivyoReviewAverage">
                <span class="rivyoReviewAverageCount">4.6</span>
                <span class="reviewRateCount">
                  <span class="rivyoReviewAverageBracket">(</span>
                  <span class="ratingCount">7</span>
                  <span class="ratingLabel">Reviews</span>
                  <span class="rivyoReviewAverageBracket">)</span>
                </span>
              </span>
            </div>
          {% endif %}
        </div>
    </div>
  {%- endif -%}
  <!-- Product Subtitle -->
  {%- if section.settings.product_subtitle != blank -%}
    <p class="product-subtitle_new">{{ section.settings.product_subtitle }}</p>
  {%- endif -%}

  <!-- Desktop Price -->
  <div class="product-price-section_new">
    <div class="product-price-container_new">
      <p class="product-price_new black">{{ product.selected_or_first_available_variant.price | money }}</p>
      {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
        <p class="product-price-original_new">{{ product.selected_or_first_available_variant.compare_at_price | money }}</p>
      {%- endif -%}
    </div>

    <!-- Variant Selector for Mobile (only shown on mobile, next to price) -->
    {%- if product.variants.size > 1 and section.settings.show_variant_selector -%}
      {%- assign selected_variant = product.selected_or_first_available_variant -%}
      <div class="variant-selector-wrapper_new variant-selector-mobile_new">
        <label for="variant-selector-mobile_new" class="sr-only">{{ section.settings.variant_label | default: "Select Option" }}</label>
        <select
          id="variant-selector-mobile_new"
          class="variant-selector_new variant-selector-mobile_new"
          name="id">
          {%- for variant in product.variants -%}
            <option
              value="{{ variant.id }}"
              {% if variant == selected_variant %}
              selected{% endif %}
              {% unless variant.available %}
              disabled{% endunless %}>
              {{ variant.title }}
              {%- unless variant.available %}
                - Sold Out{% endunless -%}
            </option>
          {%- endfor -%}
        </select>
      </div>
    {%- endif -%}

    <!-- AtivaPeople Badge (same metafield as member line; computed once at top of snippet) -->
    {%- if section.settings.show_ativapeople_badge -%}
      <div
        class="ativapeople-badge_new"
        data-ativapeople-fixed-cents="{{ ativapeople_display_cents }}"
        {% unless ap_mf_fixed %}style="display: none;"{% endunless %}>
        <div class="ativapeople-message">
          <span class="ativapeople-text">Join <a href="/pages/membership" class="ativapeople-link">AtivaPeople</a> for</span>
          <span class="ativapeople-price">{{ ativapeople_display_cents | money }}</span>
        </div>
      </div>
    {%- endif -%}

    {%- liquid
      assign wds_ps = product.metafields.product_schema
      assign wds_pill_rating = nil
      assign wds_pill_count = 0
      if wds_ps.th_ratingValue != blank
        assign wds_pill_rating = wds_ps.th_ratingValue | plus: 0.0
        assign wds_pill_count = wds_ps.th_ratingCount | default: 0 | plus: 0
      endif
      if wds_pill_count == 0 or wds_pill_rating == blank
        assign wds_rm = product.metafields.reviews.rating
        assign wds_rc = product.metafields.reviews.rating_count
        if wds_rm != blank
          assign wds_ro = wds_rm.value | default: wds_rm
          assign wds_cc = wds_rc.value | default: wds_rc | default: 0 | plus: 0
          if wds_ro != blank and wds_cc > 0
            assign wds_pill_rating = wds_ro.rating | plus: 0.0
            assign wds_pill_count = wds_cc
          endif
        endif
      endif
    -%}
    {%- if wds_pill_rating != blank and wds_pill_count > 0 -%}
      <div
        class="product-info-rating-pill"
        role="img"
        aria-label="Rating {{ wds_pill_rating | round: 2 }} out of 5, {{ wds_pill_count }} reviews">
        <svg
          class="product-info-rating-pill__star"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          aria-hidden="true"
          focusable="false">
          <path fill="currentColor" d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
        </svg>
        <span class="product-info-rating-pill__value">{{ wds_pill_rating | round: 2 }}</span>
        <span class="product-info-rating-pill__sep" aria-hidden="true">·</span>
        <span class="product-info-rating-pill__count">{{ wds_pill_count }} reviews</span>
      </div>
    {%- endif -%}
  </div>

  {%- if ap_mf_fixed and ativapeople_display_cents > 0 -%}
    <p class="product-info-member-line_new">
      <span class="product-info-member-line__muted">Member price </span>
      <span class="product-info-member-line__price">{{ ativapeople_display_cents | money }}</span>
      <span class="product-info-member-line__muted" aria-hidden="true"> · </span>
      <a href="/pages/membership" class="product-info-member-line__link">Join AtivaPeople</a>
    </p>
  {%- endif -%}

  <!-- Mini Media Mentions (only when enabled in section settings) -->
  {% if section.settings.show_media_mentions_carousel == true %}
    {% render 'product-media-mentions', section: section %}
  {% endif %}

</div>