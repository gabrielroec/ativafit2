{% comment %}
  Product Info Component
  Renders product information including title, subtitle, price, reviews, and features.
  Accepts:
  - product: {Object} Product object
  - section: {Object} Section object for settings

  AtivaPeople — preço só via custom.price_discount_ativapeople
  - Ordem: variante → produto (sem loja). Se nenhum tiver valor, badge não aparece.
  - Vírgula decimal (Shopify BR/EU) normalizada antes de | plus.
{% endcomment %}

{%- liquid
  assign ativapeople_display_cents = 0
  assign ap_mf_fixed = false
  assign current_variant = product.selected_or_first_available_variant
  assign mf_v = current_variant.metafields.custom.price_discount_ativapeople
  assign mf_p = product.metafields.custom.price_discount_ativapeople
  assign mf_use = mf_v
  unless mf_v != blank and mf_v.value != blank
    assign mf_use = mf_p
    unless mf_p != blank and mf_p.value != blank
      assign mf_use = blank
    endunless
  endunless
  if mf_use != blank and mf_use.value != blank
    assign ap_mf_fixed = true
    assign _raw = ''
    if mf_use.value.amount != blank
      assign _raw = mf_use.value.amount | append: '' | strip
    else
      assign _raw = mf_use.value | append: '' | strip
    endif
    assign _raw = _raw | replace: ' ', '' | replace: ' ', '' | replace: "'", ''
    if _raw contains ','
      assign _pa = _raw | split: ','
      if _pa.size == 2
        assign _L = _pa[0] | strip
        assign _R = _pa[1] | strip
        assign _rL = _R | size
        if _rL == 1 or _rL == 2
          assign _L = _L | replace: '.', ''
          assign _raw = _L | append: '.' | append: _R
        elsif _rL == 3
          if _L contains '.'
            assign _L = _L | replace: '.', ''
            assign _raw = _L | append: '.' | append: _R
          else
            assign _raw = _L | append: _R
          endif
        else
          assign _L = _L | replace: '.', ''
          assign _raw = _L | append: '.' | append: _R
        endif
      else
        assign _raw = _raw | replace: '.', '' | replace: ',', '.'
      endif
    endif
    assign _u = _raw | plus: 0.0
    assign ativapeople_display_cents = _u | times: 100 | round
  endif
  if ativapeople_display_cents < 0
    assign ativapeople_display_cents = 0
  endif
-%}

<div class="product-info-container_new">
  <!-- Product Badges -->
  {%- if section.settings.show_badges -%}
    {%- assign badge_blocks = section.blocks | where: 'type', 'product_badge' -%}
    {%- if badge_blocks.size > 0 -%}
      <div class="product-badges_new">
        {%- for block in badge_blocks -%}
          {%- if block.settings.badge_text != blank -%}
            <span class="product-badge_new" {{ block.shopify_attributes }}>
              {{ block.settings.badge_text }}
            </span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endif -%}

  <!-- Product Title -->
  <h1 class="product-name_new">
    {%- if section.settings.product_title != blank -%}
      {{ section.settings.product_title }}
    {%- else -%}
      {{ product.title }}
    {%- endif -%}
  </h1>
  <!-- Reviews -->
  {%- assign reviews_block = section.blocks | where: 'type', 'reviews' | first -%}
  {%- if reviews_block and reviews_block.settings.enabled and reviews_block.settings.review_text != blank -%}
    <div class="review_new" {% if product.handle == '50lbs' %}style="display: none;"{% endif %}>
       <div class="review">
          <!-- Rivyo Product Badge Rating - Dinâmico -->
          {%- assign productRivyoReview = product.metafields.product_schema -%}
          {%- assign shopRivyoReview = shop.metafields.rivyo -%}
          {%- assign shopRivyoReviewSetting = shopRivyoReview.setting.value -%}
          {%- assign productRivyoRating = productRivyoReview.th_ratingValue | split:'.' | default: '0' -%}
          {%- assign rivyoRatingSplit0 = productRivyoRating[0] | times: 1 -%}
          {%- assign rivyoRatingSplit1 = productRivyoRating[1] | default: '00' -%}
          {%- assign rivyoRatingCeil = productRivyoReview.th_ratingValue | ceil -%}
          {% assign hide_non_ratting_review = shopRivyoReviewSetting.hide_empty_review | times: 1 %}
          {% assign is_empty = false %}
          {% assign isClick = true %}
          
          <div class="rivyoReviewWidget rivyoWidgetTrigger" data-rating="{{ productRivyoReview.th_ratingValue | default: '00' }}" style="display:none;">
            <div class="rivyoReviewIcon" style="display:flex; gap:3px; line-height: 0; flex-direction: row">
              {%- for i in (1..5) -%}
                {% if hide_non_ratting_review == 0 or rivyoRatingSplit0 != 0 %}
                  <div class="rivyoReviewRatingIcon">
                    {{ shopRivyoReviewSetting.rating_icon }}
                    </div>
                  {% else %}
                    {% assign is_empty = true %}
                {% endif %}
              {%- endfor -%}
            </div>
            {% if is_empty != true %}
              <span class="rivyoReviewAverage">
                <span class="rivyoReviewAverageCount">
                  {{- productRivyoReview.th_ratingValue | default: 0 | round: 1 }}
                </span>
                <span class="reviewRateCount">
                  <span class="rivyoReviewAverageBracket">(</span>
                  <span class="ratingCount">{{- productRivyoReview.th_ratingCount | default: 0 }}</span>
                  <span class="ratingLabel"> {{ shopRivyoReview.average_review_label }}</span>
                  <span class="rivyoReviewAverageBracket">)</span>
                </span>
              </span>
            {% endif %}
          </div>
          
          <!-- Fallback para quando não há reviews do Rivyo -->
          {% if is_empty == true or productRivyoReview.th_ratingValue == blank %}
            <div class="rivyo-fallback-rating">
              <div class="rivyoReviewIcon" style="display:flex; gap:3px; line-height: 0; flex-direction: row">
                <div class="rivyoReviewRatingIcon">
