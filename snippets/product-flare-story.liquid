{% comment %}
  Bloco editorial (título + corpo rich text) — abaixo da flare-pdp__trust-strip.
{% endcomment %}

{%- if section.settings.show_flare_story -%}
  {%- if section.settings.flare_story_heading != blank or section.settings.flare_story_body != blank -%}
    <div class="flare-story">
      {%- if section.settings.flare_story_heading != blank -%}
        <h2 class="flare-story__heading">{{ section.settings.flare_story_heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.flare_story_body != blank -%}
        <div class="flare-story__body rte">{{ section.settings.flare_story_body }}</div>
      {%- endif -%}
    </div>
  {%- endif -%}
{%- endif -%}
