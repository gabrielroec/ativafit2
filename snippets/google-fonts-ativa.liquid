{%- comment -%}
  Ativafit — Space Grotesk, Lexend e Material Symbols (Google Fonts).

  - Um único CSS para texto (Space Grotesk + Lexend) = menos round-trips.
  - Ícones em folha separada para não misturar prioridade com texto.
  - Preload + onload: mesmo padrão de theme.liquid (Barlow/Inter), não bloqueia parsing.
  - display=swap no URL: reduz FOIT, melhora percepção de carregamento e alinha a Core Web Vitals.

  Uso tipográfico: variáveis em snippets/css-variables.liquid (--font-ativa-*).
{%- endcomment -%}

{%- capture gf_ativa_text -%}
https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;900&family=Lexend:wght@300;400;500;600;700&display=swap
{%- endcapture -%}
{%- capture gf_ativa_icons -%}
https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap
{%- endcapture -%}

<link
  rel="preload"
  as="style"
  href="{{ gf_ativa_text | strip }}"
  onload="this.onload=null;this.rel='stylesheet'">
<noscript>
  <link rel="stylesheet" href="{{ gf_ativa_text | strip }}">
</noscript>

<link
  rel="preload"
  as="style"
  href="{{ gf_ativa_icons | strip }}"
  onload="this.onload=null;this.rel='stylesheet'">
<noscript>
  <link rel="stylesheet" href="{{ gf_ativa_icons | strip }}">
</noscript>

<style id="google-fonts-ativa-icons">
  .material-symbols-outlined {
    font-family: 'Material Symbols Outlined', sans-serif;
    font-weight: normal;
    font-style: normal;
    font-size: 24px;
    line-height: 1;
    letter-spacing: normal;
    text-transform: none;
    display: inline-block;
    white-space: nowrap;
    direction: ltr;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
</style>
