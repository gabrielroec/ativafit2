{%- comment -%}
  Inline SVG icon set — replaces the Material Symbols Outlined web font on
  the homepage and any other page that uses the ligature names below.

  Usage:
    {% render 'inline-icon', name: 'local_shipping', class: 'foo', size: 24 %}

  Visual parity with Material Symbols Outlined (24px viewBox, currentColor
  stroke/fill). When `name` is unknown, falls back to a small dot-grid icon
  so layout is preserved.

  Why: Material Symbols variable font is ~hundreds of KB, which we save
  entirely on the home page. Each SVG below is ~200–500 bytes.
{%- endcomment -%}

{%- liquid
  assign ico_class = class | default: ''
  assign ico_size = size | default: 24
  assign ico_name = name | default: '' | strip
  assign ico_label = label | default: ''
-%}
{%- capture ico_attrs -%}xmlns="http://www.w3.org/2000/svg" width="{{ ico_size }}" height="{{ ico_size }}" viewBox="0 0 24 24" fill="currentColor"{% if ico_class != blank %} class="{{ ico_class }}"{% endif %}{% if ico_label != blank %} role="img" aria-label="{{ ico_label | escape }}"{% else %} aria-hidden="true" focusable="false"{% endif %}{%- endcapture -%}

{%- case ico_name -%}
  {%- when 'local_shipping' -%}
    <svg {{ ico_attrs }}><path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm12.5-9l1.96 2.5H17V9.5h1.5zm-.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg>
  {%- when 'replay' -%}
    <svg {{ ico_attrs }}><path d="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"/></svg>
  {%- when 'Star', 'star' -%}
    <svg {{ ico_attrs }}><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
  {%- when 'verified' -%}
    <svg {{ ico_attrs }}><path d="M23 12l-2.44-2.79.34-3.69-3.61-.82-1.89-3.2L12 2.96 8.6 1.5 6.71 4.69 3.1 5.5l.34 3.7L1 12l2.44 2.79-.34 3.7 3.61.82L8.6 22.5 12 21.04l3.4 1.46 1.89-3.19 3.61-.82-.34-3.69L23 12zm-12.91 4.72-3.8-3.81 1.48-1.48 2.32 2.33 5.85-5.87 1.48 1.48-7.33 7.35z"/></svg>
  {%- when 'arrow_forward' -%}
    <svg {{ ico_attrs }}><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>
  {%- when 'widgets' -%}
    <svg {{ ico_attrs }}><path d="M13 13v8h8v-8h-8zM3 21h8v-8H3v8zM3 3v8h8V3H3zm13.66-1.31L11 7.34 16.66 13l5.66-5.66z"/></svg>
  {%- when 'speed' -%}
    <svg {{ ico_attrs }}><path d="M20.38 8.57l-1.23 1.85a8 8 0 01-.22 7.58H5.07A8 8 0 0115.58 6.85l1.85-1.23A10 10 0 003.35 19h17.3a10 10 0 00-.27-10.43zm-9.79 6.84a2 2 0 002.83 0l5.66-8.49-8.49 5.66a2 2 0 000 2.83z"/></svg>
  {%- when 'architecture' -%}
    <svg {{ ico_attrs }}><path d="M14.84 16.26c-1.84-1.32-3.42-3-3.42-5.59 0-2.28 1.79-4.13 4.04-4.13s4.04 1.85 4.04 4.13c0 2.59-1.58 4.27-3.42 5.59-.71.51-.93 1.36-.93 2.18V20c0 .55-.45 1-1 1s-1-.45-1-1v-1.56c0-.82-.22-1.67-.93-2.18zM3 20v-9h2v9c0 .55.45 1 1 1s1-.45 1-1v-9h2v9c0 1.66-1.34 3-3 3s-3-1.34-3-3zM6 9c1.66 0 3-1.34 3-3 0-1.31-.83-2.42-2-2.83V2H5v1.17C3.83 3.58 3 4.69 3 6c0 1.66 1.34 3 3 3z"/></svg>
  {%- when 'lock' -%}
    <svg {{ ico_attrs }}><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1s3.1 1.39 3.1 3.1v2z"/></svg>
  {%- when 'image' -%}
    <svg {{ ico_attrs }}><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
  {%- when 'play_circle' -%}
    <svg {{ ico_attrs }}><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
  {%- else -%}
    {%- comment -%} Unknown icon name — neutral 4-dot fallback (avoids broken layout). {%- endcomment -%}
    <svg {{ ico_attrs }}><circle cx="6" cy="6" r="2"/><circle cx="18" cy="6" r="2"/><circle cx="6" cy="18" r="2"/><circle cx="18" cy="18" r="2"/></svg>
{%- endcase -%}
