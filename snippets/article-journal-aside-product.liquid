{%- comment -%} Product card em formato banner (horizontal): imagem + título/preço/CTA. Para asides do article journal. {%- endcomment -%}
{%- if product != blank -%}
  {%- assign v = product.selected_or_first_available_variant -%}
  {%- assign img = v.image | default: product.featured_image -%}
  {%- assign img_alt = img.alt | default: product.title | escape -%}
  <article class="article-journal-aside-card" data-aside-product>
    <a href="{{ product.url }}" class="article-journal-aside-card__link">
      <div class="article-journal-aside-card__image">
        {%- if img -%}
          {{ img | image_url: width: 320 | image_tag: loading: 'lazy', widths: '80,120,160', sizes: '80px', alt: img_alt, class: 'article-journal-aside-card__img' }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'article-journal-aside-card__placeholder' }}
        {%- endif -%}
      </div>
      <div class="article-journal-aside-card__info">
        <p class="article-journal-aside-card__title">{{ product.title | escape }}</p>
        <p class="article-journal-aside-card__price">
          {%- if v.compare_at_price > v.price -%}
            <span class="article-journal-aside-card__price-current">{{ v.price | money }}</span>
            <span class="article-journal-aside-card__price-compare">{{ v.compare_at_price | money }}</span>
          {%- else -%}
            <span class="article-journal-aside-card__price-current">{{ v.price | money }}</span>
          {%- endif -%}
        </p>
        <span class="article-journal-aside-card__cta">View product</span>
      </div>
    </a>
  </article>
{%- endif -%}
