{% comment %}
  PDP — linha de confiança (2 badges: garantia + compra tranquila).
  Substitui o carrossel Embla de "Benefit" blocks.
  Blocos: `pdp_trust_badge` (máx. 2). Sem blocos: usa arquivos em Admin → Conteúdo → Arquivos.
  Requer: section com `show_benefits` (mesmo interruptor da seção Product Main).
  Uso: {% render 'product-benefits', section: section, product: product %}
{% endcomment %}

{%- if section.settings.show_benefits -%}
  {%- liquid
    assign hide_trust_badges_on_handles = 'dumbbell-stand-accessories,f8-foldable-exercise-bike-accessories,r8-foldable-exercise-bike-accessories,36-foldable-trampoline-rebounder-accessories' | split: ','
    assign hide_trust_badges_row = false
    if product != blank and hide_trust_badges_on_handles contains product.handle
      assign hide_trust_badges_row = true
    endif
  -%}
  {%- unless hide_trust_badges_row -%}
  {%- liquid
    assign trust_blocks = section.blocks | where: 'type', 'pdp_trust_badge'
    assign warranty_file = 'high-quality-_-durable-performance.png' | file_url
    assign support_file = 'customer-support.png' | file_url
  -%}
  <div class="pdp-trust-row" data-pdp-trust-row>
    {%- if trust_blocks.size > 0 -%}
      {%- for block in trust_blocks limit: 2 -%}
        {%- liquid
          if block.settings.image != blank
            assign tb_img = block.settings.image | image_url: width: 90, format: 'webp'
          elsif forloop.index == 1
            assign tb_img = warranty_file
          else
            assign tb_img = support_file
          endif
          assign tb_w = 45
          assign tb_h = 45
          assign tb_label = block.settings.label | default: ''
          if tb_label == blank
            if forloop.index == 1
              assign tb_label = '1-Year Warranty Included'
            else
              assign tb_label = 'Worry-Free Purchase'
            endif
          endif
        -%}
        <div class="pdp-trust-badge" {{ block.shopify_attributes }}>
          <div class="pdp-trust-badge__icon">
            <img
              src="{{ tb_img }}"
              alt="{{ tb_label | escape }}"
              width="{{ tb_w }}"
              height="{{ tb_h }}"
              loading="lazy"
              decoding="async">
          </div>
          <span class="pdp-trust-badge__text">{{ tb_label | escape }}</span>
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="pdp-trust-badge">
        <div class="pdp-trust-badge__icon">
          <img
            src="{{ warranty_file }}"
            alt="{{ '1-Year Warranty Included' | escape }}"
            width="45"
            height="45"
            loading="lazy"
            decoding="async">
        </div>
        <span class="pdp-trust-badge__text">1-Year Warranty Included</span>
      </div>
      <div class="pdp-trust-badge">
        <div class="pdp-trust-badge__icon">
          <img
            src="{{ support_file }}"
            alt="{{ 'Worry-Free Purchase' | escape }}"
            width="45"
            height="45"
            loading="lazy"
            decoding="async">
        </div>
        <span class="pdp-trust-badge__text">Worry-Free Purchase</span>
      </div>
    {%- endif -%}
  </div>
  {%- endunless -%}
{%- endif -%}
