{% comment %}
  Mini Media Mentions Carousel
  Renders small media review cards as a carousel.
  Accepts:
  - section: {Object} Section object for settings and blocks
{% endcomment %}

{%- assign mention_blocks = section.blocks | where: 'type', 'mini_media_mention' -%}
{%- if mention_blocks.size > 0 -%}
  <div class="product-media-mentions_new" data-media-mentions-carousel>
    <div class="product-media-mentions-inner">
      <div
        class="product-media-mentions-viewport"
        data-media-mentions-viewport
        role="region"
        aria-label="Menções na mídia">
        <div class="product-media-mentions-track">
          {%- for block in mention_blocks -%}
            <div class="product-media-mentions-slide" {{ block.shopify_attributes }}>
              <div class="product-media-mentions-card">
                <div class="product-media-mentions-logo">
                  {%- if block.settings.logo != blank -%}
                    {{ block.settings.logo | image_url: width: 150 | image_tag: loading: 'lazy' }}
                  {%- elsif block.settings.logo_asset != blank -%}
                    <img
                      src="{{ block.settings.logo_asset | asset_url }}"
                      alt="Media Logo"
                      loading="lazy"
                      width="100"
                      height="30">
                  {%- endif -%}
                </div>
                <p class="product-media-mentions-text">"{{ block.settings.text }}"
              </p>

                {%- comment -%} Mini product info {%- endcomment -%}
                {%- assign block_product = block.settings.product | default: product -%}
                {%- if block_product != blank -%}
                  <div class="product-media-mentions-product">
                    {%- if block_product.featured_image -%}
                      <img
                        class="product-media-mentions-product-img"
                        src="{{ block_product.featured_image | image_url: width: 80 }}"
                        alt="{{ block_product.title | escape }}"
                        loading="lazy"
                        width="40"
                        height="40">
                    {%- endif -%}
                    <div class="product-media-mentions-product-info">
                      <p class="product-media-mentions-product-title">{{ block_product.title }}</p>
                      <p class="product-media-mentions-product-price">{{ block_product.price | money }}</p>
                    </div>
                  </div>
                {%- endif -%}

                {%- if block.settings.link != blank -%}
                  <a
                    href="{{ block.settings.link }}"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="product-media-mentions-link">Read full review</a>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
    {%- if mention_blocks.size > 1 -%}
      <div class="product-media-mentions-nav">
        <button
          type="button"
          class="product-media-mentions-btn product-media-mentions-prev"
          aria-label="Anterior"
          data-media-mentions-prev
          disabled>
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"><path
              d="M15 18l-6-6 6-6"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round" /></svg>
        </button>
        <button
          type="button"
          class="product-media-mentions-btn product-media-mentions-next"
          aria-label="Próximo"
          data-media-mentions-next>
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"><path
              d="M9 18l6-6-6-6"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round" /></svg>
        </button>
      </div>
    {%- endif -%}
  </div>
{%- endif -%}