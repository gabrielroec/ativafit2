{%- comment -%}
  Trust bar tiny critical CSS to reserve a 1-line height and prevent
  layout shift while trust-bar-ativa.css arrives async.
{%- endcomment -%}
<style>
.trust-bar-ativa{display:block;min-height:60px}
.trust-bar-ativa__inner{max-width:1280px;margin:0 auto;padding:14px 16px}
.trust-bar-ativa__grid{display:flex;flex-wrap:wrap;gap:16px;margin:0;padding:0;list-style:none;justify-content:center;align-items:center}
.trust-bar-ativa__item{display:flex;align-items:center;gap:8px}
.trust-bar-ativa__icon{display:inline-flex;align-items:center;justify-content:center;width:1.875rem;height:1.875rem}
.trust-bar-ativa__icon svg{width:100%;height:100%;display:block}
</style>
{{ 'trust-bar-ativa.css' | asset_url | stylesheet_tag: preload: true }}
<script src="{{ 'trust-bar-ativa.js' | asset_url }}" defer></script>

{%- liquid
  assign stagger = section.settings.stagger_ms | default: 90
  assign border_custom = section.settings.border_color
-%}

<section
  class="trust-bar-ativa"
  style="
    background-color: {{ section.settings.background_color }};
    border-bottom-color: {{ border_custom | color_modify: 'alpha', 0.1 }};
    --trust-bar-icon: {{ section.settings.icon_color }};
    --trust-bar-text: {{ section.settings.text_color }};
  "
  data-trust-bar-ativa
  aria-label="{{ section.settings.section_label | default: 'Benefits and guarantees' | escape }}"
  {{ section.shopify_attributes }}>
  <div class="trust-bar-ativa__inner">
    {%- if section.blocks.size > 0 -%}
      <ul class="trust-bar-ativa__grid" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'item' -%}
            <li
              class="trust-bar-ativa__item"
              style="--trust-stagger: {{ forloop.index0 | times: stagger }}ms"
              {{ block.shopify_attributes }}>
              <span
                class="trust-bar-ativa__icon"
                style="color: var(--trust-bar-icon);"
                aria-hidden="true">{%- render 'inline-icon', name: block.settings.icon, class: 'trust-bar-ativa__icon-svg', size: 24 -%}</span>
              <span class="trust-bar-ativa__text" style="color: var(--trust-bar-text);">{{ block.settings.text | escape }}</span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Trust bar Ativa",
  "tag": "section",
  "class": "shopify-section-trust-bar-ativa",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "section_label",
      "label": "Region name (accessibility)",
      "default": "Benefits and guarantees"
    },
    {
      "type": "range",
      "id": "stagger_ms",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "ms",
      "label": "Delay between each block (animation)",
      "default": 90,
      "info": "0 = all at once. Ignored if the user prefers reduced motion."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f3f3f3"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Bottom border base color",
      "default": "#dfc0b2",
      "info": "Line opacity is applied automatically (~10%)."
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icons",
      "default": "#eb701f"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#574237"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name (Material Symbols)",
          "default": "star",
          "info": "e.g. star, local_shipping, replay, verified. List at fonts.google.com/icons"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "4.9/5 from 2,000+ Reviews"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust bar Ativa",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "star",
            "text": "4.9/5 from 2,000+ Reviews"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "local_shipping",
            "text": "Free Shipping within US"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "replay",
            "text": "30-Day Returns"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "verified",
            "text": "1-Year Warranty"
          }
        }
      ]
    }
  ]
}
{% endschema %}
