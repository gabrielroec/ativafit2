{%- assign words = article.content | strip_html | strip_newlines | split: ' ' | size -%}
{%- assign reading_minutes = words | plus: 199 | divided_by: 200 -%}
{%- if reading_minutes < 1 -%}{%- assign reading_minutes = 1 -%}{%- endif -%}

<article class="article-journal" id="ArticleJournal-{{ section.id }}" data-section-id="{{ section.id }}" role="article">
  <header class="article-journal__header">
    <div class="article-journal__banner">
      {%- if article.image -%}
        {{ article.image | image_url: width: 1920 | image_tag: loading: 'eager', widths: '600,900,1200,1920', sizes: '100vw', class: 'article-journal__banner-image', alt: article.image.alt | default: article.title | escape }}
      {%- else -%}
        <div class="article-journal__banner-placeholder" aria-hidden="true"></div>
      {%- endif -%}
      <div class="article-journal__banner-overlay" aria-hidden="true"></div>
    </div>
    <div class="article-journal__header-inner">
      <div class="article-journal__container article-journal__container--narrow">
        {%- if section.settings.show_category and article.tags.size > 0 -%}
          <a href="{{ blog.url }}/tagged/{{ article.tags.first | handle }}" class="article-journal__category">{{ article.tags.first }}</a>
        {%- endif -%}
        <h1 class="article-journal__title">{{ article.title }}</h1>
        <div class="article-journal__meta" role="list">
          {%- if section.settings.show_author -%}<span class="article-journal__meta-item" role="listitem">{{ article.author }}</span>{%- endif -%}
          {%- if section.settings.show_date -%}<time class="article-journal__meta-item" datetime="{{ article.published_at | date: '%Y-%m-%d' }}" role="listitem">{{ article.published_at | date: format: 'month_day_year' }}</time>{%- endif -%}
          {%- if section.settings.show_reading_time -%}<span class="article-journal__meta-item article-journal__meta-item--reading" role="listitem">{{ reading_minutes }} min read</span>{%- endif -%}
        </div>
      </div>
    </div>
  </header>

  {%- assign side_products = article.metafields.custom.side_product_card.value -%}

  <div class="article-journal__body">
    <div class="article-journal__container article-journal__body-inner{% if side_products != blank and side_products.size > 0 %} article-journal__body-inner--with-aside{% endif %}">
      <nav class="article-journal__toc" aria-label="Table of contents" id="article-journal-toc-{{ section.id }}">
        <button type="button" class="article-journal__toc-mobile-toggle" data-mobile-toc-toggle aria-expanded="false" aria-controls="article-journal-toc-panel-{{ section.id }}">
          Contents
        </button>
        <div class="article-journal__toc-mobile-panel" id="article-journal-toc-panel-{{ section.id }}" data-mobile-toc-panel aria-hidden="true">
          <ol class="article-journal__toc-list" id="article-journal-toc-list-{{ section.id }}"></ol>
        </div>
      </nav>
      <div class="article-journal__main">
        <div class="article-journal__content rte" id="article-journal-content">{{ article.content }}</div>
        {%- if section.settings.show_tags and article.tags.size > 0 -%}
          <div class="article-journal__tags">
            <span class="article-journal__tags-label">{{ 'blog.article.tags' | t | default: 'Tags' }}:</span>
            {%- for tag in article.tags -%}<a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="article-journal__tag">{{ tag }}</a>{% unless forloop.last %}, {% endunless %}{%- endfor -%}
          </div>
        {%- endif -%}
        {%- if section.settings.show_share -%}
          <div class="article-journal__share">
            <span class="article-journal__share-label">{{ 'blog.article.share' | t | default: 'Share' }}</span>
            {%- assign share_url = shop.url | append: article.url -%}
            {%- assign share_title = article.title | url_param_escape -%}
            <a href="https://www.facebook.com/sharer.php?u={{ share_url }}" target="_blank" rel="noopener noreferrer" class="article-journal__share-link" aria-label="Share on Facebook">Facebook</a>
            <a href="https://twitter.com/share?text={{ share_title }}&url={{ share_url }}" target="_blank" rel="noopener noreferrer" class="article-journal__share-link" aria-label="Share on Twitter">Twitter</a>
            <a href="https://www.linkedin.com/shareArticle?mini=true&url={{ share_url }}&title={{ share_title }}" target="_blank" rel="noopener noreferrer" class="article-journal__share-link" aria-label="Share on LinkedIn">LinkedIn</a>
          </div>
        {%- endif -%}
        {%- if section.settings.show_prev_next -%}
          {%- if blog.previous_article or blog.next_article -%}
            <nav class="article-journal__nav" aria-label="Article navigation">
              {%- if blog.next_article -%}<a href="{{ blog.next_article.url }}" class="article-journal__nav-link article-journal__nav-link--prev" rel="prev"><span class="article-journal__nav-label">&larr; {{ 'blog.article.previous_article' | t | default: 'Previous' }}</span><span class="article-journal__nav-title">{{ blog.next_article.title }}</span></a>{%- endif -%}
              {%- if blog.previous_article -%}<a href="{{ blog.previous_article.url }}" class="article-journal__nav-link article-journal__nav-link--next" rel="next"><span class="article-journal__nav-label">{{ 'blog.article.next_article' | t | default: 'Next' }} &rarr;</span><span class="article-journal__nav-title">{{ blog.previous_article.title }}</span></a>{%- endif -%}
            </nav>
          {%- endif -%}
        {%- endif -%}
      </div>
      {%- if side_products != blank and side_products.size > 0 -%}
        <aside class="article-journal__aside" aria-label="{{ 'blogs.article.related_products' | t | default: 'Related products' }}">
          <div class="article-journal__aside-banner">
            {%- if section.settings.aside_heading != blank -%}
              <h3 class="article-journal__aside-heading">{{ section.settings.aside_heading | escape }}</h3>
            {%- endif -%}
            <div class="article-journal__aside-products">
              {%- for product_ref in side_products -%}
                {%- if product_ref != blank -%}
                  {% render 'article-journal-aside-product', product: product_ref %}
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        </aside>
      {%- endif -%}
    </div>
  </div>
</article>

<script src="{{ 'article-inline-cards.js' | asset_url }}" defer></script>
<script>
(function() {
  function slugify(text) {
    return text.trim().toLowerCase()
      .replace(/[^\w\s-]/g, '')
      .replace(/[\s_-]+/g, '-')
      .replace(/^-+|-+$/g, '') || 'section';
  }
  function initToc() {
    var article = document.querySelector('.article-journal');
    if (!article) return;
    var content = document.getElementById('article-journal-content');
    var tocList = article.querySelector('[id^="article-journal-toc-list-"]');
    var bodyInner = article.querySelector('.article-journal__body-inner');
    if (!content || !tocList || !bodyInner) return;
    /* Apenas H2 no sumário — navegação lateral mais curta e limpa */
    var headings = content.querySelectorAll('h2');
    if (headings.length === 0) return;
    var idx = 0;
    headings.forEach(function(h) {
      if (!h.id) h.id = 'toc-' + slugify(h.textContent) + '-' + (idx++);
      var li = document.createElement('li');
      var a = document.createElement('a');
      a.href = '#' + h.id;
      a.textContent = h.textContent.trim();
      a.className = 'article-journal__toc-link';
      a.setAttribute('data-toc-id', h.id);
      li.appendChild(a);
      tocList.appendChild(li);
    });
    initMobileTocCollapsible(article);
    bodyInner.classList.add('article-journal__body-inner--with-toc');
    var allHeadings = content.querySelectorAll('h2');
    function setActive(id) {
      article.querySelectorAll('.article-journal__toc-link').forEach(function(link) {
        link.classList.toggle('article-journal__toc-link--active', link.getAttribute('data-toc-id') === id);
      });
    }
    function updateActive() {
      var offset = 180;
      var current = null;
      allHeadings.forEach(function(h) {
        if (h.getBoundingClientRect().top <= offset) current = h;
      });
      setActive(current ? current.id : (allHeadings[0].id || ''));
    }
    window.addEventListener('scroll', function() { requestAnimationFrame(updateActive); }, { passive: true });
    updateActive();
  }
  function initMobileTocCollapsible(article) {
    if (!article) return;
    var toc = article.querySelector('.article-journal__toc');
    if (!toc) return;

    var toggle = toc.querySelector('[data-mobile-toc-toggle]');
    var panel = toc.querySelector('[data-mobile-toc-panel]');
    if (!toggle || !panel) return;

    function setOpen(next) {
      toc.classList.toggle('is-open', next);
      toggle.setAttribute('aria-expanded', next ? 'true' : 'false');
      panel.setAttribute('aria-hidden', next ? 'false' : 'true');
    }

    toggle.addEventListener('click', function () {
      setOpen(!toc.classList.contains('is-open'));
    });

    toc.querySelectorAll('.article-journal__toc-link').forEach(function (link) {
      link.addEventListener('click', function () {
        if (window.matchMedia('(max-width: 989px)').matches) setOpen(false);
      });
    });

    function syncFromViewport() {
      if (window.matchMedia('(max-width: 989px)').matches) setOpen(false);
      else setOpen(true);
    }

    window.addEventListener('resize', syncFromViewport, { passive: true });
    syncFromViewport();
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initToc);
  else initToc();
})();
</script>

<style>
#ArticleJournal-{{ section.id }} { --aj-accent: {{ section.settings.accent_color }}; --aj-text: {{ section.settings.text_color }}; --aj-muted: {{ section.settings.muted_color }}; --aj-border: {{ section.settings.border_color }}; --aj-body-width: {{ section.settings.content_width }}px; }
.article-journal { padding-bottom: 4rem; }
.article-journal__header { position: relative; margin-bottom: 3rem; }
.article-journal__banner { position: relative; aspect-ratio: 21/9; overflow: hidden; background: var(--aj-muted,#1a1a1a); }
.article-journal__banner-image { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
.article-journal__banner-placeholder { position: absolute; inset: 0; background: linear-gradient(135deg,#2c2c2c 0%,#1a1a1a 100%); }
.article-journal__banner-overlay { position: absolute; inset: 0; background: linear-gradient(to top,rgba(0,0,0,.85) 0%,rgba(0,0,0,.4) 40%,transparent 70%); pointer-events: none; }
.article-journal__header-inner { position: absolute; bottom: 0; left: 0; right: 0; padding: 2rem 24px 2.5rem; }
.article-journal__container { max-width: 1400px; margin: 0 auto; padding: 0 24px; }
.article-journal__container--narrow { max-width: var(--aj-body-width,720px); }
.article-journal__category { display: inline-block; font-size: .75rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--aj-accent); text-decoration: none; margin-bottom: .75rem; }
.article-journal__category:hover { text-decoration: underline; }
.article-journal__title { font-size: clamp(1.75rem,4vw,2.75rem); font-weight: 700; line-height: 1.2; color: #fff; margin: 0 0 1rem; letter-spacing: -.02em; }
.article-journal__meta { display: flex; flex-wrap: wrap; align-items: center; gap: 0 1rem; font-size: .875rem; color: rgba(255,255,255,.85); }
.article-journal__meta-item { position: relative; }
.article-journal__meta-item:not(:last-child)::after { content: "·"; position: absolute; right: -.6rem; opacity: .7; }
.article-journal__meta-item--reading { font-style: italic; }
.article-journal__body { color: var(--aj-text,#222); }
.article-journal__content :first-child { margin-top: 0; }
.article-journal__content h1,.article-journal__content h2,.article-journal__content h3,.article-journal__content h4 { margin: 2em 0 .6em; font-weight: 700; line-height: 1.3; color: var(--aj-text,#222); }
.article-journal__content h1{font-size:1.6em}.article-journal__content h2{font-size:1.4em}.article-journal__content h3{font-size:1.2em}.article-journal__content h4{font-size:1.1em}
.article-journal__content p { margin: 0 0 1.25em; }
.article-journal__content a:not(.button) { color: var(--aj-accent); text-decoration: underline; text-underline-offset: 2px; }
.article-journal__content blockquote { margin: 2rem 0; padding-left: 1.5rem; border-left: 4px solid var(--aj-accent); font-size: 1.1em; color: var(--aj-muted,#555); font-style: italic; }
.article-journal__content ul,.article-journal__content ol { margin: 1.25em 0; padding-left: 1.5em; }
.article-journal__content img { width: 100%; max-width: 100%; height: auto; border-radius: 16px; }
.article-journal__tags { max-width: var(--aj-body-width,720px); margin: 0 auto 2rem; padding-top: 1.5rem; border-top: 1px solid var(--aj-border,#e5e5e5); font-size: .9rem; color: var(--aj-muted,#555); }
.article-journal__tags-label { font-weight: 600; margin-right: .25rem; }
.article-journal__tag { color: var(--aj-accent); text-decoration: none; }
.article-journal__share { max-width: var(--aj-body-width,720px); margin: 0 auto 2.5rem; font-size: .9rem; }
.article-journal__share-label { font-weight: 600; margin-right: .75rem; color: var(--aj-muted,#555); }
.article-journal__share-link { margin-right: 1rem; color: var(--aj-accent); text-decoration: none; }
.article-journal__nav { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; max-width: var(--aj-body-width,720px); margin: 0 auto; padding-top: 2rem; border-top: 1px solid var(--aj-border,#e5e5e5); }
.article-journal__nav-link { display: block; padding: 1rem; background: #f8f8f8; border-radius: 8px; text-decoration: none; color: var(--aj-text,#222); transition: background .2s; }
.article-journal__nav-link:hover { background: #eee; }
.article-journal__nav-link--next { text-align: right; }
.article-journal__nav-label { display: block; font-size: .8rem; font-weight: 600; color: var(--aj-accent); margin-bottom: .25rem; }
.article-journal__nav-title { font-size: .95rem; font-weight: 500; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.article-journal__body-inner { display: grid; grid-template-columns: 1fr; gap: 2rem; align-items: start; }
.article-journal__body-inner--with-toc { grid-template-columns: minmax(0, 200px) 1fr !important; }
.article-journal__toc { display: none !important; }
.article-journal__body-inner--with-toc .article-journal__toc {
  display: block !important;
  position: sticky !important;
  top: 124px !important;
  min-width: 0 !important;
  align-self: start !important;
  max-height: calc(100vh - 140px) !important;
  overflow-y: auto !important;
  overflow-x: hidden !important;
  -webkit-overflow-scrolling: touch !important;
  padding-right: 4px !important;
}
.article-journal__toc-list { list-style: none !important; margin: 0 !important; padding: 0 !important; display: flex !important; flex-direction: column !important; gap: 0.15rem !important; }
.article-journal__toc-link {
  display: block !important;
  padding: 0.35rem 0 0.35rem 10px !important;
  font-size: 16px !important;
  line-height: 1.35 !important;
  font-weight: 600 !important;
  color: var(--aj-muted,#555) !important;
  text-decoration: none !important;
  border-left: 2px solid transparent !important;
  transition: color .2s, border-color .2s, font-weight .2s !important;
}
.article-journal__toc-link:hover { color: var(--aj-text,#222) !important; }
.article-journal__toc-link--active { color: var(--aj-accent) !important; font-weight: 600 !important; border-left-color: var(--aj-accent) !important; }
.article-journal__toc-mobile-toggle { display: none !important; }
.article-journal__toc-mobile-panel { display: block !important; }
.article-journal__main { min-width: 0; }
.article-journal__aside { display: flex !important; flex-direction: column !important; gap: 0.75rem !important; }
.article-journal__aside-banner {
  background: #f8f8f8 !important;
  border: 1px solid var(--aj-border,#e5e5e5) !important;
  border-radius: 8px !important;
  padding: 0.65rem 0.7rem !important;
}
.article-journal__aside-heading {
  font-size: 14px !important;
  font-weight: 700 !important;
  text-transform: uppercase !important;
  letter-spacing: 0.05em !important;
  margin: 0 0 0.65rem !important;
  color: var(--aj-muted,#555) !important;
  line-height: 1.3 !important;
}
.article-journal__aside-products { display: flex !important; flex-direction: column !important; gap: 0.45rem !important; }
.article-journal-aside-card { background: #fff !important; border-radius: 6px !important; overflow: hidden !important; box-shadow: 0 1px 2px rgba(0,0,0,.05) !important; }
.article-journal-aside-card__link { display: flex !important; align-items: center !important; gap: 12px !important; padding: 10px 12px !important; text-decoration: none !important; color: inherit !important; transition: background .2s !important; }
.article-journal-aside-card__link:hover { background: #fafafa !important; }
.article-journal-aside-card__image { flex-shrink: 0 !important; width: 96px !important; height: 96px !important; border-radius: 6px !important; overflow: hidden !important; background: #eee !important; }
.article-journal-aside-card__img { width: 100% !important; height: 100% !important; object-fit: cover !important; display: block !important; }
.article-journal-aside-card__placeholder { width: 100% !important; height: 100% !important; }
.article-journal-aside-card__info { flex: 1 !important; min-width: 0 !important; }
.article-journal-aside-card__title {
  font-size: 16px !important;
  font-weight: 600 !important;
  margin: 0 0 6px !important;
  line-height: 1.35 !important;
  color: var(--aj-text,#222) !important;
  display: -webkit-box !important;
  -webkit-line-clamp: 2 !important;
  -webkit-box-orient: vertical !important;
  overflow: hidden !important;
  letter-spacing: -0.01em !important;
}
.article-journal-aside-card__price { margin: 0 0 8px !important; font-size: 14px !important; line-height: 1.35 !important; }
.article-journal-aside-card__price-current { font-weight: 700 !important; color: var(--aj-accent) !important; font-size: 16px !important; }
.article-journal-aside-card__price-compare { color: var(--aj-muted,#555) !important; text-decoration: line-through !important; margin-left: 6px !important; font-size: 14px !important; }
/* Mesmo visual do CTA dos inline cards (fundo accent + texto branco) */
.article-journal-aside-card__cta {
  display: inline-block !important;
  margin-top: 2px !important;
  padding: 8px 16px !important;
  background: var(--aj-accent) !important;
  color: #fff !important;
  font-weight: 600 !important;
  font-size: 14px !important;
  letter-spacing: 0.02em !important;
  border-radius: 6px !important;
  line-height: 1.25 !important;
  text-decoration: none !important;
}
.article-journal-aside-card__link:hover .article-journal-aside-card__cta {
  opacity: 0.92 !important;
  color: #fff !important;
}
@media (min-width: 990px) {
  .article-journal__body-inner--with-aside { grid-template-columns: 1fr minmax(0, 340px) !important; }
  .article-journal__body-inner--with-toc.article-journal__body-inner--with-aside { grid-template-columns: minmax(0, 200px) 1fr minmax(0, 340px) !important; }
  .article-journal__aside { position: sticky !important; top: 124px !important; align-self: start !important; }
}
@media (max-width: 989px) {
  .article-journal__body-inner--with-toc {
    display: block !important;
    grid-template-columns: none !important;
  }
  .article-journal__toc {
    display: block !important;
    position: static !important;
    top: auto !important;
    min-width: 0 !important;
    max-height: none !important;
    overflow: visible !important;
    padding-right: 0 !important;
    margin: 0 0 14px !important;
    width: 100% !important;
  }
  .article-journal__toc-mobile-toggle {
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    width: 100% !important;
    appearance: none !important;
    border: 1px solid var(--aj-border,#e5e5e5) !important;
    border-radius: 10px !important;
    background: #fff !important;
    color: var(--aj-text,#222) !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    padding: 12px 14px !important;
    line-height: 1.2 !important;
    text-align: left !important;
    background-color: #fff;
  }
  .article-journal__toc-mobile-toggle::after {
    content: '▾';
    color: var(--aj-accent) !important;
    font-size: 14px !important;
    line-height: 1 !important;
    margin-left: 10px !important;
    transition: transform .2s ease !important;
  }
  .article-journal__toc.is-open .article-journal__toc-mobile-toggle::after {
    transform: rotate(180deg) !important;
  }
  .article-journal__toc-mobile-panel {
    display: none !important;
    margin-top: 8px !important;
    border: 1px solid var(--aj-border,#e5e5e5) !important;
    border-radius: 10px !important;
    background: #fff !important;
    padding: 8px !important;
    max-height: min(56vh, 420px) !important;
    overflow: auto !important;
  }
  .article-journal__toc.is-open .article-journal__toc-mobile-panel { display: block !important; }
  .article-journal__toc .article-journal__toc-link {
    font-size: 14px !important;
    padding: 0.45rem 0 0.45rem 8px !important;
  }
  .article-journal__aside {
    width: 100% !important;
    position: static !important;
    top: auto !important;
    order: 3 !important;
    align-self: stretch !important;
  }
  .article-journal__aside-banner {
    width: 100% !important;
    padding: 12px !important;
  }
  .article-journal__aside-products { gap: 12px !important; }
  .article-journal-aside-card__link {
    flex-direction: row !important;
    align-items: center !important;
    gap: 10px !important;
    padding: 12px !important;
  }
  .article-journal-aside-card__image {
    width: 96px !important;
    height: 96px !important;
    aspect-ratio: auto !important;
    border-radius: 6px !important;
  }
  .article-journal-aside-card__title { margin-bottom: 8px !important; }
  .article-journal-aside-card__price { margin-bottom: 10px !important; }
  .article-journal-aside-card__cta {
    display: inline-block !important;
    width: auto !important;
    text-align: left !important;
  }

}
@media (max-width:749px){
  .article-journal__banner{aspect-ratio:16/10} .article-journal__header-inner{padding:1.5rem 16px 1.75rem} .article-journal__container,.article-journal__content{padding-left:16px;padding-right:16px} .article-journal__content{font-size:1.0625rem} .article-journal__meta{font-size:.8125rem} .article-journal__nav{grid-template-columns:1fr} .article-journal__nav-link--next{text-align:left} }
.article-inline-card { margin: 2rem 0; border: 1px solid var(--aj-border,#e5e5e5); border-radius: 12px; overflow: hidden; background: #fff; }
/* Membership: mesmo padrão do card de produto (moldura, padding, 16/14px, CTA pill 6px) */
.article-inline-card.article-inline-card--membership {
  margin: 1.25rem 0 !important;
  border-radius: 8px !important;
  border: 1px solid var(--aj-border,#e5e5e5) !important;
  overflow: hidden !important;
  background: #fff !important;
}
.article-inline-card--membership .article-inline-card__membership-inner {
  display: flex !important;
  flex-wrap: wrap !important;
  align-items: center !important;
  justify-content: space-between !important;
  gap: 0.85rem !important;
  padding: 0.85rem 1rem !important;
}
.article-inline-card__membership-text { flex: 1 !important; min-width: 0 !important; }
.article-inline-card__membership-headline {
  font-size: 16px !important;
  font-weight: 600 !important;
  margin: 0 0 0.4rem !important;
  color: var(--aj-text,#222) !important;
  line-height: 1.35 !important;
  letter-spacing: -0.01em !important;
}
.article-inline-card__membership-subhead {
  font-size: 14px !important;
