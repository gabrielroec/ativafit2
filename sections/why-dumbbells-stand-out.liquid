  "presets": [
    {
      "name": "Why dumbbells stand out",
      "category": "Storytelling",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "widgets",
            "title": "12-in-1 System",
            "text": "Save up to 80% space compared to traditional dumbbells"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "speed",
            "title": "Quick Weight Changes",
            "text": "Adjust in seconds with smooth dial control"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "architecture",
            "title": "Built to Last",
            "text": "Solid steel construction for long-term durability"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "lock",
            "title": "Secure & Stable",
            "text": "Lock-in design for safe and confident workouts"
          }
        }
      ]
    }
  ]
}
