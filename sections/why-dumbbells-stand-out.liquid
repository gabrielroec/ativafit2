    },
    {
      "type": "range",
      "id": "video_margin_top",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "label": "Extra space above video",
      "default": 0
    },
    {
      "type": "range",
      "id": "video_shell_max_width",
      "min": 320,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "label": "Max video width",
      "default": 820,
      "info": "Caps width and height (16:9) and centers the block. Lower values = smaller video."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#f3f3f3"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#f7f7f7"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#eb701f"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading and card titles",
      "default": "#1a1c1c"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Card description",
      "default": "#888888"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon (Material Symbols)",
          "default": "widgets",
