{{ 'hero-ativa-home.css' | asset_url | stylesheet_tag }}
<script src="{{ 'hero-ativa-home.js' | asset_url }}" defer></script>

{%- liquid
  assign entrance_stagger = section.settings.entrance_stagger_ms | default: 90
  assign bg = section.settings.background_image
  assign media = section.settings.side_image
  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0

  assign button_primary_href = section.settings.button_primary_link
  if button_primary_href == blank
    assign button_primary_href = routes.all_products_collection_url
  endif

  assign button_secondary_href = section.settings.button_secondary_link
  if button_secondary_href == blank
    assign button_secondary_href = routes.root_url
  endif

  assign show_primary = false
  assign show_secondary = false
  if section.settings.button_primary_label != blank
    assign show_primary = true
  endif
  if section.settings.button_secondary_label != blank
    assign show_secondary = true
  endif

  assign side_alt = ''
  if media != blank
    assign side_alt = media.alt | strip
  endif
  if side_alt == blank and section.settings.subheading != blank
    assign side_alt = section.settings.subheading | strip
  endif
  if side_alt == blank
    assign side_alt = shop.name
  endif
  assign side_alt = side_alt | escape
-%}

<section
  class="hero-ativa-home font-ativa-body{% unless section.settings.show_side_image_card %} hero-ativa-home--no-side-media{% endunless %}"
  data-hero-ativa-home
  style="
    --hero-ativa-overlay-opacity: {{ overlay_opacity }};
    --hero-ativa-btn-primary-bg: {{ section.settings.primary_button_bg }};
    --hero-ativa-btn-primary-text: {{ section.settings.primary_button_text }};
    --hero-ativa-btn-secondary-text: {{ section.settings.secondary_button_text }};
    --hero-ativa-btn-secondary-border: {{ section.settings.secondary_button_border }};
  "
  aria-label="{{ section.settings.section_a11y_label | escape }}"
  {{ section.shopify_attributes }}>
  <div class="hero-ativa-home__bg" aria-hidden="true">
    {%- if bg != blank -%}
      {{
        bg
        | image_url: width: 2400
        | image_tag:
          class: 'hero-ativa-home__bg-media',
          widths: '375, 550, 750, 1100, 1500, 1920, 2400',
          sizes: '100vw',
          loading: 'eager',
          fetchpriority: 'low',
          alt: ''
      }}
    {%- else -%}
      <div class="hero-ativa-home__bg-fallback">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-ativa-home__bg-placeholder' }}
      </div>
    {%- endif -%}
  </div>

  <div class="hero-ativa-home__overlay" aria-hidden="true"></div>
  <div
    class="hero-ativa-home__noise"
    aria-hidden="true"
    {% unless section.settings.show_noise_overlay %}
      hidden
    {% endunless %}></div>

  <div class="hero-ativa-home__inner">
    <div class="hero-ativa-home__grid">
      <div class="hero-ativa-home__content">
        {%- if section.settings.heading != blank -%}
          <h1
            class="hero-ativa-home__title hero-ativa-home__entrance font-ativa-headline"
            style="--hero-entrance-delay: 0ms">{{ section.settings.heading | newline_to_br }}</h1>
        {%- else -%}
          <h1
            class="hero-ativa-home__title hero-ativa-home__entrance font-ativa-headline"
            style="--hero-entrance-delay: 0ms">
            START STRONG.<br>
            BUILD YOUR HOME<br>
            GYM YOUR WAY
          </h1>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p
            class="hero-ativa-home__sub hero-ativa-home__entrance font-ativa-body"
            style="--hero-entrance-delay: {{ entrance_stagger }}ms">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}

        {%- if show_primary or show_secondary -%}
          <div
            class="hero-ativa-home__actions hero-ativa-home__entrance"
            style="--hero-entrance-delay: {{ entrance_stagger | times: 2 }}ms">
            {%- if show_primary -%}
              <a
                class="hero-ativa-home__btn hero-ativa-home__btn--primary font-ativa-headline"
                href="{{ button_primary_href }}">
                {{- section.settings.button_primary_label | escape -}}
              </a>
            {%- endif -%}
            {%- if show_secondary -%}
              <a
                class="hero-ativa-home__btn hero-ativa-home__btn--secondary font-ativa-headline"
                href="{{ button_secondary_href }}">
                {{- section.settings.button_secondary_label | escape -}}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- if section.settings.show_side_image_card -%}
        <div
          class="hero-ativa-home__media hero-ativa-home__entrance hero-ativa-home__entrance--media"
          style="--hero-entrance-delay: {{ entrance_stagger | times: 3 }}ms">
          <div class="hero-ativa-home__media-frame">
            {%- if media != blank -%}
              {{
                media
                | image_url: width: 1500
                | image_tag:
                  class: 'hero-ativa-home__media-img',
                  widths: '400, 600, 800, 1000, 1200, 1500',
                  sizes: '(min-width: 900px) 36rem, 90vw',
                  loading: 'eager',
                  fetchpriority: 'high',
                  alt: side_alt
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'hero-ativa-home__media-img placeholder-svg' }}
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Ativa Home",
  "tag": "section",
  "class": "shopify-section-hero-ativa-home",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Title (H1)",
      "default": "START STRONG.\nBUILD YOUR HOME\nGYM YOUR WAY",
      "info": "Use a new line for each line break."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Supporting text",
      "default": "Strength, cardio, and full-body training — all from one space-saving system."
    },
    {
      "type": "text",
      "id": "section_a11y_label",
      "label": "Region name (accessibility)",
      "default": "Main hero",
      "info": "Screen readers use this to identify the block."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_primary_label",
      "label": "Text — primary button",
      "default": "SHOP DUMBBELLS"
    },
    {
      "type": "url",
      "id": "button_primary_link",
      "label": "Link — primary button",
      "info": "If empty, uses the All products collection."
    },
    {
      "type": "text",
      "id": "button_secondary_label",
      "label": "Text — secondary button",
      "default": "EXPLORE HOME GYM SETUP"
    },
    {
      "type": "url",
      "id": "button_secondary_link",
      "label": "Link — secondary button",
      "info": "If empty, uses the home page."
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "checkbox",
      "id": "show_side_image_card",
      "label": "Show image card (right side)",
      "default": false,
      "info": "Off: background image only, full width. On: shows the card with side image below (mobile) or on the right (desktop)."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image (full width)",
      "info": "While empty, Shopify’s neutral placeholder is shown."
    },
    {
      "type": "image_picker",
      "id": "side_image",
      "label": "Card image (side highlight)",
      "info": "Only shows when “Show image card” is on. If empty, uses the product placeholder. Set alt text on the asset for SEO."
    },
    {
      "type": "header",
      "content": "Look & feel"
    },
    {
      "type": "range",
      "id": "entrance_stagger_ms",
      "min": 40,
      "max": 200,
      "step": 10,
      "unit": "ms",
      "label": "Animation — delay between each element",
      "default": 90,
      "info": "Title first, then text, buttons, and image. Ignored when “reduce motion” is enabled."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 85,
      "step": 5,
      "unit": "%",
      "label": "Background dimming",
      "default": 35
    },
    {
      "type": "checkbox",
      "id": "show_noise_overlay",
      "label": "Light background texture (CSS)",
      "default": true
    },
    {
      "type": "color",
      "id": "primary_button_bg",
      "label": "Background — primary button",
      "default": "#EB701F"
    },
    {
      "type": "color",
      "id": "primary_button_text",
      "label": "Text — primary button",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "secondary_button_text",
      "label": "Text — secondary button",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "secondary_button_border",
      "label": "Border — secondary button",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Hero Ativa Home"
    }
  ]
}
{% endschema %}
