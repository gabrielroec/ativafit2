{%- liquid
  assign sm_id = 'bundle-summary-' | append: section.id
  assign checkout_href = section.settings.checkout_url
  if checkout_href == blank
    assign checkout_href = '/checkout'
  endif
  assign bcs_grid_col2 = section.settings.panel_width | plus: section.settings.fixed_right
-%}

<aside
  id="{{ sm_id }}"
  class="bundle-configuration-sidebar"
  data-bundle-summary-root
  data-section-type="bundle-configuration-sidebar"
  aria-label="{{ section.settings.sidebar_a11y_label | escape }}"
  {{ section.shopify_attributes }}>
  <button
    type="button"
    class="bundle-configuration-sidebar__mobile-toggle"
    data-bundle-mobile-toggle
    aria-expanded="false"
    aria-controls="{{ sm_id }}-panel">
    {{ section.settings.mobile_toggle_label | escape }}
  </button>
  <div class="bundle-configuration-sidebar__mobile-backdrop" data-bundle-mobile-backdrop></div>
  <div id="{{ sm_id }}-panel" class="bundle-configuration-sidebar__panel">
    <div class="bundle-configuration-sidebar__title-row">
      <h2 class="bundle-configuration-sidebar__title">
        <span class="bundle-configuration-sidebar__title-bar" aria-hidden="true"></span>
        <span class="bundle-configuration-sidebar__title-text">{{ section.settings.heading | escape }}</span>
      </h2>
      <button
        type="button"
        class="bundle-configuration-sidebar__mobile-close"
        data-bundle-mobile-close
        aria-label="{{ section.settings.mobile_close_label | escape }}">
        <span class="visually-hidden">{{ section.settings.mobile_close_label | escape }}</span>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M5 5L15 15M15 5L5 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <ul class="bundle-configuration-sidebar__lines">
      <li
        class="bundle-summary__line bundle-summary__line--empty"
        data-summary-line="1"
        data-empty-title="{{ section.settings.empty_line_label | escape }}">
        <div class="bundle-summary__line-body">
          <span class="bundle-summary__line-title" data-summary-line-title>—</span>
          <span class="bundle-summary__line-cat" data-summary-line-cat></span>
        </div>
        <span class="bundle-summary__line-price" data-summary-line-price>—</span>
      </li>
      <li
        class="bundle-summary__line bundle-summary__line--empty"
        data-summary-line="2"
        data-empty-title="{{ section.settings.empty_line_label | escape }}">
        <div class="bundle-summary__line-body">
          <span class="bundle-summary__line-title" data-summary-line-title>—</span>
          <span class="bundle-summary__line-cat" data-summary-line-cat></span>
        </div>
        <span class="bundle-summary__line-price" data-summary-line-price>—</span>
      </li>
      <li
        class="bundle-summary__line bundle-summary__line--empty"
        data-summary-line="3"
        data-empty-title="{{ section.settings.empty_line_label | escape }}">
        <div class="bundle-summary__line-body">
          <span class="bundle-summary__line-title" data-summary-line-title>—</span>
          <span class="bundle-summary__line-cat" data-summary-line-cat></span>
        </div>
        <span class="bundle-summary__line-price" data-summary-line-price>—</span>
      </li>
    </ul>

    <div class="bundle-configuration-sidebar__discount">
      <p class="bundle-configuration-sidebar__discount-label">{{ section.settings.discount_heading | escape }}</p>
      <p class="bundle-configuration-sidebar__discount-amount" data-summary-savings-amount>-$0.00</p>
      {%- if section.settings.discount_footer != blank -%}
        <div class="bundle-configuration-sidebar__discount-rule"></div>
        <p class="bundle-configuration-sidebar__discount-foot">{{ section.settings.discount_footer | escape }}</p>
      {%- endif -%}
    </div>

    <div class="bundle-configuration-sidebar__total">
      <span class="bundle-configuration-sidebar__total-label">{{ section.settings.total_label | escape }}</span>
      <span class="bundle-configuration-sidebar__total-value">
        <span class="bundle-configuration-sidebar__total-bucks" data-summary-total-bucks>$0</span><span class="bundle-configuration-sidebar__total-sub" data-summary-total-sub></span>
      </span>
    </div>

    <button
      type="button"
      class="bundle-configuration-sidebar__checkout"
      data-bundle-checkout
      data-checkout-url="{{ checkout_href }}"
      data-alert-incomplete="{{ section.settings.checkout_alert | escape }}">
      {{ section.settings.checkout_label | escape }}
    </button>

    <div class="bundle-configuration-sidebar__trust">
      <div class="bundle-configuration-sidebar__trust-item">
        <span class="bundle-configuration-sidebar__trust-text">{{ section.settings.trust_1_text | escape }}</span>
      </div>
      <div class="bundle-configuration-sidebar__trust-item">
        <span class="bundle-configuration-sidebar__trust-text">{{ section.settings.trust_2_text | escape }}</span>
      </div>
      <div class="bundle-configuration-sidebar__trust-item">
        <span class="bundle-configuration-sidebar__trust-text">{{ section.settings.trust_3_text | escape }}</span>
      </div>
    </div>
  </div>
</aside>

<script src="{{ 'bundle-page-summary.js' | asset_url }}" defer></script>

<style>
  #{{ sm_id }}.bundle-configuration-sidebar {
    --bcs-accent: {{ section.settings.accent_color }};
    --bcs-panel-bg: {{ section.settings.panel_bg }};
    --bcs-shadow: {{ section.settings.panel_shadow }};
  }

  /* Página bundle: hero 100% + [steps | sidebar] em grid (#main). Requer body.bundle-page-layout (theme.liquid). */
  @media screen and (min-width: 1100px) {
    body.bundle-page-layout #main {
      display: grid;
      grid-template-columns: minmax(0, 1fr) {{ bcs_grid_col2 }}px;
      column-gap: {{ section.settings.layout_column_gap }}px;
      align-items: start;
      width: 100%;
      grid-template-areas:
        'bundle-hero bundle-hero'
        'bundle-steps bundle-side'
        'bundle-main bundle-main';
    }

    body.bundle-page-layout #main > .shopify-section:has([data-section-type='bundle-page-hero']) {
      grid-area: bundle-hero;
    }

    body.bundle-page-layout #main > .shopify-section:has([data-section-type='bundle-steps']) {
      grid-area: bundle-steps;
    }

    body.bundle-page-layout #main > .shopify-section:has([data-section-type='bundle-configuration-sidebar']) {
      grid-area: bundle-side;
      align-self: start;
      position: sticky;
      top: {{ section.settings.fixed_top }}px;
      z-index: 5;
      box-sizing: border-box;
      padding-right: {{ section.settings.fixed_right }}px;
      max-height: calc(100vh - {{ section.settings.fixed_top | plus: 24 }}px);
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
    }

    body.bundle-page-layout #main > .shopify-section:has(section[data-section-type='page']) {
      grid-area: bundle-main;
    }

    #{{ sm_id }}.bundle-configuration-sidebar {
      position: relative;
      width: 100%;
      max-width: {{ section.settings.panel_width }}px;
      margin-left: auto;
    }
  }

  #{{ sm_id }} .bundle-configuration-sidebar__mobile-toggle,
  #{{ sm_id }} .bundle-configuration-sidebar__mobile-backdrop {
    display: none;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__mobile-close {
    display: none;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    margin: 0;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: #f2f2f2;
    color: #000000;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__mobile-close:hover {
    background: #e8e8e8;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__mobile-close:focus-visible {
    outline: 2px solid var(--bcs-accent);
    outline-offset: 2px;
  }

  @media screen and (max-width: 1099px) {
    body.bundle-mobile-open {
      overflow: hidden;
    }

    body.bundle-page-layout #main {
      padding-bottom: 92px;
    }

    #{{ sm_id }}.bundle-configuration-sidebar {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      width: 100%;
      z-index: 45;
      pointer-events: none;
    }

    #{{ sm_id }} .bundle-configuration-sidebar__mobile-toggle {
      display: block;
      pointer-events: auto;
      position: fixed;
      left: 16px;
      right: 16px;
      bottom: 16px;
      height: 52px;
      border: none;
      border-radius: 999px;
      background: var(--bcs-accent);
      color: #ffffff;
      font-family: var(--heading-font-family) !important;
      font-size: 13px !important;
      font-weight: 800 !important;
      letter-spacing: 0.08em !important;
      text-transform: uppercase !important;
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.2);
      cursor: pointer;
      z-index: 48;
    }

    #{{ sm_id }} .bundle-configuration-sidebar__mobile-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.45);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.22s ease;
      z-index: 46;
    }

    #{{ sm_id }} .bundle-configuration-sidebar__panel {
      pointer-events: auto;
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      max-height: 78vh;
      overflow-y: auto;
      border-radius: 18px 18px 0 0;
      transform: translateY(105%);
      transition: transform 0.24s ease;
      z-index: 47;
      margin: 0;
    }

    #{{ sm_id }}.is-mobile-open .bundle-configuration-sidebar__mobile-backdrop {
      opacity: 1;
      pointer-events: auto;
    }

    #{{ sm_id }}.is-mobile-open .bundle-configuration-sidebar__panel {
      transform: translateY(0);
    }

    #{{ sm_id }}.is-mobile-open .bundle-configuration-sidebar__mobile-toggle {
      opacity: 0;
      pointer-events: none;
    }

    #{{ sm_id }} .bundle-configuration-sidebar__mobile-close {
      display: inline-flex;
    }

    #{{ sm_id }} .bundle-configuration-sidebar__title-row {
      position: sticky;
      top: 0;
      z-index: 1;
      padding-top: 4px;
      margin-top: -4px;
      background: linear-gradient(to bottom, var(--bcs-panel-bg) 70%, transparent);
    }
  }

  #{{ sm_id }} .bundle-configuration-sidebar__panel {
    background: var(--bcs-panel-bg);
    border-radius: {{ section.settings.panel_radius }}px;
    padding: {{ section.settings.panel_padding }}px;
    box-shadow: var(--bcs-shadow);
    border: 1px solid {{ section.settings.panel_border }};
  }

  #{{ sm_id }} .bundle-configuration-sidebar__title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin: 0 0 {{ section.settings.title_margin_bottom }}px !important;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__title {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 0 !important;
    font-family: var(--heading-font-family) !important;
    font-size: {{ section.settings.title_size }}px !important;
    font-weight: 900 !important;
    letter-spacing: 0.04em !important;
    text-transform: uppercase !important;
    color: #000000 !important;
    line-height: 1.2 !important;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__title-bar {
    width: 4px;
    height: 1.25em;
    border-radius: 2px;
    background: var(--bcs-accent);
    flex-shrink: 0;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__lines {
    list-style: none;
    margin: 0 0 {{ section.settings.lines_margin_bottom }}px;
    padding: 0;
  }

  #{{ sm_id }} .bundle-summary__line {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 0;
    border-bottom: 1px solid #eeeeee;
  }

  #{{ sm_id }} .bundle-summary__line:last-of-type {
    border-bottom: none;
  }

  #{{ sm_id }} .bundle-summary__line-body {
    flex: 1;
    min-width: 0;
  }

  #{{ sm_id }} .bundle-summary__line-title {
    display: block;
    font-family: var(--heading-font-family) !important;
    font-size: 15px !important;
    font-weight: 700 !important;
    color: #000000 !important;
    line-height: 1.3 !important;
  }

  #{{ sm_id }} .bundle-summary__line--empty .bundle-summary__line-title {
    color: #999999 !important;
    font-weight: 600 !important;
  }

  #{{ sm_id }} .bundle-summary__line-cat {
    display: block;
    font-family: var(--text-font-family) !important;
    font-size: 11px !important;
    letter-spacing: 0.06em !important;
    text-transform: uppercase !important;
    color: #888888 !important;
    margin-top: 4px !important;
    line-height: 1.3 !important;
  }

  #{{ sm_id }} .bundle-summary__line-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    flex-shrink: 0;
    gap: 3px;
  }

  #{{ sm_id }} .bundle-summary__line-price {
    font-family: var(--heading-font-family) !important;
    font-size: 15px !important;
    font-weight: 700 !important;
    color: #000000 !important;
    line-height: 1.3 !important;
  }

  #{{ sm_id }} .bundle-summary__line--empty .bundle-summary__line-price {
    color: #aaaaaa !important;
  }

  #{{ sm_id }} .bundle-summary__line-saving {
    font-family: var(--text-font-family) !important;
    font-size: 10px !important;
    font-weight: 700 !important;
    letter-spacing: 0.04em !important;
    text-transform: uppercase !important;
    color: var(--bcs-accent) !important;
    line-height: 1.2 !important;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__discount {
    background: {{ section.settings.discount_box_bg }};
    border-radius: {{ section.settings.discount_box_radius }}px;
    padding: 16px 18px;
    margin-bottom: {{ section.settings.discount_margin_bottom }}px;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__discount-label {
    font-family: var(--heading-font-family) !important;
    font-size: 11px !important;
    font-weight: 700 !important;
    letter-spacing: 0.1em !important;
    text-transform: uppercase !important;
    color: var(--bcs-accent) !important;
    margin: 0 0 6px !important;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__discount-amount {
    font-family: var(--heading-font-family) !important;
    font-size: {{ section.settings.discount_amount_size }}px !important;
    font-weight: 800 !important;
    color: #22a047 !important;
    margin: 0 !important;
    line-height: 1 !important;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__discount-rule {
    height: 1px;
    background: #e0e0e0;
    margin: 12px 0 10px;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__discount-foot {
    font-family: var(--text-font-family) !important;
    font-size: 10px !important;
    letter-spacing: 0.06em !important;
    text-transform: uppercase !important;
    color: #888888 !important;
    margin: 0 !important;
    line-height: 1.4 !important;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__total {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: {{ section.settings.total_margin_bottom }}px;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__total-label {
    font-family: var(--heading-font-family) !important;
    font-size: 12px !important;
    font-weight: 800 !important;
    letter-spacing: 0.08em !important;
    text-transform: uppercase !important;
    color: #000000 !important;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__total-value {
    text-align: right;
    line-height: 1;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__total-bucks {
    font-family: var(--heading-font-family) !important;
    font-size: {{ section.settings.total_bucks_size }}px !important;
    font-weight: 900 !important;
    color: #000000 !important;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__total-sub {
    font-family: var(--heading-font-family) !important;
    font-size: {{ section.settings.total_sub_size }}px !important;
    font-weight: 800 !important;
    color: #000000 !important;
    vertical-align: 0.35em;
    margin-left: 1px;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__checkout {
    width: 100%;
    display: block;
    font-family: var(--heading-font-family) !important;
    font-size: {{ section.settings.checkout_font_size }}px !important;
    font-weight: 700 !important;
    letter-spacing: 0.08em !important;
    text-transform: uppercase !important;
    color: #ffffff !important;
    background: var(--bcs-accent) !important;
    border: none;
    border-radius: {{ section.settings.checkout_radius }}px;
    padding: 16px 20px;
    cursor: pointer;
    margin-bottom: {{ section.settings.checkout_margin_bottom }}px;
    box-shadow: 0 4px 16px rgba(235, 112, 31, 0.35);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__checkout:hover:not(:disabled) {
    opacity: 0.95;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__checkout:disabled {
    opacity: 0.65;
    cursor: wait;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__checkout.is-incomplete {
    background: #b0b0b0 !important;
    box-shadow: none;
    cursor: not-allowed;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__checkout:focus-visible {
    outline: 2px solid #000000;
    outline-offset: 3px;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__trust {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
    text-align: center;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__trust-item {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  #{{ sm_id }} .bundle-configuration-sidebar__trust-text {
    font-family: var(--text-font-family) !important;
    font-size: 9px !important;
    font-weight: 600 !important;
    letter-spacing: 0.06em !important;
    text-transform: uppercase !important;
    color: #999999 !important;
    line-height: 1.25 !important;
  }
</style>

{% schema %}
{
  "name": "Bundle configuration",
  "tag": "section",
  "class": "section-bundle-configuration-sidebar",
  "settings": [
    {
      "type": "text",
      "id": "sidebar_a11y_label",
      "label": "Nome da região (acessibilidade)",
      "default": "Bundle configuration summary"
    },
    {
      "type": "text",
      "id": "mobile_toggle_label",
      "label": "Texto do botão flutuante (mobile)",
      "default": "MY BUNDLE"
    },
    {
      "type": "text",
      "id": "mobile_close_label",
      "label": "Rótulo do botão fechar (mobile, acessibilidade)",
      "default": "Fechar configuração"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "CONFIGURATION"
    },
    {
      "type": "text",
      "id": "empty_line_label",
      "label": "Texto quando o passo está vazio",
      "default": "Not selected"
    },
    {
      "type": "text",
      "id": "discount_heading",
      "label": "Título do desconto",
      "default": "BUNDLE APPLIED"
    },
    {
      "type": "textarea",
      "id": "discount_footer",
      "label": "Texto abaixo do desconto",
      "default": "OPTIMIZE FURTHER FOR MAXIMUM SAVINGS TIER"
    },
    {
      "type": "text",
      "id": "total_label",
      "label": "Etiqueta do total",
      "default": "ESTIMATED TOTAL"
    },
    {
      "type": "text",
      "id": "checkout_label",
      "label": "Texto do botão",
      "default": "CHECKOUT BUNDLE"
    },
    {
      "type": "url",
      "id": "checkout_url",
      "label": "URL após adicionar ao carrinho",
      "info": "Se vazio, usa /checkout. Após /cart/add.js o visitante é redirecionado."
    },
    {
      "type": "text",
      "id": "checkout_alert",
      "label": "Alerta se passos incompletos",
      "default": "Please select Bundle 1 before checkout."
    },
    {
      "type": "header",
      "content": "Trust row"
    },
    {
      "type": "text",
      "id": "trust_1_text",
      "label": "Texto 1",
      "default": "Priority Ship"
    },
    {
      "type": "text",
      "id": "trust_2_text",
      "label": "Texto 2",
      "default": "Lab Tested"
    },
    {
      "type": "text",
      "id": "trust_3_text",
      "label": "Texto 3",
      "default": "Full Warranty"
    },
    {
      "type": "header",
      "content": "Cores"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Cor de destaque",
      "default": "#eb701f"
    },
    {
      "type": "color",
      "id": "panel_bg",
      "label": "Fundo do painel",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "panel_border",
      "label": "Borda do painel",
      "default": "#eeeeee"
    },
    {
      "type": "text",
      "id": "panel_shadow",
      "label": "Sombra (CSS)",
      "default": "0 8px 32px rgba(0, 0, 0, 0.08)"
    },
    {
      "type": "color",
      "id": "discount_box_bg",
      "label": "Fundo da caixa de desconto",
      "default": "#f5f5f5"
    },
    {
      "type": "header",
      "content": "Layout desktop"
    },
    {
      "type": "range",
      "id": "panel_width",
      "min": 300,
      "max": 440,
      "step": 4,
      "unit": "px",
      "label": "Largura do painel",
      "default": 380
    },
    {
      "type": "range",
      "id": "layout_column_gap",
      "min": 16,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Espaço entre colunas (steps / sidebar)",
      "default": 32
    },
    {
      "type": "range",
      "id": "fixed_top",
      "min": 72,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Offset sticky (abaixo do header)",
      "default": 100
    },
    {
      "type": "range",
      "id": "fixed_right",
      "min": 12,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Margem direita da coluna da sidebar",
      "default": 24
    },
    {
      "type": "range",
      "id": "mobile_margin_bottom",
      "min": 24,
      "max": 64,
      "step": 4,
      "unit": "px",
      "label": "Margem inferior (mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "panel_radius",
      "min": 8,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Raio do painel",
      "default": 14
    },
    {
      "type": "range",
      "id": "panel_padding",
      "min": 16,
      "max": 28,
      "step": 2,
      "unit": "px",
      "label": "Padding interno",
      "default": 22
    },
    {
      "type": "range",
