{{ 'shop-gym-equipment-ativa.css' | asset_url | stylesheet_tag }}
<script src="{{ 'shop-gym-equipment-ativa.js' | asset_url }}" defer></script>

{%- liquid
  assign ttc_id = 'trusted-tech-critics-' | append: section.id
  assign ttc_bg = section.settings.background_color | default: '#f3f3f3'
  assign ttc_accent = section.settings.accent_color | default: '#eb701f'
-%}

<section
  id="{{ ttc_id }}"
  class="trusted-tech-critics"
  data-section-type="trusted-tech-critics">
  <div class="trusted-tech-critics__inner">
    <div class="trusted-tech-critics__header">
      {%- if section.settings.title != blank -%}
        <h2 class="trusted-tech-critics__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="trusted-tech-critics__subtitle">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}
    </div>

    <div
      class="trusted-tech-critics__shop-carousel"
      data-shop-gym-ativa
      data-mobile-layout="carousel"
      style="--sg-accent: {{ ttc_accent }}; --sg-gutter: clamp(1rem, 4vw, 1.5rem);">
      <ul class="shop-gym-ativa__grid shop-gym-ativa__grid--mobile-carousel" role="list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign ttc_video = block.settings.video
          assign ttc_youtube_url = block.settings.youtube_url | default: ''
          assign ttc_youtube_id = ''

          if ttc_youtube_url contains 'youtu.be/'
            assign ttc_youtube_id = ttc_youtube_url | split: 'youtu.be/' | last | split: '?' | first | split: '&' | first
          elsif ttc_youtube_url contains 'watch?v='
            assign ttc_youtube_id = ttc_youtube_url | split: 'watch?v=' | last | split: '&' | first
          elsif ttc_youtube_url contains 'youtube.com/embed/'
            assign ttc_youtube_id = ttc_youtube_url | split: 'youtube.com/embed/' | last | split: '?' | first | split: '&' | first
          elsif ttc_youtube_url contains 'youtube.com/shorts/'
            assign ttc_youtube_id = ttc_youtube_url | split: 'youtube.com/shorts/' | last | split: '?' | first | split: '&' | first
          endif

          assign ttc_has_youtube = false
          if ttc_youtube_id != blank
            assign ttc_has_youtube = true
          endif

          assign ttc_has_video = false
          if ttc_video != blank or ttc_has_youtube
            assign ttc_has_video = true
          endif
        -%}

        <li class="shop-gym-ativa__item" {{ block.shopify_attributes }}>
        <article class="trusted-tech-critics__card">
          <div class="trusted-tech-critics__media-shell">
            <div class="trusted-tech-critics__preview{% unless ttc_has_video %} trusted-tech-critics__preview--static{% endunless %}" data-ttc-preview>
              {%- if block.settings.thumbnail != blank -%}
                {{
                  block.settings.thumbnail
                  | image_url: width: 1100
                  | image_tag:
                    loading: 'lazy',
                    class: 'trusted-tech-critics__preview-img',
                    widths: '400, 600, 800, 1100',
                    sizes: '(min-width: 990px) 30vw, 100vw',
                    alt: block.settings.thumbnail.alt | default: block.settings.quote
                }}
              {%- elsif ttc_video != blank and ttc_video.preview_image != blank -%}
                {{
                  ttc_video.preview_image
                  | image_url: width: 1100
                  | image_tag:
                    loading: 'lazy',
                    class: 'trusted-tech-critics__preview-img',
                    widths: '400, 600, 800, 1100',
                    sizes: '(min-width: 990px) 30vw, 100vw',
                    alt: block.settings.quote | default: 'Video review'
                }}
              {%- elsif ttc_has_youtube -%}
                <img
                  class="trusted-tech-critics__preview-img trusted-tech-critics__preview-img--youtube"
                  src="https://i.ytimg.com/vi/{{ ttc_youtube_id }}/hqdefault.jpg"
                  width="480"
                  height="360"
                  loading="lazy"
                  decoding="async"
                  alt="{{ block.settings.quote | default: 'YouTube video review' | escape }}">
              {%- else -%}
                <div class="trusted-tech-critics__placeholder" aria-hidden="true">
                  {{ 'image' | placeholder_svg_tag: 'trusted-tech-critics__placeholder-svg' }}
                </div>
              {%- endif -%}

              <button
                type="button"
                class="trusted-tech-critics__play"
                data-ttc-play
                {% unless ttc_has_video %}disabled aria-disabled="true"{% endunless %}
                aria-label="{{ block.settings.play_label | default: section.settings.play_label | escape }}">
                <span class="material-symbols-outlined" aria-hidden="true">play_circle</span>
              </button>
            </div>

            <div class="trusted-tech-critics__player" data-ttc-player hidden>
              {%- if ttc_video != blank -%}
                <video
                  class="trusted-tech-critics__video-el"
                  controls
                  playsinline
                  preload="metadata">
                  {%- for source in ttc_video.sources -%}
                    <source src="{{ source.url }}" type="{{ source.mime_type }}">
                  {%- endfor -%}
                </video>
              {%- elsif ttc_has_youtube -%}
                <iframe
                  title="{{ block.settings.quote | default: 'YouTube video review' | escape }}"
                  data-ttc-youtube
                  data-embed="https://www.youtube.com/embed/{{ ttc_youtube_id }}?autoplay=1&playsinline=1&rel=0"
                  allow="autoplay; encrypted-media; picture-in-picture"
                  allowfullscreen></iframe>
              {%- endif -%}
            </div>
          </div>
        </article>
        </li>
      {%- else -%}
        {%- for i in (1..3) -%}
        <li class="shop-gym-ativa__item">
          <article class="trusted-tech-critics__card trusted-tech-critics__card--placeholder">
            <div class="trusted-tech-critics__media-shell">
              <div class="trusted-tech-critics__preview trusted-tech-critics__preview--static">
                <div class="trusted-tech-critics__placeholder" aria-hidden="true">
                  {{ 'image' | placeholder_svg_tag: 'trusted-tech-critics__placeholder-svg' }}
                </div>
                <button type="button" class="trusted-tech-critics__play" disabled aria-disabled="true" aria-label="{{ section.settings.play_label | escape }}">
                  <span class="material-symbols-outlined" aria-hidden="true">play_circle</span>
                </button>
              </div>
            </div>
          </article>
        </li>
        {%- endfor -%}
      {%- endfor -%}
      </ul>

      <div class="shop-gym-ativa__carousel-ui" data-shop-gym-carousel-ui hidden>
        <div class="shop-gym-ativa__dots" data-shop-gym-dots role="group" aria-label="Carousel navigation"></div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('{{ ttc_id }}');
    if (!root) return;

    root.querySelectorAll('[data-ttc-play]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (btn.disabled) return;
        var card = btn.closest('.trusted-tech-critics__card');
        if (!card) return;
        var preview = card.querySelector('[data-ttc-preview]');
        var playerWrap = card.querySelector('[data-ttc-player]');
        if (!preview || !playerWrap) return;

        preview.setAttribute('hidden', '');
        playerWrap.removeAttribute('hidden');

        var video = playerWrap.querySelector('video');
        if (video) {
          var p = video.play();
          if (p && typeof p.catch === 'function') p.catch(function () {});
          return;
        }

        var iframe = playerWrap.querySelector('[data-ttc-youtube]');
        if (iframe && !iframe.getAttribute('src')) {
          iframe.setAttribute('src', iframe.getAttribute('data-embed') || '');
        }
      });
    });
  })();
</script>

<style>
  #{{ ttc_id }}.trusted-tech-critics {
    background-color: {{ ttc_bg }} !important;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #{{ ttc_id }} .trusted-tech-critics__inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 24px;
  }

  #{{ ttc_id }} .trusted-tech-critics__header {
    text-align: center;
    margin-bottom: {{ section.settings.header_margin_bottom }}px;
  }

  #{{ ttc_id }} .trusted-tech-critics__title {
    font-family: var(--heading-font-family) !important;
    font-size: {{ section.settings.title_size }}px !important;
    line-height: 1.1 !important;
    font-weight: 900 !important;
    letter-spacing: -0.04em !important;
    text-transform: uppercase !important;
    color: {{ section.settings.title_color }} !important;
    margin: 0 0 10px !important;
  }

  #{{ ttc_id }} .trusted-tech-critics__subtitle {
    font-family: var(--text-font-family) !important;
    font-size: {{ section.settings.subtitle_size }}px !important;
    line-height: 1.5 !important;
    color: {{ section.settings.subtitle_color }} !important;
    margin: 0 !important;
  }

  /* Mobile carousel + dots: shop-gym-equipment-ativa.css (same as Shop Home Gym). Desktop: 3 columns. */
  #{{ ttc_id }} .trusted-tech-critics__shop-carousel {
    width: 100%;
    /* Landscape video frame — same ratio on every breakpoint */
    --ttc-card-aspect-w: 16;
    --ttc-card-aspect-h: 9;
  }

  #{{ ttc_id }} .shop-gym-ativa__item {
    list-style: none;
  }

  /* Mobile carousel: wider slide fits 16:9 cards better than old portrait min-width */
  @media screen and (max-width: 767px) {
    #{{ ttc_id }} .shop-gym-ativa__grid--mobile-carousel .shop-gym-ativa__item {
      flex: 0 0 min(400px, calc(100% - 2.5rem));
    }
  }

  @media screen and (min-width: 768px) {
    #{{ ttc_id }} .shop-gym-ativa__grid--mobile-carousel {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: {{ section.settings.grid_gap }}px;
    }
  }

  @media screen and (min-width: 990px) {
    #{{ ttc_id }} .shop-gym-ativa__grid--mobile-carousel {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  #{{ ttc_id }} .trusted-tech-critics__card {
    display: block;
    width: 100%;
  }

  #{{ ttc_id }} .trusted-tech-critics__media-shell {
    position: relative;
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    background: #dfdfdf;
    aspect-ratio: var(--ttc-card-aspect-w) / var(--ttc-card-aspect-h);
    width: 100%;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
  }

  #{{ ttc_id }} .trusted-tech-critics__preview {
    position: absolute;
    inset: 0;
  }

  #{{ ttc_id }} .trusted-tech-critics__preview[hidden] {
    display: none !important;
  }

  #{{ ttc_id }} .trusted-tech-critics__preview-img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  /* Fills .media-shell when preview is hidden (was in-flow → 0 height before) */
  #{{ ttc_id }} .trusted-tech-critics__player {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: #000;
  }

  #{{ ttc_id }} .trusted-tech-critics__player .trusted-tech-critics__video-el,
  #{{ ttc_id }} .trusted-tech-critics__player iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    border: 0;
    object-fit: cover;
  }

  #{{ ttc_id }} .trusted-tech-critics__player[hidden] {
    display: none !important;
  }

  #{{ ttc_id }} .trusted-tech-critics__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(145deg, #ececec, #dedede);
  }

  #{{ ttc_id }} .trusted-tech-critics__placeholder-svg {
    width: 54px;
    height: 54px;
    opacity: 0.35;
  }

  #{{ ttc_id }} .trusted-tech-critics__play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: rgba(0, 0, 0, 0.2);
    cursor: pointer;
    transition: background-color 0.25s ease;
  }

  #{{ ttc_id }} .trusted-tech-critics__play:hover:not(:disabled) {
    background: rgba(0, 0, 0, 0.12);
  }

  #{{ ttc_id }} .trusted-tech-critics__play .material-symbols-outlined {
    font-family: 'Material Symbols Outlined', sans-serif !important;
    font-size: 56px !important;
    line-height: 1 !important;
    color: #ffffff !important;
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 48 !important;
  }

  #{{ ttc_id }} .trusted-tech-critics__play:disabled {
    cursor: not-allowed;
    opacity: 0.9;
  }
</style>

{% schema %}
{
  "name": "Trusted by tech critics",
  "tag": "section",
  "class": "section-trusted-tech-critics",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Trusted by Tech Critics"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "In-depth Reviews from Top Creators"
    },
    {
      "type": "text",
      "id": "play_label",
      "label": "Play button text (accessibility)",
      "default": "Play video review"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#f3f3f3"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#574237"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (mobile carousel dots)",
      "default": "#eb701f"
    },
    {
      "type": "header",
      "content": "Typography and spacing"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 28,
      "max": 44,
      "step": 1,
      "unit": "px",
      "label": "Title size",
      "default": 40
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Subtitle size",
      "default": 16
    },
    {
      "type": "range",
      "id": "header_margin_bottom",
      "min": 32,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Space below header",
      "default": 64
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Column gap",
      "default": 32
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 8,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Card corner radius",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 48,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 48,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "MP4 video (Shopify picker)",
          "info": "Takes priority when set."
        },
        {
          "type": "url",
          "id": "youtube_url",
          "label": "YouTube link",
          "info": "Supports youtu.be, watch?v=, embed, and shorts URLs. Without a custom thumbnail, the YouTube poster image is used."
        },
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Custom thumbnail (optional)"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Description (accessibility)",
          "info": "Used for thumbnail alt text and embed title; not shown on the page.",
          "default": "\"The most precise dial mechanism I've used this year.\" - FitTech Daily"
        },
        {
          "type": "text",
          "id": "play_label",
          "label": "Play button accessibility label (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trusted by tech critics",
      "category": "Storytelling",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "quote": "\"The most precise dial mechanism I've used this year.\" - FitTech Daily"
          }
        },
        {
          "type": "review",
          "settings": {
            "quote": "\"Perfect for small apartments without compromising on heavy lifts.\" - GarageGymReviews"
          }
        },
        {
          "type": "review",
          "settings": {
            "quote": "\"The build quality is industry-standard. Solid steel.\" - ProTrainer Insights"
          }
        }
      ]
    }
  ]
}
{% endschema %}
