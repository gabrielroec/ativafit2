  #{{ bs_id }} .bundle-steps__recovery-save { font-family: var(--heading-font-family) !important; font-size: 11px !important; font-weight: 700 !important; letter-spacing: .04em !important; text-transform: uppercase !important; color: {{ section.settings.selection_border_color }} !important; background: rgba(235, 112, 31, .16) !important; padding: 6px 12px !important; border-radius: 999px !important; }
  #{{ bs_id }} .bundle-steps__recovery-description { font-family: var(--text-font-family) !important; font-size: 15px !important; line-height: 1.55 !important; color: {{ section.settings.description_color }} !important; margin: 0 !important; }
