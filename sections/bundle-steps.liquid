  #{{ bs_id }} .bundle-steps__inner { max-width: 80rem; margin: 0 auto; padding: 0 24px; }
  #{{ bs_id }} .bundle-steps__part + .bundle-steps__part { margin-top: {{ section.settings.step_gap }}px; }
  #{{ bs_id }} .bundle-steps__heading { margin: 0 0 {{ section.settings.heading_margin_bottom }}px !important; font-family: var(--heading-font-family) !important; text-transform: uppercase !important; letter-spacing: -0.03em !important; line-height: 1.05 !important; }
  #{{ bs_id }} .bundle-steps__heading-num { color: {{ section.settings.step_number_color }} !important; font-weight: 800 !important; font-size: {{ section.settings.heading_num_size_mobile }}px !important; margin-right: 0.35em !important; }
  #{{ bs_id }} .bundle-steps__heading-text { color: {{ section.settings.step_title_color }} !important; font-weight: 900 !important; font-size: {{ section.settings.heading_title_size_mobile }}px !important; }
  @media screen and (min-width: 750px) {
    #{{ bs_id }} .bundle-steps__heading-num { font-size: {{ section.settings.heading_num_size_desktop }}px !important; }
    #{{ bs_id }} .bundle-steps__heading-text { font-size: {{ section.settings.heading_title_size_desktop }}px !important; }
  }
  #{{ bs_id }} .bundle-steps__fieldset { border: none; margin: 0; padding: 0; min-width: 0; }
  #{{ bs_id }} .bundle-steps__grid { display: grid; grid-template-columns: 1fr; gap: {{ section.settings.grid_gap }}px; align-items: stretch; }
