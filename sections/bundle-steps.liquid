  #{{ bs_id }} .bundle-steps__recovery-footer { display: flex; flex-direction: column; align-items: flex-start; gap: 16px; margin-top: auto; padding-top: 8px; }
  @media screen and (min-width: 750px) { #{{ bs_id }} .bundle-steps__recovery-footer { flex-direction: row; align-items: flex-end; justify-content: space-between; } }
  #{{ bs_id }} .bundle-steps__recovery-prices { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; }
  #{{ bs_id }} .bundle-steps__recovery-compare { font-size: 15px !important; color: #888 !important; text-decoration: line-through !important; }
  #{{ bs_id }} .bundle-steps__recovery-price { font-family: var(--heading-font-family) !important; font-size: 28px !important; font-weight: 700 !important; color: {{ section.settings.selection_border_color }} !important; line-height: 1 !important; }
  #{{ bs_id }} .bundle-steps__recovery-include { display: inline-flex; align-items: center; justify-content: center; font-family: var(--heading-font-family) !important; font-size: 12px !important; font-weight: 700 !important; letter-spacing: .06em !important; text-transform: uppercase !important; color: #fff !important; background: #000 !important; padding: 14px 22px !important; border-radius: 8px !important; white-space: nowrap; border: none; cursor: pointer; transition: background-color .2s ease, box-shadow .2s ease; }
  #{{ bs_id }} .bundle-steps__recovery-include--active { background: {{ section.settings.selection_border_color }} !important; box-shadow: 0 4px 14px rgba(235, 112, 31, .35); }
  @media screen and (max-width: 749px) {
    #{{ bs_id }} .bundle-steps__inner { padding: 0 16px; }
    #{{ bs_id }} .bundle-steps__part + .bundle-steps__part { margin-top: 36px; }
    #{{ bs_id }} .bundle-steps__grid--step1,
    #{{ bs_id }} .bundle-steps__grid--step2 { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
    #{{ bs_id }} .bundle-steps__grid--step1 .bundle-steps__cell:nth-child(3),
    #{{ bs_id }} .bundle-steps__grid--step2 .bundle-steps__cell:nth-child(3) { grid-column: 1 / -1; max-width: calc(50% - 6px); justify-self: center; }
