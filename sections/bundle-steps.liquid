    #{{ bs_id }} .bundle-steps__recovery-save { font-size: 10px !important; padding: 4px 8px !important; }
    #{{ bs_id }} .bundle-steps__recovery-description { font-size: 12px !important; line-height: 1.4 !important; }
    #{{ bs_id }} .bundle-steps__recovery-footer { gap: 10px; padding-top: 2px; }
    #{{ bs_id }} .bundle-steps__recovery-compare { font-size: 12px !important; }
    #{{ bs_id }} .bundle-steps__recovery-price { font-size: 22px !important; }
    #{{ bs_id }} .bundle-steps__recovery-include { width: 100%; font-size: 11px !important; padding: 11px 14px !important; }
    #{{ bs_id }} .bundle-steps__recovery-ribbon { font-size: 8px !important; padding: 6px 10px 6px 14px !important; letter-spacing: .08em !important; max-width: 45%; }
  }

  /* ── Step lock state ─────────────────────────────────────────────── */
  #{{ bs_id }} .bundle-steps__heading-optional {
    font-size: 0.5em !important;
    font-weight: 600 !important;
    letter-spacing: 0.06em !important;
    text-transform: uppercase !important;
    color: #aaa !important;
    margin-left: 0.5em !important;
    vertical-align: middle !important;
  }
  #{{ bs_id }} .bundle-steps__lock-hint {
    display: none;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    margin-bottom: 20px;
    background: #f8f8f8;
    border-radius: 8px;
    border-left: 3px solid #d8d8d8;
    font-family: var(--text-font-family) !important;
    font-size: 13px !important;
    color: #888 !important;
    line-height: 1.4 !important;
  }
  #{{ bs_id }} .bundle-steps__lock-icon { flex-shrink: 0; color: #bbb; }
  #{{ bs_id }} .bundle-steps__part.is-locked .bundle-steps__lock-hint { display: flex; }
  #{{ bs_id }} .bundle-steps__part.is-locked .bundle-steps__fieldset {
    opacity: 0.28;
    pointer-events: none;
    user-select: none;
    transition: opacity 0.25s ease;
  }
  #{{ bs_id }} .bundle-steps__part.is-locked [data-bundle-recovery-card] {
    opacity: 0.28;
    pointer-events: none;
    user-select: none;
    transition: opacity 0.25s ease;
  }
  #{{ bs_id }} .bundle-steps__part:not(.is-locked) .bundle-steps__fieldset,
  #{{ bs_id }} .bundle-steps__part:not(.is-locked) [data-bundle-recovery-card] {
    transition: opacity 0.25s ease;
  }
</style>

{% schema %}
{
  "name": "Bundle steps",
  "tag": "section",
  "class": "section-bundle-steps",
  "max_blocks": 6,
