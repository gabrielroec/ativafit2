  #{{ bs_id }} .bundle-steps__cell { display: flex; flex-direction: column; min-width: 0; min-height: 0; }
  #{{ bs_id }} .bundle-option-card { display: flex; flex-direction: column; flex: 1; min-height: 0; height: 100%; cursor: pointer; margin: 0; }
