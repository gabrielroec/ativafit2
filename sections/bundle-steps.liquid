{%- liquid
  assign bs_id = 'bundle-steps-' | append: section.id
  assign step1_name = 'bundle-dumbbell-base-' | append: section.id
  assign step2_name = 'bundle-support-storage-' | append: section.id

  assign s3_product = section.settings.step3_product
  assign s3_variant = nil
  if s3_product != blank
    assign s3_variant = s3_product.selected_or_first_available_variant
  endif
  assign s3_save_cents = 0
  assign s3_show_auto_save = false
  if s3_variant != blank
    assign s3_compare = s3_variant.compare_at_price
    assign s3_price = s3_variant.price
    if s3_compare != blank and s3_compare > s3_price and s3_compare > 0
      assign s3_save_cents = s3_compare | minus: s3_price
      assign s3_show_auto_save = true
    endif
  endif
  assign s3_save_label = section.settings.step3_save_badge_text | strip
  if s3_save_label == blank and s3_show_auto_save
    assign s3_save_money = s3_save_cents | money
    assign s3_save_label = 'SAVE ' | append: s3_save_money
  endif
  assign s3_display_title = section.settings.step3_card_title | strip
  if s3_display_title == blank and s3_product != blank
    assign s3_display_title = s3_product.title
  endif

  assign s1_discount_cents = section.settings.step1_item_discount | times: 100
  assign s2_discount_cents = section.settings.step2_item_discount | times: 100
  assign s3_discount_cents = section.settings.step3_item_discount | times: 100
-%}

<section id="{{ bs_id }}" class="bundle-steps" data-section-type="bundle-steps" {{ section.shopify_attributes }}>
  <div class="bundle-steps__inner">
    <div id="bundle-step-1" class="bundle-steps__part" data-section-type="bundle-step-dumbbell-base" data-bundle-step="1">
      <h2 class="bundle-steps__heading">
        <span class="bundle-steps__heading-num">{{ section.settings.step1_number | escape }}</span>
        <span class="bundle-steps__heading-text">{{ section.settings.step1_title | escape }}</span>
      </h2>
      <fieldset class="bundle-steps__fieldset">
        <legend class="visually-hidden">{{ section.settings.step1_legend | escape }}</legend>
        <div class="bundle-steps__grid bundle-steps__grid--step1" role="radiogroup" aria-label="{{ section.settings.step1_legend | escape }}">
          {%- assign s1_render = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'step1_option' -%}
              {%- assign s1_render = s1_render | plus: 1 -%}
              <div class="bundle-steps__cell" {{ block.shopify_attributes }}>
                {%- assign p = block.settings.product -%}
                {%- if p != blank -%}
                  {%- assign v = p.selected_or_first_available_variant -%}
                  {%- assign input_id = 'bundle-s1-' | append: section.id | append: '-' | append: s1_render -%}
                  {%- render 'bundle-option-card',
                    product: p,
                    variant: v,
                    input_id: input_id,
                    input_name: step1_name,
                    input_type: 'checkbox',
                    card_title: block.settings.card_title,
                    card_description: block.settings.card_description,
                    badge_label: block.settings.badge_label,
                    line_category: block.settings.sidebar_category,
                    discount_cents: s1_discount_cents
                  -%}
                {%- else -%}
                  <div class="bundle-steps__placeholder"><span>{{ section.settings.empty_state_text | escape }}</span></div>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </fieldset>
    </div>

    <div class="bundle-steps__part" data-section-type="bundle-step-support-storage" data-bundle-step="2">
      <h2 class="bundle-steps__heading">
        <span class="bundle-steps__heading-num">{{ section.settings.step2_number | escape }}</span>
        <span class="bundle-steps__heading-text">{{ section.settings.step2_title | escape }}</span>
      </h2>
      <div class="bundle-steps__lock-hint" data-bundle-lock-hint aria-live="polite">
        <svg class="bundle-steps__lock-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="3" y="7" width="10" height="8" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M5 7V5a3 3 0 0 1 6 0v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <span>Select at least 1 product in Step {{ section.settings.step1_number | escape }} to unlock this step.</span>
      </div>
      <fieldset class="bundle-steps__fieldset">
        <legend class="visually-hidden">{{ section.settings.step2_legend | escape }}</legend>
        <div class="bundle-steps__grid bundle-steps__grid--step2" role="radiogroup" aria-label="{{ section.settings.step2_legend | escape }}">
          {%- assign s2_render = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'step2_option' -%}
              {%- assign s2_render = s2_render | plus: 1 -%}
              <div class="bundle-steps__cell" {{ block.shopify_attributes }}>
                {%- assign p = block.settings.product -%}
                {%- if p != blank -%}
                  {%- assign v = p.selected_or_first_available_variant -%}
                  {%- assign input_id = 'bundle-s2-' | append: section.id | append: '-' | append: s2_render -%}
                  {%- render 'bundle-option-card',
                    product: p,
                    variant: v,
                    input_id: input_id,
                    input_name: step2_name,
                    input_type: 'checkbox',
                    card_title: block.settings.card_title,
                    card_description: block.settings.card_description,
                    badge_label: block.settings.badge_label,
                    line_category: block.settings.sidebar_category,
                    discount_cents: s2_discount_cents
                  -%}
                {%- else -%}
                  <div class="bundle-steps__placeholder"><span>{{ section.settings.empty_state_text | escape }}</span></div>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </fieldset>
    </div>

    <div class="bundle-steps__part" data-section-type="bundle-step-recovery-protocol" data-bundle-step="3">
      <h2 class="bundle-steps__heading">
        <span class="bundle-steps__heading-num">{{ section.settings.step3_number | escape }}</span>
        <span class="bundle-steps__heading-text">{{ section.settings.step3_title | escape }}</span>
        <span class="bundle-steps__heading-optional">(optional)</span>
      </h2>
      <div class="bundle-steps__lock-hint" data-bundle-lock-hint aria-live="polite">
        <svg class="bundle-steps__lock-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="3" y="7" width="10" height="8" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M5 7V5a3 3 0 0 1 6 0v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <span>Select at least 1 product in Step {{ section.settings.step2_number | escape }} to unlock this step.</span>
      </div>
      {%- if s3_product != blank and s3_variant != blank -%}
        {%- assign s3_on = section.settings.step3_included_default -%}
        <div
        class="bundle-steps__recovery-card{% if s3_on %} is-included{% endif %}"
          data-bundle-recovery-card
          data-bundle-variant-id="{{ s3_variant.id }}"
          data-bundle-line-title="{{ s3_display_title | escape }}"
          data-bundle-line-category="{{ section.settings.step3_sidebar_category | escape }}"
          data-bundle-compare-price-cents="{{ s3_variant.compare_at_price | default: 0 }}"
          data-bundle-price-cents="{{ s3_variant.price }}"
          data-bundle-discount-cents="{{ s3_discount_cents }}">
          {%- if section.settings.step3_lab_ribbon_text != blank -%}
            <div class="bundle-steps__recovery-ribbon">{{ section.settings.step3_lab_ribbon_text | escape }}</div>
          {%- endif -%}
          <div class="bundle-steps__recovery-layout">
            <div class="bundle-steps__recovery-media">
              {%- assign img = s3_variant.image | default: s3_product.featured_image -%}
              {%- if img -%}
                {{ img | image_url: width: 800 | image_tag: loading: 'lazy', class: 'bundle-steps__recovery-img', widths: '200, 300, 400, 600, 800', sizes: '(min-width: 750px) 320px, 100vw', alt: img.alt | default: s3_display_title | escape }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'bundle-steps__recovery-img-ph' }}
              {%- endif -%}
            </div>
            <div class="bundle-steps__recovery-content">
              <div class="bundle-steps__recovery-title-row">
                <h3 class="bundle-steps__recovery-title">{{ s3_display_title | escape }}</h3>
                {%- if s3_save_label != blank -%}
                  <span class="bundle-steps__recovery-save">{{ s3_save_label | escape }}</span>
                {%- endif -%}
              </div>
              {%- if section.settings.step3_description != blank -%}
                <div class="bundle-steps__recovery-description rte">{{ section.settings.step3_description }}</div>
              {%- endif -%}
              <div class="bundle-steps__recovery-footer">
                <div class="bundle-steps__recovery-prices">
                  {%- assign compare = s3_variant.compare_at_price -%}
                  {%- assign price = s3_variant.price -%}
                  {%- if compare != blank and compare > price and compare > 0 -%}
                    <span class="bundle-steps__recovery-compare">{{ compare | money }}</span>
                  {%- endif -%}
                  <span class="bundle-steps__recovery-price">{{ price | money }}</span>
                </div>
                <button type="button" class="bundle-steps__recovery-include{% if s3_on %} bundle-steps__recovery-include--active{% endif %}" data-bundle-recovery-toggle aria-pressed="{% if s3_on %}true{% else %}false{% endif %}">
                  {{ section.settings.step3_included_label | escape }}
                </button>
              </div>
            </div>
          </div>
        </div>
      {%- else -%}
        <div class="bundle-steps__placeholder"><span>{{ section.settings.empty_state_text | escape }}</span></div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
