  #{{ bs_id }} .bundle-option-card__input:checked + .bundle-option-card__surface { border-width: 3px; border-color: {{ section.settings.selection_border_color }}; box-shadow: 0 0 0 1px {{ section.settings.selection_border_color }}; }
