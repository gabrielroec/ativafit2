  #{{ bs_id }} [data-section-type='bundle-step-dumbbell-base'] .bundle-option-card__body { align-items: flex-start; text-align: left; }
  #{{ bs_id }} [data-section-type='bundle-step-support-storage'] .bundle-option-card__body { align-items: center; text-align: center; }
  #{{ bs_id }} .bundle-option-card__badge { font-family: var(--heading-font-family) !important; font-size: 11px !important; font-weight: 700 !important; letter-spacing: .08em !important; text-transform: uppercase !important; color: {{ section.settings.selection_border_color }} !important; background: rgba(235, 112, 31, .14) !important; padding: 5px 10px !important; border-radius: 6px !important; line-height: 1.2 !important; }
  #{{ bs_id }} .bundle-option-card__title { font-family: var(--heading-font-family) !important; font-size: 16px !important; line-height: 1.3 !important; font-weight: 700 !important; color: #000 !important; margin: 0 !important; }
  #{{ bs_id }} .bundle-option-card__desc { font-family: var(--text-font-family) !important; font-size: 14px !important; line-height: 1.45 !important; color: {{ section.settings.description_color }} !important; margin: 0 !important; }
  #{{ bs_id }} .bundle-option-card__price-row { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; margin-top: auto; padding-top: 4px; }
  #{{ bs_id }} [data-section-type='bundle-step-support-storage'] .bundle-option-card__price-row { justify-content: center; width: 100%; }
