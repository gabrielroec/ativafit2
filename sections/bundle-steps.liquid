  #{{ bs_id }} .bundle-steps__recovery-card.is-included { border-width: 3px; border-color: {{ section.settings.selection_border_color }}; box-shadow: 0 0 0 1px {{ section.settings.selection_border_color }}; }
  #{{ bs_id }} .bundle-steps__recovery-ribbon { position: absolute; top: 0; right: 0; z-index: 2; font-family: var(--heading-font-family) !important; font-size: 10px !important; font-weight: 700 !important; letter-spacing: .12em !important; text-transform: uppercase !important; color: #fff !important; background: {{ section.settings.selection_border_color }} !important; padding: 10px 16px 10px 22px !important; border-radius: 0 0 0 12px !important; max-width: 55%; text-align: right; line-height: 1.2 !important; }
  #{{ bs_id }} .bundle-steps__recovery-layout { display: flex; flex-direction: column; }
  @media screen and (min-width: 750px) { #{{ bs_id }} .bundle-steps__recovery-layout { flex-direction: row; align-items: stretch; min-height: 280px; } }
  #{{ bs_id }} .bundle-steps__recovery-media { flex-shrink: 0; background: #f2f2f2; aspect-ratio: 1 / 1; max-height: 320px; }
  @media screen and (min-width: 750px) { #{{ bs_id }} .bundle-steps__recovery-media { width: 320px; max-height: none; align-self: stretch; min-height: 0; } }
  #{{ bs_id }} .bundle-steps__recovery-img, #{{ bs_id }} .bundle-steps__recovery-img-ph { width: 100%; height: 100%; object-fit: contain; display: block; }
  #{{ bs_id }} .bundle-steps__recovery-content { flex: 1; min-width: 0; padding: 24px; display: flex; flex-direction: column; gap: 12px; }
  #{{ bs_id }} .bundle-steps__recovery-title-row { display: flex; flex-wrap: wrap; align-items: center; gap: 10px 14px; }
