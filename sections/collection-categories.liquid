<div class="collection-categories" data-collection-categories>
  <div class="collection-categories__grid" data-collection-categories-swipe>
    {% for block in section.blocks %}
      <div class="collection-category collection-category--{{ block.id }}" {{ block.shopify_attributes }}>
        <div class="collection-category__image-container">

          <img
            src="{{ block.settings.category_image | image_url: width: 583, height: 530, crop: 'center', format: 'webp' }}"
            srcset="{{ block.settings.category_image | image_url: width: 292, height: 265, crop: 'center', format: 'webp' }} 292w,
                    {{ block.settings.category_image | image_url: width: 583, height: 530, crop: 'center', format: 'webp' }} 583w"
            sizes="(max-width: 768px) 100vw, 583px"
            width="583"
            height="530"
            alt="{{ block.settings.category_title | strip_html }}"
            loading="lazy"
            class="collection-category__image">
          <div class="collection-category__overlay">
            <a href="{{ block.settings.category_link }}" class="collection-category__button">
              {{ block.settings.button_text | default: 'SHOP NOW' }}
            </a>
          </div>
        </div>
        <h3 class="collection-category__title">{{ block.settings.category_title }}</h3>
      </div>
    {% endfor %}
  </div>
</div>

{%- style -%}
  .collection-categories {
    width: 100%;
    max-width: 1750px;
    margin: 70px auto 0;
    padding: 0 20px;
  }

  .collection-categories__grid {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    justify-content: center;
  }

  .collection-category {
    text-align: center;
    position: relative;
    width: 100%;
  }

  .collection-category__image-container {
    position: relative;
    width: 100%;
    height: 502px;
    overflow: hidden;
    border-radius: 16px;
  }

  .collection-category__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
    border-radius: 16px;
  }

  .collection-category__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    border-radius: 16px;
  }

  .collection-category:hover .collection-category__overlay {
    opacity: 1;
  }

  .collection-category__button {
    background: #fff;
    color: #000;
    padding: 12px 24px;
    border-radius: 4px;
    text-decoration: none;
    font-weight: bold;
    transition: all 0.3s ease;
  }

  .collection-category__button:hover {
    background: #c23d12;
    color: #fff;
  }

  {% for block in section.blocks %}
    .collection-category--{{ block.id }}
    .collection-category__title {
      margin: 0 auto;
      font-size: 24px;
      font-weight: bold;
      color: #fff;
      position: absolute;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      max-width: {{ block.settings.title_max_width | default: 200 }}px;
      text-align: center;
      line-height: 1.2;
    }
  {% endfor %}

  /* < 768px: modo swipe/scroll lateral */
  @media screen and (max-width: 767px) {
    .collection-categories {
      margin: 40px auto 0;
      padding: 0 10px;
    }

    .collection-categories__grid {
      display: flex;
      flex-wrap: nowrap;
      gap: 16px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: 20px;
      cursor: grab;
      justify-content: flex-start;
    }

    .collection-categories__grid::-webkit-scrollbar {
      display: none;
    }

    .collection-categories__grid.is-down {
      cursor: grabbing;
    }

    .collection-categories__grid.is-down .collection-category {
      -webkit-user-select: none;
      user-select: none;
    }

    .collection-categories__grid.is-dragging .collection-category {
      pointer-events: none;
    }

    .collection-category {
      flex: 0 0 85%;
      max-width: 400px;
      min-width: 280px;
    }

    .collection-category__image-container {
      height: calc((100vw - 20px) * 0.75);
    }

    {% for block in section.blocks %}
      .collection-category--{{ block.id }}
      .collection-category__title {
        font-size: 20px;
        bottom: 15px;
        max-width: {{ block.settings.title_max_width_mobile | default: 180 }}px;
      }
    {% endfor %}
  }

  @media screen and (max-width: 480px) {
    {% for block in section.blocks %}
      .collection-category--{{ block.id }}
      .collection-category__title {
        font-size: 18px;
      }
    {% endfor %}
  }
{%- endstyle -%}

<script>
  (function() {
    var section = document.querySelector('[data-collection-categories]');
    if (!section) return;
    var grid = section.querySelector('[data-collection-categories-swipe]');
    if (!grid) return;

    grid.scrollLeft = 0;

    var isDown = false, isDragging = false, justDragged = false, startX, scrollLeft;

    function onMouseMove(e) {
      if (!isDown) return;
      e.preventDefault();
      var x = e.pageX - grid.offsetLeft;
      var walk = (x - startX) * 2;
      if (Math.abs(walk) > 10) {
        isDragging = true;
        grid.classList.add('is-dragging');
      }
      grid.scrollLeft = scrollLeft - walk;
    }

    function onMouseUp() {
      if (isDragging) justDragged = true;
      isDown = false;
      isDragging = false;
      grid.classList.remove('is-down', 'is-dragging');
      document.removeEventListener('mousemove', onMouseMove);
      document.removeEventListener('mouseup', onMouseUp);
    }

    grid.addEventListener('mousedown', function(e) {
      if (e.target.closest('a')) return;
      e.preventDefault();
      isDown = true;
      isDragging = false;
      grid.classList.add('is-down');
      startX = e.pageX - grid.offsetLeft;
      scrollLeft = grid.scrollLeft;
      document.addEventListener('mousemove', onMouseMove);
      document.addEventListener('mouseup', onMouseUp);
    });
    grid.addEventListener('mouseleave', function() {
      if (!isDown) return;
      onMouseUp();
    });
    grid.addEventListener('click', function(e) {
      if (justDragged) {
        e.preventDefault();
        e.stopPropagation();
        justDragged = false;
      }
    }, true);
  })();
</script>

