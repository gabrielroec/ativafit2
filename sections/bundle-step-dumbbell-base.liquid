{%- liquid
  assign bsd_id = 'bundle-step-dumbbell-' | append: section.id
  assign radio_name = 'bundle-dumbbell-base-' | append: section.id
  assign bsd_default_slot = 0
  assign bsd_first_slot = 0

  for block in section.blocks
    if block.type == 'dumbbell_option'
      assign bsd_prod = block.settings.product
      if bsd_prod != blank
        assign bsd_var = bsd_prod.selected_or_first_available_variant
        if bsd_var != blank
          if bsd_first_slot == 0
            assign bsd_first_slot = forloop.index
          endif
          if block.settings.default_selected and bsd_default_slot == 0
            assign bsd_default_slot = forloop.index
          endif
        endif
      endif
    endif
  endfor

  if bsd_default_slot == 0
    assign bsd_default_slot = bsd_first_slot
  endif
-%}

<section
  id="{{ bsd_id }}"
  class="bundle-step-dumbbell-base"
  data-section-type="bundle-step-dumbbell-base"
  {{ section.shopify_attributes }}>
  <div class="bundle-step-dumbbell-base__inner">
    <h2 class="bundle-step-dumbbell-base__heading">
      <span class="bundle-step-dumbbell-base__heading-num">{{ section.settings.step_number | escape }}</span>
      <span class="bundle-step-dumbbell-base__heading-text">{{ section.settings.step_title | escape }}</span>
    </h2>

    <fieldset class="bundle-step-dumbbell-base__fieldset">
      <legend class="visually-hidden">{{ section.settings.fieldset_legend | escape }}</legend>
      <div class="bundle-step-dumbbell-base__grid" role="radiogroup" aria-label="{{ section.settings.fieldset_legend | escape }}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'dumbbell_option' -%}
            <div class="bundle-step-dumbbell-base__cell" {{ block.shopify_attributes }}>
              {%- assign opt_product = block.settings.product -%}
              {%- if opt_product != blank -%}
                {%- assign opt_variant = opt_product.selected_or_first_available_variant -%}
                {%- assign input_id = 'bundle-dumbbell-' | append: section.id | append: '-' | append: forloop.index -%}
                {%- assign is_checked = false -%}
                {%- if forloop.index == bsd_default_slot -%}
                  {%- assign is_checked = true -%}
                {%- endif -%}
                {%- render 'bundle-option-card',
                  product: opt_product,
                  variant: opt_variant,
                  input_id: input_id,
                  input_name: radio_name,
                  checked: is_checked,
                  card_title: block.settings.card_title,
                  card_description: block.settings.card_description,
                  badge_label: block.settings.badge_label,
                  line_category: block.settings.sidebar_category,
                  line_icon: block.settings.sidebar_icon
                -%}
              {%- else -%}
                <div class="bundle-step-dumbbell-base__placeholder">
                  <span class="bundle-step-dumbbell-base__placeholder-inner">{{ section.settings.empty_state_text | escape }}</span>
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </fieldset>
  </div>
</section>

<style>
  #{{ bsd_id }}.bundle-step-dumbbell-base {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
  }

  #{{ bsd_id }} .bundle-step-dumbbell-base__inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 24px;
  }

  #{{ bsd_id }} .bundle-step-dumbbell-base__heading {
    font-family: var(--heading-font-family) !important;
    margin: 0 0 {{ section.settings.heading_margin_bottom }}px !important;
    line-height: 1.05 !important;
    text-transform: uppercase !important;
    letter-spacing: -0.03em !important;
  }

  #{{ bsd_id }} .bundle-step-dumbbell-base__heading-num {
    color: {{ section.settings.step_number_color }} !important;
    font-weight: 800 !important;
    font-size: {{ section.settings.heading_num_size_mobile }}px !important;
    margin-right: 0.35em !important;
  }

  #{{ bsd_id }} .bundle-step-dumbbell-base__heading-text {
    color: {{ section.settings.step_title_color }} !important;
    font-weight: 900 !important;
    font-size: {{ section.settings.heading_title_size_mobile }}px !important;
  }

  @media screen and (min-width: 750px) {
    #{{ bsd_id }} .bundle-step-dumbbell-base__heading-num {
      font-size: {{ section.settings.heading_num_size_desktop }}px !important;
    }
    #{{ bsd_id }} .bundle-step-dumbbell-base__heading-text {
      font-size: {{ section.settings.heading_title_size_desktop }}px !important;
    }
  }

  #{{ bsd_id }} .bundle-step-dumbbell-base__fieldset {
    border: none;
    margin: 0;
    padding: 0;
    min-width: 0;
  }

  #{{ bsd_id }} .bundle-step-dumbbell-base__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ section.settings.grid_gap }}px;
    align-items: stretch;
  }

  @media screen and (min-width: 750px) {
    #{{ bsd_id }} .bundle-step-dumbbell-base__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  #{{ bsd_id }} .bundle-step-dumbbell-base__cell {
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-self: stretch;
    min-height: 0;
  }

  /* Card (alinhado a product-card-simple da coleção) */
  #{{ bsd_id }} .bundle-option-card {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    height: 100%;
    cursor: pointer;
    margin: 0;
  }

  #{{ bsd_id }} .bundle-option-card__surface {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    height: 100%;
    background: #ffffff;
    border-radius: 10px;
    border: 1px solid #e5e5e5;
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  #{{ bsd_id }} .bundle-option-card__input:checked + .bundle-option-card__surface {
    border-width: 3px;
    border-color: {{ section.settings.selection_border_color }};
    box-shadow: 0 0 0 1px {{ section.settings.selection_border_color }};
  }

  #{{ bsd_id }} .bundle-option-card__input:focus-visible + .bundle-option-card__surface {
    outline: 2px solid {{ section.settings.selection_border_color }};
    outline-offset: 3px;
  }

  #{{ bsd_id }} .bundle-option-card__media {
    position: relative;
    background: #f2f2f2;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  #{{ bsd_id }} .bundle-option-card__img,
  #{{ bsd_id }} .bundle-option-card__placeholder {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  #{{ bsd_id }} .bundle-option-card__check {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: {{ section.settings.selection_border_color }};
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
    z-index: 2;
  }

  #{{ bsd_id }} .bundle-option-card__input:checked + .bundle-option-card__surface .bundle-option-card__check {
    opacity: 1;
    transform: scale(1);
  }

  #{{ bsd_id }} .bundle-option-card__body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-start;
    flex: 1;
  }

  #{{ bsd_id }} .bundle-option-card__badge {
    font-family: var(--heading-font-family) !important;
    font-size: 11px !important;
    font-weight: 700 !important;
    letter-spacing: 0.08em !important;
    text-transform: uppercase !important;
    color: {{ section.settings.selection_border_color }} !important;
    background: rgba(235, 112, 31, 0.14) !important;
    padding: 5px 10px !important;
    border-radius: 6px !important;
    line-height: 1.2 !important;
  }

  #{{ bsd_id }} .bundle-option-card__title {
    font-family: var(--heading-font-family) !important;
    font-size: 16px !important;
    line-height: 1.3 !important;
    font-weight: 700 !important;
    color: #000000 !important;
    margin: 0 !important;
  }

  #{{ bsd_id }} .bundle-option-card__desc {
    font-family: var(--text-font-family) !important;
    font-size: 14px !important;
    line-height: 1.45 !important;
    font-weight: var(--text-font-weight) !important;
    color: {{ section.settings.description_color }} !important;
    margin: 0 !important;
  }

  #{{ bsd_id }} .bundle-option-card__price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: 4px;
  }

  #{{ bsd_id }} .bundle-option-card__price {
    font-family: var(--heading-font-family) !important;
    font-size: 18px !important;
    font-weight: 700 !important;
    color: {{ section.settings.selection_border_color }} !important;
    line-height: 1 !important;
  }

  #{{ bsd_id }} .bundle-option-card__compare {
    font-size: 14px !important;
    color: #555555 !important;
    text-decoration: line-through !important;
  }

  #{{ bsd_id }} .bundle-step-dumbbell-base__placeholder {
    border: 2px dashed #e0e0e0;
    border-radius: 10px;
    flex: 1;
    min-height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    text-align: center;
    background: #fafafa;
  }

  #{{ bsd_id }} .bundle-step-dumbbell-base__placeholder-inner {
    font-family: var(--text-font-family) !important;
    font-size: 14px !important;
    color: #888888 !important;
  }
</style>

{% schema %}
{
  "name": "Step 1: dumbbell base",
  "tag": "section",
  "class": "section-bundle-step-dumbbell-base",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "step_number",
      "label": "Número do passo",
      "default": "01"
    },
    {
      "type": "text",
      "id": "step_title",
      "label": "Título do passo",
      "default": "DUMBBELL BASE"
    },
    {
      "type": "text",
      "id": "fieldset_legend",
      "label": "Legenda do grupo (acessibilidade)",
      "default": "Choose your dumbbell base"
    },
    {
      "type": "text",
      "id": "empty_state_text",
      "label": "Texto quando o produto não está definido",
      "default": "Select a product in this block"
    },
    {
      "type": "header",
      "content": "Cores"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fundo da secção",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "step_number_color",
      "label": "Cor do número (ex.: 01)",
      "default": "#e8b896"
    },
    {
      "type": "color",
      "id": "step_title_color",
      "label": "Cor do título",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Cor da descrição nos cards",
      "default": "#574237"
    },
    {
      "type": "color",
      "id": "selection_border_color",
      "label": "Cor de seleção (borda + check)",
      "default": "#eb701f"
    },
    {
      "type": "header",
      "content": "Tipografia"
    },
    {
      "type": "range",
      "id": "heading_num_size_mobile",
      "min": 24,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Tamanho do número — mobile",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_num_size_desktop",
      "min": 28,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Tamanho do número — desktop",
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_title_size_mobile",
      "min": 20,
      "max": 36,
      "step": 1,
      "unit": "px",
      "label": "Tamanho do título — mobile",
      "default": 26
    },
    {
      "type": "range",
      "id": "heading_title_size_desktop",
      "min": 24,
      "max": 44,
      "step": 1,
      "unit": "px",
      "label": "Tamanho do título — desktop",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Espaço abaixo do título",
      "default": 28
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Espaço entre cards",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 24,
      "max": 96,
      "step": 4,
      "unit": "px",
      "label": "Padding superior",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 24,
      "max": 96,
      "step": 4,
      "unit": "px",
      "label": "Padding inferior",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "dumbbell_option",
      "name": "Opção",
      "limit": 3,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Produto"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Título no card (opcional)",
          "info": "Se vazio, usa o título do produto."
        },
        {
          "type": "textarea",
          "id": "card_description",
          "label": "Descrição curta"
        },
        {
          "type": "text",
          "id": "badge_label",
          "label": "Badge (opcional)",
          "info": "Ex.: CORE CHOICE — deixe vazio para ocultar."
        },
        {
          "type": "checkbox",
          "id": "default_selected",
          "label": "Pré-selecionado",
          "default": false,
          "info": "Marque só numa opção. Se nenhuma, a primeira com produto fica selecionada."
        },
        {
          "type": "text",
          "id": "sidebar_category",
          "label": "Categoria na sidebar",
          "default": "ADJUSTABLE DUMBBELLS"
        },
        {
          "type": "select",
          "id": "sidebar_icon",
          "label": "Ícone na sidebar (Material)",
          "default": "fitness_center",
          "options": [
            { "value": "fitness_center", "label": "fitness_center" },
            { "value": "exercise", "label": "exercise" },
            { "value": "sports_martial_arts", "label": "sports_martial_arts" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Step 1: dumbbell base",
      "category": "Product",
      "blocks": [
        {
          "type": "dumbbell_option",
          "settings": {
            "product": "50lbs",
            "card_title": "50 lb Elite Set",
            "card_description": "Versatile range for all levels.",
            "badge_label": "CORE CHOICE",
            "default_selected": true
          }
        },
        {
          "type": "dumbbell_option",
          "settings": {
            "product": "66lbs",
            "card_title": "66 lb Pro Set",
            "card_description": "Engineered for strength progression.",
            "badge_label": "",
            "default_selected": false
          }
        },
        {
          "type": "dumbbell_option",
          "settings": {
            "product": "88lbs",
            "card_title": "88 lb Max Set",
            "card_description": "Elite performance capacity.",
            "badge_label": "",
            "default_selected": false
          }
        }
      ]
    }
  ]
}
{% endschema %}
