{%- liquid
  assign section_id = 'CollectionGridSimple-' | append: section.id
  if section.settings.collection != blank
    assign collection_to_show = section.settings.collection
  else
    assign collection_to_show = collection
  endif

  assign extra_products = section.blocks | where: 'type', 'extra_product'
  assign has_collection = false
  if collection_to_show != blank and collection_to_show.products_count > 0
    assign has_collection = true
  endif
  assign has_extras = false
  if extra_products.size > 0
    assign has_extras = true
  endif

  assign show_filters = section.settings.show_filters
  assign show_search = section.settings.show_search
  assign show_sort = section.settings.show_sort
  assign show_count = section.settings.show_product_count
  assign show_color_swatch = section.settings.show_filter_color_swatch
  assign facet_default = section.settings.facet_groups_default | default: 'first_open'

  assign has_native_filters = false
  if has_collection and collection_to_show.filters.size > 0
    assign has_native_filters = true
  endif

  assign active_filter_count = 0
  if has_native_filters
    for filter in collection_to_show.filters
      if filter.active_values.size > 0
        assign active_filter_count = active_filter_count | plus: filter.active_values.size
      endif
      if filter.type == 'price_range'
        if filter.min_value.value != nil or filter.max_value.value != nil
          assign active_filter_count = active_filter_count | plus: 1
        endif
      endif
    endfor
  endif
-%}

{{ 'collection-filters.css' | asset_url | stylesheet_tag }}
<script src="{{ 'collection-filters.js' | asset_url }}" defer></script>

{%- if has_collection or has_extras -%}
  <section id="{{ section_id }}" class="collection-grid-simple">
    {%- if has_collection -%}
      {%- paginate collection_to_show.products by section.settings.products_per_page -%}
        <div class="collection-grid-simple__container">

          {%- comment -%} Toolbar {%- endcomment -%}
          {%- if show_search or show_sort or show_count or show_filters -%}
            <div class="cf-toolbar">
              {%- if show_search -%}
                <div class="cf-search">
                  <input
                    type="text"
                    class="cf-search__input"
                    placeholder="Search products..."
                    data-collection-search
                    aria-label="Search products in this collection">
                  <button type="button" class="cf-search__clear" data-search-clear aria-label="Clear search">
                    <svg width="14" height="14" viewBox="0 0 14 14"><line x1="3" y1="3" x2="11" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="11" y1="3" x2="3" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  </button>
                  <span class="cf-search__icon" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.5"/><line x1="11" y1="11" x2="14" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  </span>
                </div>
              {%- endif -%}

              {%- if show_filters -%}
                <button type="button" class="cf-mobile-toggle" data-filter-drawer-toggle aria-label="Open filters">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><line x1="1" y1="4" x2="15" y2="4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="1" y1="8" x2="11" y2="8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="1" y1="12" x2="13" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  Filters
                  <span class="cf-mobile-toggle__count" data-active-count style="{% if active_filter_count == 0 %}display:none{% endif %}">{{ active_filter_count }}</span>
                </button>
              {%- endif -%}

              {%- if show_sort -%}
                <div class="cf-sort">
                  <select class="cf-sort__select" data-sort-select aria-label="Sort products">
                    {%- for option in collection_to_show.sort_options -%}
                      <option value="{{ option.value }}" {% if collection_to_show.sort_by == option.value %}selected{% endif %}>
                        {{ option.name }}
                      </option>
                    {%- endfor -%}
                  </select>
                  <svg class="cf-sort__chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true"><polyline points="2 4 6 8 10 4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
              {%- endif -%}

              {%- if show_count -%}
                <span class="cf-product-count" data-product-count>
                  {{ collection_to_show.products_count }}
                  {%- if collection_to_show.products_count == 1 %} product{% else %} products{% endif -%}
                </span>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- comment -%} Active filter pills (native) {%- endcomment -%}
          {%- if show_filters and has_native_filters -%}
            {%- render 'collection-active-filters', collection: collection_to_show -%}
          {%- endif -%}

          {%- comment -%} JS active pills (when no native filters) {%- endcomment -%}
          {%- if show_filters and has_native_filters == false -%}
            <div class="cf-active-filters" data-js-active-filters style="display:none;"></div>
          {%- endif -%}

          {%- comment -%} Two-column layout: sidebar + grid {%- endcomment -%}
          <div class="cf-layout{% unless show_filters %} cf-layout--no-filters{% endunless %}">

            {%- comment -%} Sidebar (always render when show_filters is on) {%- endcomment -%}
            {%- if show_filters -%}
              <aside class="cf-sidebar" aria-label="Collection filters">
                {%- if has_native_filters -%}
                  {%- render 'collection-filters',
                    collection: collection_to_show,
                    show_color_swatch: show_color_swatch,
                    facet_default: facet_default
                  -%}
                {%- else -%}
                  <div class="cf-filters-js" data-js-filters>
                    <div class="cf-filters__groups" data-js-filter-groups></div>
                    <div class="cf-filters__actions">
                      <button type="button" class="cf-filters__clear" data-js-clear-all style="display:none;">Clear all</button>
                    </div>
                  </div>
                {%- endif -%}
              </aside>
            {%- endif -%}

            {%- comment -%} Product grid {%- endcomment -%}
            <div class="collection-grid-simple__main">
              {%- if collection_to_show.products.size > 0 -%}
                <div class="collection-grid-simple__grid" data-collection-grid>
                  {%- for product in collection_to_show.products -%}
                    {%- assign pv = product.selected_or_first_available_variant -%}
                    <div class="collection-grid-simple__item"
                      data-product-title="{{ product.title | escape }}"
                      data-product-type="{{ product.type | escape }}"
                      data-product-vendor="{{ product.vendor | escape }}"
                      data-product-price="{{ pv.price }}"
                      data-product-available="{{ pv.available }}"
                      data-product-tags="{{ product.tags | join: ',' | escape }}">
                      {%- render 'product-card-simple', product: product -%}
                    </div>
                  {%- endfor -%}

                  {%- if has_extras and paginate.pages <= 1 or paginate.current_page == paginate.pages -%}
                    {%- for block in extra_products -%}
                      {%- if block.settings.product != blank -%}
                        {%- assign extra_variant = nil -%}
                        {%- if block.settings.variant_index != blank -%}
                          {%- assign idx = block.settings.variant_index | plus: 0 -%}
                          {%- assign extra_variant = block.settings.product.variants[idx] -%}
                        {%- endif -%}
                        {%- assign ep = block.settings.product -%}
                        {%- assign epv = ep.selected_or_first_available_variant -%}
                        <div class="collection-grid-simple__item" {{ block.shopify_attributes }}
                          data-product-title="{{ ep.title | escape }}"
                          data-product-type="{{ ep.type | escape }}"
                          data-product-vendor="{{ ep.vendor | escape }}"
                          data-product-price="{{ epv.price }}"
                          data-product-available="{{ epv.available }}"
                          data-product-tags="{{ ep.tags | join: ',' | escape }}">
                          {%- render 'product-card-simple', product: ep, variant: extra_variant -%}
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}
                </div>

                <div class="cf-no-results" data-no-search-results style="display: none;">
                  <h3 class="cf-no-results__title">No matching products</h3>
                  <p class="cf-no-results__text">Try a different search term or adjust your filters.</p>
                  <button type="button" class="cf-no-results__link" data-js-clear-all>Clear all filters</button>
                </div>
              {%- else -%}
                <div class="cf-no-results">
                  <h3 class="cf-no-results__title">No products found</h3>
                  <p class="cf-no-results__text">Try removing some filters to see more products.</p>
                  <a href="{{ collection_to_show.url }}" class="cf-no-results__link">Clear all filters</a>
                </div>
              {%- endif -%}

              {%- if section.settings.show_pagination and paginate.pages > 1 -%}
                <div class="collection-grid-simple__pagination">
                  {%- render 'pagination', paginate: paginate -%}
                </div>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endpaginate -%}

    {%- else -%}
      <div class="collection-grid-simple__container">
        <div class="collection-grid-simple__grid" data-collection-grid>
          {%- for block in extra_products -%}
            {%- if block.settings.product != blank -%}
              {%- assign extra_variant = nil -%}
              {%- if block.settings.variant_index != blank -%}
                {%- assign idx = block.settings.variant_index | plus: 0 -%}
                {%- assign extra_variant = block.settings.product.variants[idx] -%}
              {%- endif -%}
              <div class="collection-grid-simple__item" {{ block.shopify_attributes }}>
                {%- render 'product-card-simple', product: block.settings.product, variant: extra_variant -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} Mobile filter drawer — always rendered when show_filters is on {%- endcomment -%}
    {%- if show_filters and has_collection -%}
      <div class="cf-drawer-overlay" data-filter-drawer-overlay></div>
      <div class="cf-drawer" data-filter-drawer aria-label="Filters" role="dialog" aria-modal="true">
        <div class="cf-drawer__header">
          <span class="cf-drawer__title">Filters</span>
          <button type="button" class="cf-drawer__close" data-filter-drawer-close aria-label="Close filters">
            <svg width="20" height="20" viewBox="0 0 20 20"><line x1="4" y1="4" x2="16" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="16" y1="4" x2="4" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </button>
        </div>
        <div class="cf-drawer__body" data-filter-drawer-body></div>
        <div class="cf-drawer__footer">
          <button type="button" class="cf-filters__apply" data-filter-drawer-apply>
            Apply Filters
          </button>
        </div>
      </div>
    {%- endif -%}
  </section>
{%- endif -%}

<style>
  #{{ section_id }} {
    padding-top: {{ section.settings.padding_top | default: 24 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 24 }}px;
  }
  #{{ section_id }} .collection-grid-simple__container {
    max-width: 1750px;
    margin: 0 auto;
    padding: 0 32px;
  }
  #{{ section_id }} .collection-grid-simple__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 20px;
  }
  .cf-layout:not(.cf-layout--no-filters) .collection-grid-simple__grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  #{{ section_id }} .collection-grid-simple__item {
    width: 100%;
    display: block;
  }
  #{{ section_id }} .product-card-simple__card {
    display: flex;
    flex-direction: column;
    border: 1px solid #e5e5e5;
    background: #ffffff;
    border-radius: 10px;
    height: 100%;
  }
  #{{ section_id }} .product-card-simple__link {
    display: block;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }
  #{{ section_id }} .product-card-simple__image {
    position: relative;
    background: #f2f2f2;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    flex-shrink: 0;
  }
  #{{ section_id }} .product-card-simple__discount-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    padding: 6px 12px;
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    background: #eb701f;
    border-radius: 999px;
    line-height: 1;
    z-index: 1;
  }
  #{{ section_id }} .product-card-simple__image img,
  #{{ section_id }} .product-card-simple__image svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  #{{ section_id }} .product-card-simple__content {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
    min-height: 0;
  }
  #{{ section_id }} .product-card-simple__title {
    font-size: 16px!important;
    line-height: 1.3!important;
    margin: 0!important;
    font-weight: 700!important;
  }
  #{{ section_id }} .product-card-simple__title a {
    color: inherit;
    text-decoration: none;
  }
  #{{ section_id }} .product-card-simple__title a:hover {
    text-decoration: underline;
  }
  #{{ section_id }} .product-card-simple__form {
    margin-top: auto;
    padding-top: 8px;
  }
  #{{ section_id }} .product-card-simple__atc {
    width: 100%;
    padding: 10px 16px;
    font-size: 14px;
    font-weight: 600;
    color: #fff;
    background: #eb701f;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  #{{ section_id }} .product-card-simple__atc:hover:not(:disabled) {
    opacity: 0.9;
  }
  #{{ section_id }} .product-card-simple__atc--disabled,
  #{{ section_id }} .product-card-simple__atc:disabled {
    background: #ccc;
    cursor: not-allowed;
  }
  #{{ section_id }} .product-card-simple__price {
    display: flex;
    align-items: baseline;
    gap: 8px;
    line-height: 1!important;
  }
  #{{ section_id }} .product-card-simple__price-current {
    color: #eb701f;
    font-weight: 600;
    line-height: 1!important;
  }
  #{{ section_id }} .product-card-simple__price-compare {
    color: #555555;
    text-decoration: line-through;
    font-size: 0.9em;
  }
  #{{ section_id }} .product-card-simple__rating {
    display: flex!important;
    align-items: center!important;
    gap: 6px!important;
    font-size: 16px!important;
    color: #000000!important;
    line-height: 1!important;
  }
  #{{ section_id }} .product-card-simple__stars {
    display: inline-flex;
    gap: 2px;
    line-height: 1;
  }
  #{{ section_id }} .product-card-simple__star {
    font-size: 20px!important;
    line-height: 1;
    color: #b5b5b5;
  }
  #{{ section_id }} .product-card-simple__star--active {
    color: #000000;
  }
  #{{ section_id }} .product-card-simple__variants {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    padding: 10px 16px 0;
  }
  #{{ section_id }} .product-card-simple__variant-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid #e5e5e5;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    background: #f2f2f2;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  #{{ section_id }} .product-card-simple__variant-btn:hover {
    border-color: #ccc;
  }
  #{{ section_id }} .product-card-simple__variant-btn--selected {
    border-color: #000;
    box-shadow: 0 0 0 1px #000;
  }
  #{{ section_id }} .product-card-simple__variant-btn-inner {
    display: block;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  #{{ section_id }} .product-card-simple__variant-btn-inner--placeholder {
    background-color: #e5e5e5;
  }
  @media (max-width: 990px) {
    .cf-layout:not(.cf-layout--no-filters) .collection-grid-simple__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
  @media (max-width: 749px) {
    #{{ section_id }} .collection-grid-simple__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    #{{ section_id }} .collection-grid-simple__container {
      padding: 0 16px;
    }
    #{{ section_id }} .product-card-simple__atc {
      width: 100%;
      padding: 8px;
      font-size: 12px!important;
      font-weight: 600!important;
    }
  }
  @media (max-width: 430px) {
    #{{ section_id }} .product-card-simple__stars {
      display: inline-flex;
      gap: 1px;
    }
    #{{ section_id }} .product-card-simple__star,
    #{{ section_id }} .product-card-simple__rating-value,
    #{{ section_id }} .product-card-simple__rating-count {
      font-size: 14px!important;
    }
    #{{ section_id }} .product-card-simple__title {
      font-size: 14px!important;
    }
  }
  @media (max-width: 340px) {
    #{{ section_id }} .product-card-simple__star,
    #{{ section_id }} .product-card-simple__rating-value,
    #{{ section_id }} .product-card-simple__rating-count {
      font-size: 12px!important;
    }
  }
  #{{ section_id }} .collection-grid-simple__pagination {
    margin-top: 32px;
  }
</style>

{% schema %}
{
  "name": "Collection Grid Simple",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Leave blank to show the current page's collection."
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 3,
      "max": 48,
      "step": 3,
      "default": 12,
      "info": "Com filtros/busca no tema, valores altos (ex.: 48) carregam mais itens numa página para o filtro JS ver toda a lista. A paginação só aparece quando há mais de uma página."
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show pagination",
      "default": true
    },
    {
      "type": "header",
      "content": "Filters & Search"
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Show filters sidebar",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_filter_color_swatch",
      "label": "Show color swatches",
      "default": true
    },
    {
      "type": "select",
      "id": "facet_groups_default",
      "label": "Filter groups default state",
      "default": "first_open",
      "options": [
        { "value": "all_open", "label": "All open" },
        { "value": "first_open", "label": "First open" },
        { "value": "all_closed", "label": "All closed" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search bar",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sort",
      "label": "Show sort dropdown",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "extra_product",
      "name": "Extra Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "select",
          "id": "variant_index",
          "label": "Variant",
          "default": "",
          "options": [
            { "value": "", "label": "First available" },
            { "value": "0", "label": "1st variant" },
            { "value": "1", "label": "2nd variant" },
            { "value": "2", "label": "3rd variant" },
            { "value": "3", "label": "4th variant" },
            { "value": "4", "label": "5th variant" },
            { "value": "5", "label": "6th variant" },
            { "value": "6", "label": "7th variant" },
            { "value": "7", "label": "8th variant" },
            { "value": "8", "label": "9th variant" },
            { "value": "9", "label": "10th variant" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Grid Simple"
    }
  ]
}
{% endschema %}
