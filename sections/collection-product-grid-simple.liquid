{%- liquid
  assign section_id = 'CollectionGridSimple-' | append: section.id
  assign collection_to_show = section.settings.collection | default: collection

  assign use_contextual_collection = false
  if template.name == 'collection' and collection != blank
    if section.settings.collection == blank
      assign use_contextual_collection = true
    elsif section.settings.collection.handle == collection.handle
      assign use_contextual_collection = true
    endif
  endif

  if use_contextual_collection
    assign product_collection = collection
  else
    assign product_collection = collection_to_show
  endif

  assign has_facets = false
  if section.settings.show_filters and template.name == 'collection' and use_contextual_collection and product_collection.filters != empty
    assign has_facets = true
  endif

  assign form_id = 'cgs-facets-form-' | append: section.id
  assign sort_by = product_collection.sort_by | default: product_collection.default_sort_by

  assign active_filters_count = 0
  for filter in product_collection.filters
    if filter.type == 'list'
      assign active_filters_count = active_filters_count | plus: filter.active_values.size
    elsif filter.type == 'price_range' and filter.min_value.value or filter.max_value.value
      assign active_filters_count = active_filters_count | plus: 1
    elsif filter.type == 'boolean' and filter.true_value.active
      assign active_filters_count = active_filters_count | plus: 1
    endif
  endfor

  assign extra_products = section.blocks | where: 'type', 'extra_product'
  assign has_collection = false
  if product_collection != blank and product_collection.products_count > 0
    assign has_collection = true
  endif
  assign has_extras = false
  if extra_products.size > 0
    assign has_extras = true
  endif
-%}

{%- if has_facets -%}
  {{ 'collection-facets-simple.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- if has_collection or has_extras -%}
  <section
    id="{{ section_id }}"
    class="collection-grid-simple{% if has_facets %} collection-grid-simple--facets{% endif %}"
  >
    {%- if has_collection -%}
      {%- paginate product_collection.products by section.settings.products_per_page -%}
        {%- if has_facets -%}
          <div class="collection-grid-simple__shell">
            <aside
              class="collection-grid-simple__facets"
              data-cgs-facets-root
              aria-hidden="true"
              id="{{ section_id }}-facets-aside"
            >
              <button
                type="button"
                class="cgs-facets-backdrop"
                data-cgs-facets-close
                aria-label="{{ 'general.accessibility.close' | t | escape }}"
              ></button>
              <div class="collection-grid-simple__facets-panel">
                <div class="cgs-facets-mobile-head">
                  <h2 class="cgs-facets-mobile-head__title" id="{{ section_id }}-facets-heading">
                    {{ 'collection.filter.title' | t }}
                  </h2>
                  <button
                    type="button"
                    class="cgs-facets-mobile-head__close"
                    data-cgs-facets-close
                    aria-label="{{ 'general.accessibility.close' | t | escape }}"
                  >
                    ×
                  </button>
                </div>
                {% render 'collection-facets-simple',
                  product_collection: product_collection,
                  form_id: form_id,
                  sort_by: sort_by,
                  show_swatches: section.settings.show_filter_color_swatch,
                  groups_mode: section.settings.facet_groups_default,
                  template_suffix: template.suffix,
                  section_id: section_id
                %}
              </div>
            </aside>

            <div class="collection-grid-simple__main">
              <div class="cgs-toolbar">
                <button
                  type="button"
                  class="cgs-toolbar__filter"
                  data-cgs-facets-open
                  aria-expanded="false"
                  aria-controls="{{ section_id }}-facets-aside"
                >
                  {{ 'collection.filter.show_filter' | t }}
                  {%- if active_filters_count > 0 -%}
                    <span class="cgs-toolbar__filter-badge">{{ active_filters_count }}</span>
                  {%- endif -%}
                </button>
                <p class="cgs-toolbar__meta">
                  {{ 'collection.general.results_count' | t: count: paginate.items }}
                </p>
                <div class="cgs-toolbar__sort">
                  <label class="cgs-toolbar__sort-label" for="cgs-sort-{{ section_id }}">{{ 'collection.sorting.title' | t }}</label>
                  <select
                    id="cgs-sort-{{ section_id }}"
                    class="cgs-toolbar__sort-select"
                    name="sort_by"
                    form="{{ form_id }}"
                    data-cgs-sort-select
                  >
                    {%- for option in product_collection.sort_options -%}
                      <option value="{{ option.value | escape }}" {% if option.value == sort_by %}selected{% endif %}>
                        {{ option.name }}
                      </option>
                    {%- endfor -%}
                  </select>
                </div>
              </div>

              <div class="collection-grid-simple__grid">
                {%- for product in product_collection.products -%}
                  <div class="collection-grid-simple__item">
                    {%- render 'product-card-simple', product: product -%}
                  </div>
                {%- endfor -%}

                {%- if paginate.items == 0 -%}
                  <p class="cgs-empty" role="status">{{ 'collection.general.no_results' | t }}</p>
                {%- endif -%}

                {%- if has_extras and paginate.pages <= 1 or paginate.current_page == paginate.pages -%}
                  {%- for block in extra_products -%}
                    {%- if block.settings.product != blank -%}
                      {%- assign extra_variant = nil -%}
                      {%- if block.settings.variant_index != blank -%}
                        {%- assign idx = block.settings.variant_index | plus: 0 -%}
                        {%- assign extra_variant = block.settings.product.variants[idx] -%}
                      {%- endif -%}
                      <div class="collection-grid-simple__item" {{ block.shopify_attributes }}>
                        {%- render 'product-card-simple', product: block.settings.product, variant: extra_variant -%}
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
              </div>

              {%- if section.settings.show_pagination and paginate.pages > 1 -%}
                <div class="collection-grid-simple__pagination">
                  {%- render 'pagination', paginate: paginate -%}
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- else -%}
          <div class="collection-grid-simple__container">
            <div class="collection-grid-simple__grid">
              {%- for product in product_collection.products -%}
                <div class="collection-grid-simple__item">
                  {%- render 'product-card-simple', product: product -%}
                </div>
              {%- endfor -%}

              {%- if has_extras and paginate.pages <= 1 or paginate.current_page == paginate.pages -%}
                {%- for block in extra_products -%}
                  {%- if block.settings.product != blank -%}
                    {%- assign extra_variant = nil -%}
                    {%- if block.settings.variant_index != blank -%}
                      {%- assign idx = block.settings.variant_index | plus: 0 -%}
                      {%- assign extra_variant = block.settings.product.variants[idx] -%}
                    {%- endif -%}
                    <div class="collection-grid-simple__item" {{ block.shopify_attributes }}>
                      {%- render 'product-card-simple', product: block.settings.product, variant: extra_variant -%}
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            </div>
          </div>

          {%- if section.settings.show_pagination and paginate.pages > 1 -%}
            <div class="collection-grid-simple__pagination">
              {%- render 'pagination', paginate: paginate -%}
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endpaginate -%}
    {%- else -%}
      <div class="collection-grid-simple__container">
        <div class="collection-grid-simple__grid">
          {%- for block in extra_products -%}
            {%- if block.settings.product != blank -%}
              {%- assign extra_variant = nil -%}
              {%- if block.settings.variant_index != blank -%}
                {%- assign idx = block.settings.variant_index | plus: 0 -%}
                {%- assign extra_variant = block.settings.product.variants[idx] -%}
              {%- endif -%}
              <div class="collection-grid-simple__item" {{ block.shopify_attributes }}>
                {%- render 'product-card-simple', product: block.settings.product, variant: extra_variant -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </section>

  {%- if has_facets -%}
    <script src="{{ 'collection-facets-simple.js' | asset_url }}" defer></script>
  {%- endif -%}
{%- endif -%}

<style>
  #{{ section_id }} {
    padding-top: {{ section.settings.padding_top | default: 24 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 24 }}px;
  }
  #{{ section_id }} .collection-grid-simple__container {
    max-width: 1750px;
    margin: 0 auto;
    padding: 0 32px;
  }
  #{{ section_id }} .collection-grid-simple__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 20px;
  }
  #{{ section_id }} .collection-grid-simple__item {
    width: 100%;
    display: block;
  }
  #{{ section_id }} .product-card-simple__card {
    display: flex;
    flex-direction: column;
    border: 1px solid #e5e5e5;
    background: #ffffff;
    border-radius: 10px;
    height: 100%;
  }
  #{{ section_id }} .product-card-simple__link {
    display: block;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }
  #{{ section_id }} .product-card-simple__image {
    position: relative;
    background: #f2f2f2;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    flex-shrink: 0;
  }
  #{{ section_id }} .product-card-simple__discount-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    padding: 6px 12px;
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    background: #eb701f;
    border-radius: 999px;
    line-height: 1;
    z-index: 1;
  }
  #{{ section_id }} .product-card-simple__image img,
  #{{ section_id }} .product-card-simple__image svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  #{{ section_id }} .product-card-simple__content {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
    min-height: 0;
  }
  #{{ section_id }} .product-card-simple__title {
    font-size: 16px!important;
    line-height: 1.3!important;
    margin: 0!important;
    font-weight: 700!important;
  }
  #{{ section_id }} .product-card-simple__title a {
    color: inherit;
    text-decoration: none;
  }
  #{{ section_id }} .product-card-simple__title a:hover {
    text-decoration: underline;
  }
  #{{ section_id }} .product-card-simple__form {
    margin-top: auto;
    padding-top: 8px;
  }
  #{{ section_id }} .product-card-simple__atc {
    width: 100%;
    padding: 10px 16px;
    font-size: 14px;
    font-weight: 600;
    color: #fff;
    background: #eb701f;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  #{{ section_id }} .product-card-simple__atc:hover:not(:disabled) {
    opacity: 0.9;
  }
  #{{ section_id }} .product-card-simple__atc--disabled,
  #{{ section_id }} .product-card-simple__atc:disabled {
    background: #ccc;
    cursor: not-allowed;
  }
  #{{ section_id }} .product-card-simple__price {
    display: flex;
    align-items: baseline;
    gap: 8px;
    line-height: 1!important;
  }
  #{{ section_id }} .product-card-simple__price-current {
    color: #eb701f;
    font-weight: 600;
    line-height: 1!important;
  }
  #{{ section_id }} .product-card-simple__price-compare {
    color: #555555;
    text-decoration: line-through;
    font-size: 0.9em;
  }
  #{{ section_id }} .product-card-simple__rating {
    display: flex!important;
    align-items: center!important;
    gap: 6px!important;
    font-size: 16px!important;
    color: #000000!important;
    line-height: 1!important;
  }
  #{{ section_id }} .product-card-simple__stars {
    display: inline-flex;
    gap: 2px;
    line-height: 1;
  }
  #{{ section_id }} .product-card-simple__star {
    font-size: 20px!important;
    line-height: 1;
    color: #b5b5b5;
  }
  #{{ section_id }} .product-card-simple__star--active {
    color: #000000;
  }

  #{{ section_id }} .product-card-simple__variants {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    padding: 10px 16px 0;
  }
  #{{ section_id }} .product-card-simple__variant-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid #e5e5e5;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    background: #f2f2f2;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  #{{ section_id }} .product-card-simple__variant-btn:hover {
    border-color: #ccc;
  }
  #{{ section_id }} .product-card-simple__variant-btn--selected {
    border-color: #000;
    box-shadow: 0 0 0 1px #000;
  }
  #{{ section_id }} .product-card-simple__variant-btn-inner {
    display: block;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  #{{ section_id }} .product-card-simple__variant-btn-inner--placeholder {
    background-color: #e5e5e5;
  }

  @media (max-width: 749px) {
    #{{ section_id }} .collection-grid-simple__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    #{{ section_id }} .product-card-simple__atc {
    width: 100%;
    padding: 8px;
    font-size: 12px!important;
    font-weight: 600!important;
    }
  }

   @media (max-width: 430px) {
     #{{ section_id }} .product-card-simple__stars {
    display: inline-flex;
    gap: 1px;
    line-height: 1;
  }
  #{{ section_id }} .product-card-simple__star, #{{ section_id }} .product-card-simple__rating-value, #{{ section_id }} .product-card-simple__rating-count {
    font-size: 14px!important;
  }
   #{{ section_id }} .product-card-simple__title {
    font-size: 14px!important;
    line-height: 1.3!important;
    }
  }

   @media (max-width: 340px) {
     #{{ section_id }} .product-card-simple__stars {
    display: inline-flex;
    gap: 1px;
    line-height: 1;
  }
  #{{ section_id }} .product-card-simple__star, #{{ section_id }} .product-card-simple__rating-value, #{{ section_id }} .product-card-simple__rating-count {
    font-size: 12px!important;
  }

  }
  @media (max-width: 320px) {
    #{{ section_id }} .product-card-simple__title {
      font-size: 14px!important;
    }
  }
</style>

{% comment %} Variant switcher for product-card-simple is in theme.liquid (product-card-simple.js) so it works in grid and in banner carousel/Swiper. {% endcomment %}

{% schema %}
{
  "name": "Collection Grid Simple",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Leave blank to show the current page's collection (e.g. on a collection page). Set to force a specific collection."
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Show collection filters",
      "default": true,
      "info": "Uses Shopify storefront filtering. Configure filters in Shopify Admin → Search & Discovery. Only applies when the section shows the same collection as the page URL."
    },
    {
      "type": "checkbox",
      "id": "show_filter_color_swatch",
      "label": "Color swatches for color filters",
      "default": true
    },
    {
      "type": "select",
      "id": "facet_groups_default",
      "label": "Filter groups default state",
      "default": "first_open",
      "options": [
        { "value": "first_open", "label": "First group open" },
        { "value": "all_open", "label": "All open" },
        { "value": "all_closed", "label": "All closed" }
      ]
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 3,
      "max": 48,
      "step": 3,
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show pagination",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "extra_product",
      "name": "Extra Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "Add a product card that appears alongside the collection products, without adding it to the collection."
        },
        {
          "type": "select",
          "id": "variant_index",
          "label": "Variant",
          "default": "",
          "info": "Which variant to show on the card. Order matches the product admin.",
          "options": [
            { "value": "", "label": "First available" },
            { "value": "0", "label": "1st variant" },
            { "value": "1", "label": "2nd variant" },
            { "value": "2", "label": "3rd variant" },
            { "value": "3", "label": "4th variant" },
            { "value": "4", "label": "5th variant" },
            { "value": "5", "label": "6th variant" },
            { "value": "6", "label": "7th variant" },
            { "value": "7", "label": "8th variant" },
            { "value": "8", "label": "9th variant" },
            { "value": "9", "label": "10th variant" },
            { "value": "10", "label": "11th variant" },
            { "value": "11", "label": "12th variant" },
            { "value": "12", "label": "13th variant" },
            { "value": "13", "label": "14th variant" },
            { "value": "14", "label": "15th variant" },
            { "value": "15", "label": "16th variant" },
            { "value": "16", "label": "17th variant" },
            { "value": "17", "label": "18th variant" },
            { "value": "18", "label": "19th variant" },
            { "value": "19", "label": "20th variant" },
            { "value": "20", "label": "21st variant" },
            { "value": "21", "label": "22nd variant" },
            { "value": "22", "label": "23rd variant" },
            { "value": "23", "label": "24th variant" },
            { "value": "24", "label": "25th variant" },
            { "value": "25", "label": "26th variant" },
            { "value": "26", "label": "27th variant" },
            { "value": "27", "label": "28th variant" },
            { "value": "28", "label": "29th variant" },
            { "value": "29", "label": "30th variant" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Grid Simple"
    }
  ]
}
{% endschema %}
