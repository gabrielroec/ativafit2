{%- liquid
  assign sid = 'brand-credentials-' | append: section.id

  comment
    Backward compat:
    Se `number_X` estiver em branco, tenta derivar de `line_X` fazendo split no primeiro espaço.
    - "30+ Years Experience" -> number "30+", label "Years Experience"
    Se o label_X novo estiver em branco, também tenta pegar o resto do line_X.
  endcomment

  assign num_1 = section.settings.number_1 | strip
  assign lbl_1 = section.settings.label_1 | strip
  if num_1 == blank and section.settings.line_1 != blank
    assign line_1_clean = section.settings.line_1 | strip
    assign parts_1 = line_1_clean | split: ' '
    assign num_1 = parts_1 | first
    if lbl_1 == blank
      assign prefix_1 = num_1 | append: ' '
      assign lbl_1 = line_1_clean | remove_first: prefix_1
    endif
  endif

  assign num_2 = section.settings.number_2 | strip
  assign lbl_2 = section.settings.label_2 | strip
  if num_2 == blank and section.settings.line_2 != blank
    assign line_2_clean = section.settings.line_2 | strip
    assign parts_2 = line_2_clean | split: ' '
    assign num_2 = parts_2 | first
    if lbl_2 == blank
      assign prefix_2 = num_2 | append: ' '
      assign lbl_2 = line_2_clean | remove_first: prefix_2
    endif
  endif

  assign num_3 = section.settings.number_3 | strip
  assign lbl_3 = section.settings.label_3 | strip
  if num_3 == blank and section.settings.line_3 != blank
    assign line_3_clean = section.settings.line_3 | strip
    assign parts_3 = line_3_clean | split: ' '
    assign num_3 = parts_3 | first
    if lbl_3 == blank
      assign prefix_3 = num_3 | append: ' '
      assign lbl_3 = line_3_clean | remove_first: prefix_3
    endif
  endif
-%}

<section
  id="{{ sid }}"
  class="brand-credentials-bar"
  data-section-type="brand-credentials-bar">
  <div class="brand-credentials-bar__container">
    <div class="brand-credentials-bar__row">
      {%- if num_1 != blank or lbl_1 != blank -%}
        <div class="brand-credentials-bar__item">
          {%- if num_1 != blank -%}
            <span class="brand-credentials-bar__number">{{ num_1 | escape }}</span>
          {%- endif -%}
          {%- if lbl_1 != blank -%}
            <span class="brand-credentials-bar__label">{{ lbl_1 | escape }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
      {%- if num_2 != blank or lbl_2 != blank -%}
        <div class="brand-credentials-bar__item">
          {%- if num_2 != blank -%}
            <span class="brand-credentials-bar__number">{{ num_2 | escape }}</span>
          {%- endif -%}
          {%- if lbl_2 != blank -%}
            <span class="brand-credentials-bar__label">{{ lbl_2 | escape }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
      {%- if num_3 != blank or lbl_3 != blank -%}
        <div class="brand-credentials-bar__item">
          {%- if num_3 != blank -%}
            <span class="brand-credentials-bar__number">{{ num_3 | escape }}</span>
          {%- endif -%}
          {%- if lbl_3 != blank -%}
            <span class="brand-credentials-bar__label">{{ lbl_3 | escape }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #{{ sid }}.brand-credentials-bar {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_y }}px !important;
    padding-bottom: {{ section.settings.padding_y }}px !important;
  }

  #{{ sid }} .brand-credentials-bar__container {
    max-width: 80rem;
    margin-left: auto;
    margin-right: auto;
    padding-left: 24px;
    padding-right: 24px;
  }

  #{{ sid }} .brand-credentials-bar__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem 1rem;
    align-items: start;
    justify-items: center;
    text-align: center;
  }

  @media screen and (min-width: 600px) {
    #{{ sid }} .brand-credentials-bar__row {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem 2rem;
    }
  }

  #{{ sid }} .brand-credentials-bar__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ section.settings.gap_number_label }}px;
    min-width: 0;
  }

  #{{ sid }} .brand-credentials-bar__number {
    color: {{ section.settings.number_color }} !important;
    font-family: "Barlow", sans-serif !important;
    font-size: {{ section.settings.number_size_mobile }}px !important;
    line-height: 1 !important;
    font-weight: 600 !important;
    font-style: normal !important;
    letter-spacing: -0.02em !important;
    white-space: nowrap;
  }

  #{{ sid }} .brand-credentials-bar__label {
    color: {{ section.settings.label_color }} !important;
    font-family: "Barlow", sans-serif !important;
    font-size: {{ section.settings.label_size_mobile }}px !important;
    line-height: 1.3 !important;
    font-weight: 500 !important;
    font-style: normal !important;
    letter-spacing: 0 !important;
    text-transform: none !important;
  }

  @media screen and (min-width: 768px) {
    #{{ sid }} .brand-credentials-bar__number {
      font-size: {{ section.settings.number_size_desktop }}px !important;
    }
    #{{ sid }} .brand-credentials-bar__label {
      font-size: {{ section.settings.label_size_desktop }}px !important;
    }
  }
</style>

{% schema %}
{
