      "id": "number_1",
      "label": "Number",
      "default": "30+"
    },
    {
      "type": "text",
      "id": "label_1",
      "label": "Label",
      "default": "years experience"
    },
    {
      "type": "header",
      "content": "Stat 2"
    },
    {
      "type": "text",
      "id": "number_2",
      "label": "Number",
      "default": "30+"
    },
    {
      "type": "text",
      "id": "label_2",
      "label": "Label",
      "default": "patents"
    },
    {
      "type": "header",
      "content": "Stat 3"
    },
    {
      "type": "text",
      "id": "number_3",
      "label": "Number",
      "default": "2,000+"
    },
    {
      "type": "text",
      "id": "label_3",
      "label": "Label",
      "default": "verified reviews"
    },
    {
      "type": "header",
