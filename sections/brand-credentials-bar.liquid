{%- liquid
  assign sid = 'brand-credentials-' | append: section.id
-%}

<section
  id="{{ sid }}"
  class="brand-credentials-bar"
  data-section-type="brand-credentials-bar">
  <div class="brand-credentials-bar__container">
    <div class="brand-credentials-bar__row">
      {%- if section.settings.line_1 != blank -%}
        <span class="brand-credentials-bar__text">{{ section.settings.line_1 | escape }}</span>
      {%- endif -%}
      {%- if section.settings.line_1 != blank and section.settings.line_2 != blank -%}
        <span class="brand-credentials-bar__divider" aria-hidden="true">|</span>
      {%- endif -%}
      {%- if section.settings.line_2 != blank -%}
        <span class="brand-credentials-bar__text">{{ section.settings.line_2 | escape }}</span>
      {%- endif -%}
      {%- if section.settings.line_2 != blank and section.settings.line_3 != blank -%}
        <span class="brand-credentials-bar__divider" aria-hidden="true">|</span>
      {%- endif -%}
      {%- if section.settings.line_3 != blank -%}
        <span class="brand-credentials-bar__text">{{ section.settings.line_3 | escape }}</span>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #{{ sid }}.brand-credentials-bar {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_y }}px !important;
    padding-bottom: {{ section.settings.padding_y }}px !important;
    border-top: 1px solid {{ section.settings.border_base | color_modify: 'alpha', 0.1 }};
    border-bottom: 1px solid {{ section.settings.border_base | color_modify: 'alpha', 0.1 }};
  }

  #{{ sid }} .brand-credentials-bar__container {
    max-width: 80rem;
    margin-left: auto;
    margin-right: auto;
    padding-left: 24px;
    padding-right: 24px;
  }

  #{{ sid }} .brand-credentials-bar__row {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    text-align: center;
  }

  @media screen and (min-width: 768px) {
    #{{ sid }} .brand-credentials-bar__row {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }

  #{{ sid }} .brand-credentials-bar__text {
    color: {{ section.settings.text_color }} !important;
    font-family: var(--heading-font-family) !important;
    font-size: {{ section.settings.font_size }}px !important;
    line-height: 1.2 !important;
    font-weight: 900 !important;
    font-style: normal !important;
    text-transform: uppercase !important;
    letter-spacing: -0.04em !important;
  }

  #{{ sid }} .brand-credentials-bar__divider {
    color: {{ section.settings.text_color }} !important;
    font-family: var(--heading-font-family) !important;
    font-size: {{ section.settings.font_size }}px !important;
    line-height: 1.2 !important;
    font-weight: 900 !important;
    font-style: normal !important;
    display: none !important;
  }

  @media screen and (min-width: 768px) {
    #{{ sid }} .brand-credentials-bar__divider {
      display: inline !important;
    }
  }
</style>

{% schema %}
{
  "name": "Brand credentials bar",
  "tag": "section",
  "class": "section-brand-credentials-bar",
  "settings": [
    {
      "type": "text",
      "id": "line_1",
      "label": "Text 1",
      "default": "30+ Years Experience"
    },
    {
      "type": "text",
      "id": "line_2",
      "label": "Text 2",
      "default": "30+ Patents"
    },
    {
      "type": "text",
      "id": "line_3",
      "label": "Text 3",
      "default": "Awards-Winner Design"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 11,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 14
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#eeeeee"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text and dividers",
      "default": "#eb701f"
    },
    {
      "type": "color",
      "id": "border_base",
      "label": "Border color (10% opacity)",
      "default": "#dfc0b2",
      "info": "Outline variant from design system; borders use 10% opacity."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_y",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Vertical padding",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Brand credentials bar",
      "category": "Trust & social proof"
    }
  ]
}
{% endschema %}
