{%- comment -%} Async CSS — banner is mid-page, no need to block render. {%- endcomment -%}
<link rel="preload" as="style" href="{{ 'banner-product-showcase.css' | asset_url }}" onload="this.onload=null;this.rel='stylesheet'">
<noscript><link rel="stylesheet" href="{{ 'banner-product-showcase.css' | asset_url }}"></noscript>
{%- comment -%}
  Swiper CSS/JS — carregado on-demand pela section quando entra no viewport
  (ver IntersectionObserver no <script> abaixo). Evita 158KB pré-FCP na home.
{%- endcomment -%}
<link rel="prefetch" as="script" href="{{ 'swiper.min.js' | asset_url }}">
<link rel="prefetch" as="style" href="{{ 'swiper.min.css' | asset_url }}">
<noscript><link rel="stylesheet" href="{{ 'swiper.min.css' | asset_url }}"></noscript>
{%- liquid
  assign mobile_layout = section.settings.mobile_layout | default: 'carousel'
  assign desktop_layout = section.settings.desktop_layout | default: 'carousel'
  assign bps_title_fs = section.settings.title_font_size | default: 30
  assign bps_title_fs_mobile = section.settings.title_font_size_mobile | default: 36
-%}


<div
  class="banner-product-showcase banner-product-showcase--mobile-{{ mobile_layout }} banner-product-showcase--desktop-{{ desktop_layout }}"
  id="banner-showcase-{{ section.id }}"
  data-banner-showcase-mobile="{{ mobile_layout }}"
  data-banner-showcase-desktop="{{ desktop_layout }}"
  style="--bps-title-fs: {{ bps_title_fs }}px; --bps-title-fs-mobile: {{ bps_title_fs_mobile }}px;">
  <div class="banner-product-showcase__header">
    {% if section.settings.title != blank %}
      <h2 class="banner-product-showcase__title">{{ section.settings.title }}</h2>
    {% endif %}
    {% if section.settings.button_link != blank and section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link }}" class="banner-product-showcase__button condensed-bold">{{ section.settings.button_text }}</a>
    {% endif %}
  </div>

  <div class="banner-product-showcase__grid">
    <div class="banner-product-showcase__products-area">
      {%- liquid
        assign has_products = false
        for block in section.blocks
          if block.type == 'product' and block.settings.product != blank
            assign has_products = true
          endif
        endfor
      -%}
      {%- if mobile_layout == 'grid' -%}
        <div class="banner-product-showcase__mobile-grid">
          {% for block in section.blocks %}
            {% if block.type == 'product' and block.settings.product != blank %}
              {% assign product = all_products[block.settings.product] %}
              <div class="banner-product-showcase__mobile-grid-cell">
                {% render 'product-card-simple', product: product, show_reviews: section.settings.show_product_card_reviews %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {%- endif -%}

      {%- if desktop_layout == 'grid' -%}
        <div class="banner-product-showcase__desktop-grid">
          {% for block in section.blocks %}
            {% if block.type == 'product' and block.settings.product != blank %}
              {% assign product = all_products[block.settings.product] %}
              <div class="banner-product-showcase__desktop-grid-cell">
                {% render 'product-card-simple', product: product, show_reviews: section.settings.show_product_card_reviews %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {%- endif -%}

      <div class="banner-product-showcase__swiper-shell">
        <div class="banner-product-showcase__carousel-container">
          <div id="carousel-{{ section.id }}" class="banner-product-showcase__carousel swiper">
            <div class="swiper-wrapper">
              {% for block in section.blocks %}
                {% if block.type == 'product' and block.settings.product != blank %}
                  {% assign product = all_products[block.settings.product] %}
                  <div class="swiper-slide">
                    {% render 'product-card-simple', product: product, show_reviews: section.settings.show_product_card_reviews %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
          <div class="banner-product-showcase__pagination" id="carousel-pagination-{{ section.id }}"></div>
        </div>
      </div>
      {% unless has_products %}
        <p style="margin-top:10px;color:#888;">No products added to this section yet.</p>
      {% endunless %}
    </div>
  </div>
</div>

<script>
  (function () {
    var sectionId = '{{ section.id }}';
    var mobileLayout = {{ mobile_layout | json }};
    var desktopLayout = {{ desktop_layout | json }};
    var root = document.getElementById('banner-showcase-' + sectionId);
    var el = document.querySelector('#carousel-' + sectionId);
    var paginationEl = document.querySelector('#carousel-pagination-' + sectionId);
    var swiperInstance = null;
    var mq = window.matchMedia('(min-width: 768px)');

    function shouldUseSwiper() {
      if (mq.matches) {
        return desktopLayout === 'carousel';
      }
      return mobileLayout === 'carousel';
    }

    function destroySwiper() {
      if (swiperInstance && typeof swiperInstance.destroy === 'function') {
        try {
          swiperInstance.destroy(true, true);
        } catch (e) {}
        swiperInstance = null;
      }
    }

    function initSwiper() {
      if (!el || typeof Swiper === 'undefined') return;
      if (!shouldUseSwiper()) {
        destroySwiper();
        return;
      }
      if (swiperInstance) {
        swiperInstance.update();
        return;
      }
      swiperInstance = new Swiper(el, {
        slidesPerView: 2,
        spaceBetween: 20,
        centeredSlides: false,
        loop: false,
        pagination: {
          el: paginationEl,
          clickable: true,
          dynamicBullets: true
        },
        breakpoints: {
          320: { slidesPerView: 2, spaceBetween: 10 },
          768: { slidesPerView: 3, spaceBetween: 15 },
          1024: { slidesPerView: 4, spaceBetween: 20 }
        }
      });
    }

    /* Swiper é carregado on-demand: na home o theme.liquid não inclui o
       script global, e o prefetch do <link> acima aquece o cache. Quando a
       section chega perto do viewport, injetamos o <script>/<link> e só aí
       inicializamos o carrossel. */
    var swiperLoading = false;
    function ensureSwiperLoaded(cb) {
      if (typeof Swiper !== 'undefined') { cb(); return; }
      if (swiperLoading) {
        var iv = setInterval(function(){
          if (typeof Swiper !== 'undefined') { clearInterval(iv); cb(); }
        }, 50);
        setTimeout(function(){ clearInterval(iv); }, 8000);
        return;
      }
      swiperLoading = true;
      if (!document.querySelector('link[data-swiper-css]')) {
        var l = document.createElement('link');
        l.rel = 'stylesheet';
        l.href = {{ 'swiper.min.css' | asset_url | json }};
        l.setAttribute('data-swiper-css','1');
        document.head.appendChild(l);
      }
      var s = document.createElement('script');
      s.src = {{ 'swiper.min.js' | asset_url | json }};
      s.defer = true;
      s.onload = cb;
      document.head.appendChild(s);
    }

    function onReady() {
      ensureSwiperLoaded(initSwiper);
    }

    /* Defer init until the carousel is near the viewport. Saves the Swiper
       constructor cost on the first paint when the section is below the fold. */
    function scheduleInit() {
      if (!root || !('IntersectionObserver' in window)) {
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', onReady);
        } else {
          onReady();
        }
        return;
      }
      var io = new IntersectionObserver(function (entries, obs) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { onReady(); obs.disconnect(); }
        });
      }, { rootMargin: '400px 0px' });
      io.observe(root);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', scheduleInit);
    } else {
      scheduleInit();
    }

    mq.addEventListener('change', function () { ensureSwiperLoaded(initSwiper); });

    document.addEventListener('shopify:section:load', function (event) {
      if (!root || !event.target.contains(root)) return;
      destroySwiper();
      setTimeout(function () { ensureSwiperLoaded(initSwiper); }, 0);
    });
  })();
</script>

{% schema %}
  {
    "name": "Banner + Carousel",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Title",
        "default": "TRENDING"
      },
      {
        "type": "range",
        "id": "title_font_size",
        "label": "Title Font Size – Desktop",
        "min": 20,
        "max": 96,
        "step": 1,
        "unit": "px",
        "default": 40
      },
      {
        "type": "range",
        "id": "title_font_size_mobile",
        "label": "Title Font Size – Mobile",
        "min": 16,
        "max": 64,
        "step": 1,
        "unit": "px",
        "default": 36
      },
      {
        "type": "select",
        "id": "mobile_layout",
        "label": "Mobile layout",
        "options": [
          {
            "value": "carousel",
            "label": "Carousel (Swiper)"
          },
          {
            "value": "grid",
            "label": "Grid (2 per row)"
          }
        ],
        "default": "carousel",
        "info": "Applies to screens &lt;768px. Pair with “Desktop layout” below."
      },
      {
        "type": "select",
        "id": "desktop_layout",
        "label": "Desktop layout",
        "options": [
          {
            "value": "carousel",
            "label": "Carousel (Swiper)"
          },
          {
            "value": "grid",
            "label": "Grid (4 per row)"
          }
        ],
        "default": "carousel",
        "info": "Grid: 4 products per row without Swiper. Carousel: same as previous desktop behavior."
      },
      {
        "type": "text",
        "id": "button_text",
        "label": "Button Text",
        "default": "SHOP ALL TREND"
      }, {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      },
      {
        "type": "header",
        "content": "Product cards"
      },
      {
        "type": "checkbox",
        "id": "show_product_card_reviews",
        "label": "Show ratings (stars) on cards",
        "default": false,
        "info": "Off by default. Variants appear below the title to align names across cards."
      }
    ],
    "blocks": [
      {
        "type": "product",
        "name": "Product",
        "settings": [
          {
            "type": "product",
            "id": "product",
            "label": "Select Product"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Banner + Carousel",
        "settings": {},
        "blocks": [
          {
            "type": "product"
          }, {
            "type": "product"
          }, {
            "type": "product"
          }, {
            "type": "product"
          }
        ]
      }
    ]
  }
{% endschema %}
