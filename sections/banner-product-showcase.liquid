{%- liquid
  assign mobile_layout = section.settings.mobile_layout | default: 'carousel'
  assign desktop_layout = section.settings.desktop_layout | default: 'carousel'
-%}
{%- style -%}
  .banner-product-showcase {
    padding: 0 20px;
    width: 100%;
    max-width: 1750px;
    margin: 70px auto 0;
  }

  .banner-product-showcase__grid {
    display: flex;
    gap: 10px;
  }

  .banner-product-showcase__products-area {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    justify-content: center;
  }

  .banner-product-showcase__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }

  /* Title size is adjustable via schema */
  .banner-product-showcase__title {
    font-family: "Barlow", "Barlow Fallback", sans-serif !important;
    font-size: {{ section.settings.title_font_size | default: 30 }}
    px !important;
    font-weight: 900;
    line-height: 100%;
    margin: 0;
  }

  .banner-product-showcase__button {
    display: inline-block;
    color: #EB701F;
    text-decoration: underline;
    font-weight: 700;
    font-size: 16px;
    transition: color 0.3s ease;
  }
  .banner-product-showcase__button:hover {
    color: #c23d12;
  }

  /* Carousel */
  .banner-product-showcase__carousel-container {
    position: relative;
    width: 100%;
    padding-bottom: 50px;
    /* room for dots */
  }
  .banner-product-showcase__carousel {
    width: 100%;
    overflow-x: hidden;
    overflow-y: visible;
  }
  .banner-product-showcase__carousel .swiper-wrapper {
    display: flex;
    align-items: stretch;
  }
  .banner-product-showcase__carousel .swiper-slide,
  .banner-product-showcase__mobile-grid-cell,
  .banner-product-showcase__desktop-grid-cell {
    height: auto;
    min-height: 420px;
    display: flex !important;
    align-items: stretch !important;
    box-sizing: border-box;
  }
  .banner-product-showcase__carousel .swiper-slide > *,
  .banner-product-showcase__mobile-grid-cell > *,
  .banner-product-showcase__desktop-grid-cell > * {
    width: 100%;
    flex: 1;
    min-width: 0;
  }
  .banner-product-showcase__carousel .swiper-slide .product-card-simple__card,
  .banner-product-showcase__mobile-grid-cell .product-card-simple__card,
  .banner-product-showcase__desktop-grid-cell .product-card-simple__card {
    width: 100%;
    height: 100%;
    min-height: 420px;
    display: flex;
    flex-direction: column;
    border: 1px solid #e5e5e5;
    background: #fff;
    border-radius: 10px;
  }
  .banner-product-showcase__carousel .product-card-simple__link, .banner-product-showcase__mobile-grid .product-card-simple__link, .banner-product-showcase__desktop-grid .product-card-simple__link {
    display: block;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }
  .banner-product-showcase__carousel .product-card-simple__image, .banner-product-showcase__mobile-grid .product-card-simple__image, .banner-product-showcase__desktop-grid .product-card-simple__image {
    position: relative;
    background: #f2f2f2;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    flex-shrink: 0;
  }
  .banner-product-showcase__carousel .product-card-simple__discount-badge, .banner-product-showcase__mobile-grid .product-card-simple__discount-badge, .banner-product-showcase__desktop-grid .product-card-simple__discount-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    padding: 6px 12px;
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    background: #eb701f;
    border-radius: 999px;
    line-height: 1;
    z-index: 1;
  }
  .banner-product-showcase__carousel .product-card-simple__image img, .banner-product-showcase__mobile-grid .product-card-simple__image img, .banner-product-showcase__desktop-grid .product-card-simple__image img,
  .banner-product-showcase__carousel .product-card-simple__image svg, .banner-product-showcase__mobile-grid .product-card-simple__image svg, .banner-product-showcase__desktop-grid .product-card-simple__image svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .banner-product-showcase__carousel .product-card-simple__content, .banner-product-showcase__mobile-grid .product-card-simple__content, .banner-product-showcase__desktop-grid .product-card-simple__content {
    padding: 12px 14px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
    min-height: 0;
    overflow: hidden;
  }
  .banner-product-showcase__carousel .product-card-simple__title, .banner-product-showcase__mobile-grid .product-card-simple__title, .banner-product-showcase__desktop-grid .product-card-simple__title {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .banner-product-showcase__carousel .product-card-simple__title a, .banner-product-showcase__mobile-grid .product-card-simple__title a, .banner-product-showcase__desktop-grid .product-card-simple__title a {
    color: inherit;
    text-decoration: none;
  }
  .banner-product-showcase__carousel .product-card-simple__title a:hover, .banner-product-showcase__mobile-grid .product-card-simple__title a:hover, .banner-product-showcase__desktop-grid .product-card-simple__title a:hover {
    color: #EB701F;
  }
  .banner-product-showcase__carousel .product-card-simple__price, .banner-product-showcase__mobile-grid .product-card-simple__price, .banner-product-showcase__desktop-grid .product-card-simple__price {
    font-size: 14px;
    font-weight: 700;
    flex-shrink: 0;
  }
  .banner-product-showcase__carousel .product-card-simple__price-compare, .banner-product-showcase__mobile-grid .product-card-simple__price-compare, .banner-product-showcase__desktop-grid .product-card-simple__price-compare {
    text-decoration: line-through;
    color: #888;
    margin-left: 6px;
  }
  .banner-product-showcase__carousel .product-card-simple__form, .banner-product-showcase__mobile-grid .product-card-simple__form, .banner-product-showcase__desktop-grid .product-card-simple__form {
    margin: auto 0 0;
    flex-shrink: 0;
  }
  .banner-product-showcase__carousel .product-card-simple__atc, .banner-product-showcase__mobile-grid .product-card-simple__atc, .banner-product-showcase__desktop-grid .product-card-simple__atc {
    width: 100%;
    padding: 10px 14px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    border: none;
    border-radius: 8px;
    background: #EB701F;
    color: #fff;
    cursor: pointer;
    transition: background 0.2s
    , opacity 0.2s;
  }
  .banner-product-showcase__carousel .product-card-simple__atc:hover:not(:disabled), .banner-product-showcase__mobile-grid .product-card-simple__atc:hover:not(:disabled), .banner-product-showcase__desktop-grid .product-card-simple__atc:hover:not(:disabled) {
    background: #c23d12;
  }
  .banner-product-showcase__carousel .product-card-simple__atc:disabled, .banner-product-showcase__mobile-grid .product-card-simple__atc:disabled, .banner-product-showcase__desktop-grid .product-card-simple__atc:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .banner-product-showcase__carousel .product-card-simple__variants, .banner-product-showcase__mobile-grid .product-card-simple__variants, .banner-product-showcase__desktop-grid .product-card-simple__variants {
    flex-shrink: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0;
    margin: 0;
    justify-content: flex-start;
  }
  .banner-product-showcase__carousel .product-card-simple__rating, .banner-product-showcase__mobile-grid .product-card-simple__rating, .banner-product-showcase__desktop-grid .product-card-simple__rating {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
  }
  .banner-product-showcase__carousel .product-card-simple__variant-btn, .banner-product-showcase__mobile-grid .product-card-simple__variant-btn, .banner-product-showcase__desktop-grid .product-card-simple__variant-btn {
    width: 36px;
    height: 36px;
    padding: 0;
    border: 2px solid #e5e5e5;
    border-radius: 8px;
    background: #fff;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .banner-product-showcase__carousel .product-card-simple__variant-btn--selected, .banner-product-showcase__mobile-grid .product-card-simple__variant-btn--selected, .banner-product-showcase__desktop-grid .product-card-simple__variant-btn--selected,
  .banner-product-showcase__carousel .product-card-simple__variant-btn:hover, .banner-product-showcase__mobile-grid .product-card-simple__variant-btn:hover, .banner-product-showcase__desktop-grid .product-card-simple__variant-btn:hover {
    border-color: #EB701F;
  }
  .banner-product-showcase__carousel .product-card-simple__variant-btn-inner, .banner-product-showcase__mobile-grid .product-card-simple__variant-btn-inner, .banner-product-showcase__desktop-grid .product-card-simple__variant-btn-inner {
    display: block;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  .banner-product-showcase__carousel .product-card-simple__stars, .banner-product-showcase__mobile-grid .product-card-simple__stars, .banner-product-showcase__desktop-grid .product-card-simple__stars {
    color: #ddd;
  }
  .banner-product-showcase__carousel .product-card-simple__star--active, .banner-product-showcase__mobile-grid .product-card-simple__star--active, .banner-product-showcase__desktop-grid .product-card-simple__star--active {
    color: #EB701F;
  }

  /* Dots */
  .banner-product-showcase__pagination {
    position: absolute !important;
    bottom: 0 !important;
    left: 50% !important;
    transform: translateX(-50%) !important;
    width: auto !important;
    text-align: center;
    margin-top: 0;
  }
  .banner-product-showcase__pagination .swiper-pagination-bullet {
    width: 12px;
    height: 12px;
    background: #ccc;
    border-radius: 50%;
    margin: 0 5px;
    cursor: pointer;
    transition: background 0.3s ease;
    opacity: 1;
  }
  .banner-product-showcase__pagination .swiper-pagination-bullet-active {
    background: #EB701F;
  }

  /* Mobile: grelha 2 colunas (sem Swiper) vs carrossel — controlado por .banner-product-showcase--mobile-* */
  .banner-product-showcase__mobile-grid {
    display: none;
  }
  @media screen and (max-width: 767px) {
    .banner-product-showcase--mobile-grid .banner-product-showcase__mobile-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      width: 100%;
    }
    .banner-product-showcase--mobile-grid .banner-product-showcase__swiper-shell {
      display: none !important;
    }
  }
  @media screen and (min-width: 768px) {
    .banner-product-showcase__mobile-grid {
      display: none !important;
    }
  }

  /* Desktop: grelha 4 colunas (sem Swiper) vs carrossel */
  .banner-product-showcase__desktop-grid {
    display: none;
  }
  @media screen and (min-width: 768px) {
    .banner-product-showcase--desktop-grid .banner-product-showcase__desktop-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 20px;
      width: 100%;
    }
    .banner-product-showcase--desktop-grid .banner-product-showcase__swiper-shell {
      display: none !important;
    }
  }
  @media screen and (max-width: 767px) {
    .banner-product-showcase__desktop-grid {
      display: none !important;
    }
  }

  @media screen and (max-width: 768px) {
    .banner-product-showcase {
      padding: 0 10px;
    }
    .banner-product-showcase__grid {
      flex-direction: column;
    }
    .banner-product-showcase__products-area {
      width: 100%;
    }
    .banner-product-showcase__title {
      font-size: {{ section.settings.title_font_size_mobile | default: 36 }}
      px !important;
    }
  }

  .swiper-horizontal > .swiper-pagination-bullets.swiper-pagination-bullets-dynamic,
  .swiper-pagination-horizontal.swiper-pagination-bullets.swiper-pagination-bullets-dynamic {
    overflow: visible;
    transform: translateY(-25px) !important;
  }
{%- endstyle -%}

<div
  class="banner-product-showcase banner-product-showcase--mobile-{{ mobile_layout }} banner-product-showcase--desktop-{{ desktop_layout }}"
  id="banner-showcase-{{ section.id }}"
  data-banner-showcase-mobile="{{ mobile_layout }}"
  data-banner-showcase-desktop="{{ desktop_layout }}">
  <div class="banner-product-showcase__header">
    {% if section.settings.title != blank %}
      <h2 class="banner-product-showcase__title">{{ section.settings.title }}</h2>
    {% endif %}
    {% if section.settings.button_link != blank and section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link }}" class="banner-product-showcase__button condensed-bold">{{ section.settings.button_text }}</a>
    {% endif %}
  </div>

  <div class="banner-product-showcase__grid">
    <div class="banner-product-showcase__products-area">
      {%- liquid
        assign has_products = false
        for block in section.blocks
          if block.type == 'product' and block.settings.product != blank
            assign has_products = true
          endif
        endfor
      -%}
      {%- if mobile_layout == 'grid' -%}
        <div class="banner-product-showcase__mobile-grid">
          {% for block in section.blocks %}
            {% if block.type == 'product' and block.settings.product != blank %}
              {% assign product = all_products[block.settings.product] %}
              <div class="banner-product-showcase__mobile-grid-cell">
                {% render 'product-card-simple', product: product, show_reviews: section.settings.show_product_card_reviews %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {%- endif -%}

      {%- if desktop_layout == 'grid' -%}
        <div class="banner-product-showcase__desktop-grid">
          {% for block in section.blocks %}
            {% if block.type == 'product' and block.settings.product != blank %}
              {% assign product = all_products[block.settings.product] %}
              <div class="banner-product-showcase__desktop-grid-cell">
                {% render 'product-card-simple', product: product, show_reviews: section.settings.show_product_card_reviews %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {%- endif -%}

      <div class="banner-product-showcase__swiper-shell">
        <div class="banner-product-showcase__carousel-container">
          <div id="carousel-{{ section.id }}" class="banner-product-showcase__carousel swiper">
            <div class="swiper-wrapper">
              {% for block in section.blocks %}
                {% if block.type == 'product' and block.settings.product != blank %}
                  {% assign product = all_products[block.settings.product] %}
                  <div class="swiper-slide">
                    {% render 'product-card-simple', product: product, show_reviews: section.settings.show_product_card_reviews %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
          <div class="banner-product-showcase__pagination" id="carousel-pagination-{{ section.id }}"></div>
        </div>
      </div>
      {% unless has_products %}
        <p style="margin-top:10px;color:#888;">No products added to this section yet.</p>
      {% endunless %}
    </div>
  </div>
</div>

<script>
  (function () {
    var sectionId = '{{ section.id }}';
    var mobileLayout = {{ mobile_layout | json }};
    var desktopLayout = {{ desktop_layout | json }};
    var root = document.getElementById('banner-showcase-' + sectionId);
    var el = document.querySelector('#carousel-' + sectionId);
    var paginationEl = document.querySelector('#carousel-pagination-' + sectionId);
    var swiperInstance = null;
    var mq = window.matchMedia('(min-width: 768px)');

    function shouldUseSwiper() {
      if (mq.matches) {
        return desktopLayout === 'carousel';
      }
      return mobileLayout === 'carousel';
    }

    function destroySwiper() {
      if (swiperInstance && typeof swiperInstance.destroy === 'function') {
        try {
          swiperInstance.destroy(true, true);
        } catch (e) {}
        swiperInstance = null;
      }
    }

    function initSwiper() {
      if (!el || typeof Swiper === 'undefined') return;
      if (!shouldUseSwiper()) {
        destroySwiper();
        return;
      }
      if (swiperInstance) {
        swiperInstance.update();
        return;
      }
      swiperInstance = new Swiper(el, {
        slidesPerView: 2,
        spaceBetween: 20,
        centeredSlides: false,
        loop: false,
        pagination: {
          el: paginationEl,
          clickable: true,
          dynamicBullets: true
        },
        breakpoints: {
          320: { slidesPerView: 2, spaceBetween: 10 },
          768: { slidesPerView: 3, spaceBetween: 15 },
          1024: { slidesPerView: 4, spaceBetween: 20 }
        }
      });
    }

    function onReady() {
      initSwiper();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', onReady);
    } else {
      onReady();
    }

    mq.addEventListener('change', initSwiper);

    document.addEventListener('shopify:section:load', function (event) {
      if (!root || !event.target.contains(root)) return;
      destroySwiper();
      setTimeout(initSwiper, 0);
    });
  })();
</script>

{% schema %}
  {
    "name": "Banner + Carousel",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Title",
        "default": "TRENDING"
      },
      {
        "type": "range",
        "id": "title_font_size",
        "label": "Title Font Size – Desktop",
        "min": 20,
        "max": 96,
        "step": 1,
        "unit": "px",
        "default": 40
      },
      {
        "type": "range",
        "id": "title_font_size_mobile",
        "label": "Title Font Size – Mobile",
        "min": 16,
        "max": 64,
        "step": 1,
        "unit": "px",
        "default": 36
      },
      {
        "type": "select",
        "id": "mobile_layout",
        "label": "Mobile layout",
        "options": [
          {
            "value": "carousel",
            "label": "Carousel (Swiper)"
          },
          {
            "value": "grid",
            "label": "Grid (2 per row)"
          }
        ],
        "default": "carousel",
        "info": "Applies to screens &lt;768px. Pair with “Desktop layout” below."
      },
      {
        "type": "select",
        "id": "desktop_layout",
        "label": "Desktop layout",
        "options": [
          {
            "value": "carousel",
            "label": "Carousel (Swiper)"
          },
          {
            "value": "grid",
            "label": "Grid (4 per row)"
          }
        ],
        "default": "carousel",
        "info": "Grid: 4 products per row without Swiper. Carousel: same as previous desktop behavior."
      },
      {
        "type": "text",
        "id": "button_text",
        "label": "Button Text",
        "default": "SHOP ALL TREND"
      }, {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      },
      {
        "type": "header",
        "content": "Product cards"
      },
      {
        "type": "checkbox",
        "id": "show_product_card_reviews",
        "label": "Show ratings (stars) on cards",
        "default": false,
        "info": "Off by default. Variants appear below the title to align names across cards."
      }
    ],
    "blocks": [
      {
        "type": "product",
        "name": "Product",
        "settings": [
          {
            "type": "product",
            "id": "product",
            "label": "Select Product"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Banner + Carousel",
        "settings": {},
        "blocks": [
          {
            "type": "product"
          }, {
            "type": "product"
          }, {
            "type": "product"
          }, {
            "type": "product"
          }
        ]
      }
    ]
  }
{% endschema %}