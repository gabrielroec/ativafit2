{%- liquid
  assign hg_id = 'home-gyms-marquee-' | append: section.id
  assign hg_kf = section.id | split: '__' | last | handleize | default: 'home-gyms'
  assign hg_blocks_count = section.blocks.size
  assign hg_duration = section.settings.marquee_seconds | default: 45
  if hg_duration < 12
    assign hg_duration = 12
  endif
  assign hg_strip_cycles = section.settings.strip_cycles | default: 2
  if hg_strip_cycles < 1
    assign hg_strip_cycles = 1
  endif
  if hg_strip_cycles > 8
    assign hg_strip_cycles = 8
  endif
-%}

<section
  id="{{ hg_id }}"
  class="home-gyms-marquee"
  data-section-type="home-gyms-results-marquee">
  <div class="home-gyms-marquee__inner">
    <div class="home-gyms-marquee__intro">
      {%- if section.settings.title != blank -%}
        <h2 class="home-gyms-marquee__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="home-gyms-marquee__subtitle">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}
    </div>

    <div class="home-gyms-marquee__viewport">
      <div
        class="home-gyms-marquee__track"
        data-home-gyms-track
        style="--hg-duration: {{ hg_duration }}s;">
        <div class="home-gyms-marquee__strip" data-home-gyms-strip>
          {%- if hg_blocks_count > 0 -%}
            {%- for hg_rep in (1..hg_strip_cycles) -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'card' -%}
                  <div
                    class="home-gyms-marquee__cell"
                    {% if hg_rep == 1 %}
                      {{ block.shopify_attributes }}
                    {% endif %}>
                    {%- render 'home-gyms-marquee-card',
                      block: block,
                      section: section,
                      duplicate_strip: false,
                      hg_rep: hg_rep,
                      card_index: forloop.index0
                    -%}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            {%- endfor -%}
          {%- else -%}
            {%- for hg_rep in (1..hg_strip_cycles) -%}
              {%- for i in (1..4) -%}
                <div class="home-gyms-marquee__cell">
                  <div class="home-gyms-marquee__card home-gyms-marquee__card--placeholder" style="width: {{ section.settings.card_width }}px;">
                    <div class="home-gyms-marquee__card-frame">
                      <div class="home-gyms-marquee__ph"></div>
                      <div class="home-gyms-marquee__tag-wrap">
                        <span class="home-gyms-marquee__tag">{{ 'Community' | escape }}</span>
                      </div>
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            {%- endfor -%}
          {%- endif -%}
        </div>
        <div class="home-gyms-marquee__strip" aria-hidden="true">
          {%- if hg_blocks_count > 0 -%}
            {%- for hg_rep in (1..hg_strip_cycles) -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'card' -%}
                  <div class="home-gyms-marquee__cell">
                    {%- render 'home-gyms-marquee-card',
                      block: block,
                      section: section,
                      duplicate_strip: true,
                      hg_rep: hg_rep,
                      card_index: forloop.index0
                    -%}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            {%- endfor -%}
          {%- else -%}
            {%- for hg_rep in (1..hg_strip_cycles) -%}
              {%- for i in (1..4) -%}
                <div class="home-gyms-marquee__cell">
                  <div class="home-gyms-marquee__card home-gyms-marquee__card--placeholder" style="width: {{ section.settings.card_width }}px;">
                    <div class="home-gyms-marquee__card-frame">
                      <div class="home-gyms-marquee__ph"></div>
                      <div class="home-gyms-marquee__tag-wrap">
                        <span class="home-gyms-marquee__tag">{{ 'Community' | escape }}</span>
                      </div>
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('{{ hg_id }}');
    if (!root) return;
    var track = root.querySelector('[data-home-gyms-track]');
    var stripPrimary = root.querySelector('[data-home-gyms-strip]');
    if (!track || !stripPrimary) return;

    function motionReduced() {
      return window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    }

    function syncShift() {
      if (motionReduced()) {
        track.classList.remove('home-gyms-marquee__track--ready');
        root.style.removeProperty('--hg-shift');
        return;
      }
      var w = stripPrimary.getBoundingClientRect().width;
      if (!w) return;
      root.style.setProperty('--hg-shift', (-w).toFixed(2) + 'px');
      track.classList.add('home-gyms-marquee__track--ready');
    }

    function bindImageLoads() {
      root.querySelectorAll('[data-home-gyms-strip] img').forEach(function (img) {
        if (!img.complete) img.addEventListener('load', syncShift, { once: true });
      });
    }

    function initMarquee() {
      if (root._hgMarqueeInit) return;
      root._hgMarqueeInit = true;

      if (typeof ResizeObserver !== 'undefined') {
        new ResizeObserver(syncShift).observe(stripPrimary);
      }

      syncShift();
      requestAnimationFrame(syncShift);
      requestAnimationFrame(function () {
        requestAnimationFrame(syncShift);
      });

      window.addEventListener('load', syncShift);
      window.addEventListener('resize', function () {
        clearTimeout(root._hgMarqueeDebounce);
        root._hgMarqueeDebounce = setTimeout(syncShift, 100);
      });

      bindImageLoads();
      initGifPlay();
    }

    function initGifPlay() {
      root.addEventListener('click', function (e) {
        var btn = e.target.closest('.home-gyms-marquee__gif-play');
        if (!btn || !root.contains(btn)) return;
        e.preventDefault();
        e.stopPropagation();
        var wrap = btn.closest('[data-home-gyms-gif]');
        if (!wrap || wrap.getAttribute('data-hg-loading') === 'true' || wrap.getAttribute('data-hg-played') === 'true') return;
        var src = wrap.dataset.gifSrc || wrap.getAttribute('data-gif-src');
        if (!src) return;
        wrap.setAttribute('data-hg-loading', 'true');
        btn.disabled = true;
        var poster = wrap.querySelector('.home-gyms-marquee__gif-poster');
        var anim = document.createElement('img');
        anim.className = 'home-gyms-marquee__gif-anim home-gyms-marquee__card-img';
        anim.alt = wrap.getAttribute('data-gif-alt') || '';
        anim.decoding = 'async';
        anim.loading = 'eager';
        anim.setAttribute('fetchpriority', 'high');
        function finishPlay() {
          wrap.setAttribute('data-hg-played', 'true');
          wrap.removeAttribute('data-hg-loading');
          wrap.classList.add('home-gyms-marquee__gif--playing');
          if (poster) poster.style.display = 'none';
          if (btn.parentNode) btn.remove();
          syncShift();
        }
        function onFail() {
          wrap.removeAttribute('data-hg-loading');
          btn.disabled = false;
        }
        anim.onload = function () {
          if (typeof anim.decode === 'function') {
            anim.decode().then(finishPlay).catch(finishPlay);
          } else {
            finishPlay();
          }
        };
        anim.onerror = onFail;
        wrap.insertBefore(anim, btn);
        anim.src = src;
        syncShift();
      });
    }

    var marginPx = {{ section.settings.defer_init_margin | default: 320 }};
    var rootMarginStr = marginPx > 0 ? marginPx + 'px' : '0px';
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(
        function (entries, obs) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              initMarquee();
              obs.disconnect();
            }
          });
        },
        { root: null, rootMargin: rootMarginStr, threshold: 0 }
      );
      io.observe(root);
    } else {
      initMarquee();
    }
  })();
</script>

<style>
  #{{ hg_id }} .home-gyms-marquee__inner {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }

  #{{ hg_id }} .home-gyms-marquee__intro {
    max-width: 80rem;
    margin-left: auto;
    margin-right: auto;
    padding-left: 24px;
    padding-right: 24px;
    margin-bottom: {{ section.settings.intro_margin_bottom }}px;
  }

  #{{ hg_id }} .home-gyms-marquee__title {
    margin: 0 0 0px !important;
    font-family: Barlow, Barlow Fallback, sans-serif !important;
    font-weight: 900 !important;
    font-size: clamp(1.75rem, 4.5vw, 2.25rem) !important;
    line-height: 1.1 !important;
    letter-spacing: -.04em !important;
    text-transform: uppercase !important;
    text-align: center !important;
    color: var(--sg-heading-color, #1a1c1c);
  }

  #{{ hg_id }} .home-gyms-marquee__subtitle {
    font-family: var(--text-font-family) !important;
    font-size: {{ section.settings.subtitle_size }}px !important;
    line-height: 1.5 !important;
    font-weight: var(--text-font-weight) !important;
    color: {{ section.settings.subtitle_color }} !important;
    margin: 0 !important;
    text-align: center !important;
  }

  #{{ hg_id }} .home-gyms-marquee__viewport {
    overflow: hidden;
    width: 100%;
    contain: layout style;
  }

  #{{ hg_id }} .home-gyms-marquee__track {
    display: flex;
    width: max-content;
    flex-wrap: nowrap;
    animation: none;
  }

  #{{ hg_id }} .home-gyms-marquee__track.home-gyms-marquee__track--ready {
    will-change: transform;
    animation: hg-marquee-{{ hg_kf }} var(--hg-duration, 45s) linear infinite;
    transform: translate3d(0, 0, 0);
  }

  /* Pause on hover or when a link is focused (easier clicking) */
  #{{ hg_id }} .home-gyms-marquee__viewport:hover .home-gyms-marquee__track.home-gyms-marquee__track--ready,
  #{{ hg_id }} .home-gyms-marquee__viewport:focus-within .home-gyms-marquee__track.home-gyms-marquee__track--ready {
    animation-play-state: paused;
  }

  @keyframes hg-marquee-{{ hg_kf }} {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      transform: translate3d(var(--hg-shift, 0px), 0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #{{ hg_id }} .home-gyms-marquee__track {
      animation: none !important;
      transform: translate3d(0, 0, 0) !important;
      flex-wrap: wrap;
      width: 100%;
      max-width: 80rem;
      margin: 0 auto;
      justify-content: center;
      gap: {{ section.settings.card_gap }}px;
      padding-left: 24px;
      padding-right: 24px;
      box-sizing: border-box;
    }

    #{{ hg_id }} .home-gyms-marquee__strip {
      flex-wrap: wrap !important;
      justify-content: center !important;
      width: 100% !important;
      padding-left: 0 !important;
      padding-right: 0 !important;
      gap: {{ section.settings.card_gap }}px !important;
    }

    #{{ hg_id }} .home-gyms-marquee__strip[aria-hidden='true'] {
      display: none !important;
    }
  }

  #{{ hg_id }} .home-gyms-marquee__strip {
    display: flex;
    flex-shrink: 0;
    align-items: stretch;
    gap: {{ section.settings.card_gap }}px;
    padding-left: 24px;
    padding-right: 24px;
    box-sizing: border-box;
  }

  #{{ hg_id }} .home-gyms-marquee__cell {
    flex-shrink: 0;
  }

  #{{ hg_id }} .home-gyms-marquee__card {
    display: block;
    position: relative;
    text-decoration: none;
    color: inherit;
  }

  #{{ hg_id }} .home-gyms-marquee__card--gif {
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
  }

  #{{ hg_id }} .home-gyms-marquee__card-hit {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: {{ section.settings.card_radius }}px;
  }

  #{{ hg_id }} .home-gyms-marquee__card-hit:focus-visible {
    outline: 2px solid {{ section.settings.title_color }};
    outline-offset: 4px;
    z-index: 3;
  }

  #{{ hg_id }} .home-gyms-marquee__gif {
    position: absolute;
    inset: 0;
    z-index: 0;
    isolation: isolate;
  }

  #{{ hg_id }} .home-gyms-marquee__gif-poster:not(.home-gyms-marquee__gif-poster--empty) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  #{{ hg_id }} .home-gyms-marquee__gif-poster--empty {
    position: absolute;
    inset: 0;
    background: linear-gradient(145deg, #ececec, #d4d4d4);
  }

  #{{ hg_id }} .home-gyms-marquee__gif-anim {
    position: absolute;
    inset: 0;
    z-index: 2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  #{{ hg_id }} .home-gyms-marquee__gif-play {
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: 3;
    width: 3.75rem;
    height: 3.75rem;
    margin: 0;
    padding: 0;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgb(0 0 0 / 0.48);
    color: #fff;
    transform: translate(-50%, -50%);
    transition: background 0.2s ease, transform 0.2s ease;
  }

  #{{ hg_id }} .home-gyms-marquee__gif-play:hover {
    background: rgb(0 0 0 / 0.62);
    transform: translate(-50%, -50%) scale(1.06);
  }

  #{{ hg_id }} .home-gyms-marquee__gif-play:focus-visible {
    outline: 2px solid {{ section.settings.title_color }};
    outline-offset: 3px;
  }

  #{{ hg_id }} .home-gyms-marquee__gif-play-icon {
    display: flex;
    margin-left: 2px;
  }

  #{{ hg_id }} .home-gyms-marquee__gif--playing .home-gyms-marquee__gif-play {
    display: none !important;
  }

  #{{ hg_id }} .home-gyms-marquee__card:hover .home-gyms-marquee__gif:not(.home-gyms-marquee__gif--playing) .home-gyms-marquee__gif-poster,
  #{{ hg_id }} .home-gyms-marquee__card:hover .home-gyms-marquee__gif--playing .home-gyms-marquee__gif-anim {
    transform: scale(1.1);
  }

  #{{ hg_id }} .home-gyms-marquee__card:hover .home-gyms-marquee__gif:not(.home-gyms-marquee__gif--playing) .home-gyms-marquee__gif-poster--empty {
    transform: none;
  }

  #{{ hg_id }} .home-gyms-marquee__card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: {{ section.settings.card_radius }}px;
  }

  #{{ hg_id }} .home-gyms-marquee__card-link:focus-visible {
    outline: 2px solid {{ section.settings.title_color }};
    outline-offset: 4px;
  }

  #{{ hg_id }} .home-gyms-marquee__card-frame {
    position: relative;
    z-index: 2;
    width: 100%;
    aspect-ratio: 9 / 16;
    overflow: hidden;
    border-radius: {{ section.settings.card_radius }}px;
    background: #e8e8e8;
    pointer-events: none;
  }

  /* Frame deixa passar cliques para o link por baixo; só play e GIF animado capturam */
  #{{ hg_id }} .home-gyms-marquee__card-frame .home-gyms-marquee__gif {
    pointer-events: none;
  }

  #{{ hg_id }} .home-gyms-marquee__card-frame .home-gyms-marquee__gif-play,
  #{{ hg_id }} .home-gyms-marquee__card-frame .home-gyms-marquee__gif-anim {
    pointer-events: auto;
  }

  #{{ hg_id }} .home-gyms-marquee__card-frame .home-gyms-marquee__gif-poster {
    pointer-events: none;
  }

  #{{ hg_id }} .home-gyms-marquee__card-frame .home-gyms-marquee__card-img,
  #{{ hg_id }} .home-gyms-marquee__card-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.5s ease;
  }

  #{{ hg_id }} .home-gyms-marquee__card:hover .home-gyms-marquee__card-frame .home-gyms-marquee__card-img,
  #{{ hg_id }} .home-gyms-marquee__card:hover .home-gyms-marquee__card-frame img:not(.home-gyms-marquee__gif-poster),
  #{{ hg_id }} .home-gyms-marquee__card-link:hover .home-gyms-marquee__card-frame .home-gyms-marquee__card-img,
  #{{ hg_id }} .home-gyms-marquee__card-link:hover .home-gyms-marquee__card-frame img:not(.home-gyms-marquee__gif-poster),
  #{{ hg_id }} .home-gyms-marquee__card-link:focus-visible .home-gyms-marquee__card-frame .home-gyms-marquee__card-img,
  #{{ hg_id }} .home-gyms-marquee__card-link:focus-visible .home-gyms-marquee__card-frame img:not(.home-gyms-marquee__gif-poster) {
    transform: scale(1.1);
  }

  #{{ hg_id }} .home-gyms-marquee__ph {
    width: 100%;
    height: 100%;
    min-height: 120px;
    background: linear-gradient(145deg, #ececec, #d4d4d4);
    border: 1px dashed rgba(0, 0, 0, 0.12);
    box-sizing: border-box;
  }

  #{{ hg_id }} .home-gyms-marquee__tag-wrap {
    position: absolute;
    bottom: 24px;
    left: 24px;
    right: 24px;
    pointer-events: none;
    z-index: 4;
  }

  #{{ hg_id }} .home-gyms-marquee__tag {
    display: inline-block;
    font-family: var(--heading-font-family) !important;
    font-size: 12px !important;
    line-height: 1.2 !important;
    font-weight: 700 !important;
    letter-spacing: 0.12em !important;
    text-transform: uppercase !important;
    color: {{ section.settings.tag_text_color }} !important;
    background: rgba(255, 255, 255, 0.9);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    padding: 8px 16px;
    border-radius: 999px;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }
</style>

{% schema %}
{
  "name": "Home gyms results marquee",
  "tag": "section",
  "class": "section-home-gyms-results-marquee",
  "max_blocks": 16,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Real Home Gyms. Real Results."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "See how our community trains at home with Ativafit gear"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 24,
      "max": 52,
      "step": 1,
      "unit": "px",
      "label": "Title size",
      "default": 36
    },
    {
      "type": "range",
      "id": "title_sub_gap",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Space title → subtitle",
      "default": 8
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 14,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Subtitle size",
      "default": 16
    },
    {
      "type": "range",
      "id": "intro_margin_bottom",
      "min": 32,
      "max": 96,
      "step": 4,
      "unit": "px",
      "label": "Space below intro (before marquee)",
      "default": 64
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#574237"
    },
    {
      "type": "color",
      "id": "tag_text_color",
      "label": "Tag text color",
      "default": "#1a1c1c"
    },
    {
      "type": "range",
      "id": "card_width",
      "min": 220,
      "max": 380,
      "step": 10,
      "unit": "px",
      "label": "Each card width (height follows 9:16)",
      "default": 300,
      "info": "Fixed 9 (width) : 16 (height) ratio — vertical story-style format."
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 16,
      "max": 64,
      "step": 4,
      "unit": "px",
      "label": "Gap between cards",
      "default": 32
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Card corner radius",
      "default": 8
    },
    {
      "type": "range",
      "id": "marquee_seconds",
      "min": 20,
      "max": 120,
      "step": 1,
      "unit": "s",
      "label": "Full loop duration",
      "default": 50
    },
    {
      "type": "range",
      "id": "strip_cycles",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "List repeats per strip",
      "default": 2,
      "info": "Increase if the strip is shorter than the viewport."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 32,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 32,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 96
    },
    {
      "type": "header",
      "content": "Performance"
    },
    {
      "type": "range",
      "id": "eager_first_cards",
      "min": 0,
      "max": 6,
      "step": 1,
      "label": "Eager-load first cards (visible strip)",
      "default": 0,
      "info": "First N cards in the first row use high fetch priority and eager loading. IMPORTANT: Keep at 0 if this section is below the fold (it steals fetch priority from the hero image and hurts LCP). Only raise if the marquee is actually the hero/ATF."
    },
    {
      "type": "range",
      "id": "defer_init_margin",
      "min": 0,
      "max": 800,
      "step": 40,
      "unit": "px",
      "label": "Start marquee JS before scroll (margin)",
      "default": 320,
      "info": "IntersectionObserver expands the viewport by this amount so animation and layout run slightly before the section enters the screen. 0 = init only when any part of the section is visible."
    },
    {
      "type": "text",
