{% liquid
  assign desktop_columns = section.settings.columns_desktop | at_most: 4 | at_least: 1
  assign mobile_columns = section.settings.columns_mobile | at_most: 2 | at_least: 1
  assign block_count = section.blocks.size
%}

<section id="ServiceCommunityDiscount-{{ section.id }}" class="service-community-discount section-{{ section.id }}">
  <div class="service-community-discount__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="service-community-discount__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.intro != blank -%}
      <div class="service-community-discount__intro rte">
        {{ section.settings.intro }}
      </div>
    {%- endif -%}

    {%- if block_count > 0 -%}
      <div
        class="service-community-discount__grid"
        style="--scd-desktop-columns: {{ desktop_columns }}; --scd-mobile-columns: {{ mobile_columns }};"
      >
        {%- for block in section.blocks -%}
          {% liquid
            assign card_title = block.settings.title
            assign card_description = block.settings.description
            assign card_link = block.settings.link
            assign card_image = block.settings.image
          %}

          <article class="service-community-discount__card" {{ block.shopify_attributes }}>
            {%- if card_link != blank -%}<a class="service-community-discount__card-link" href="{{ card_link }}">{%- endif -%}

            <div class="service-community-discount__media">
              {%- if card_image != blank -%}
                {{
                  card_image
                  | image_url: width: 960
                  | image_tag:
                    loading: 'lazy',
                    widths: '240,320,480,640,800,960',
                    sizes: '(max-width: 749px) calc((100vw - 48px) / var(--scd-mobile-columns)), (max-width: 1099px) calc((100vw - 72px) / 2), calc((min(1200px, 100vw - 80px) - (var(--scd-desktop-columns) - 1) * 20px) / var(--scd-desktop-columns))',
                    class: 'service-community-discount__image',
                    alt: card_image.alt | default: card_title | escape
                }}
              {%- else -%}
                <div class="service-community-discount__image-placeholder" aria-hidden="true"></div>
              {%- endif -%}
            </div>

            <div class="service-community-discount__content">
              {%- if card_title != blank -%}
                <h3 class="service-community-discount__title">{{ card_title | escape }}</h3>
              {%- endif -%}
              {%- if card_description != blank -%}
                <div class="service-community-discount__description rte">{{ card_description }}</div>
              {%- endif -%}
            </div>

            {%- if card_link != blank -%}</a>{%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% style %}
  .section-{{ section.id }} {
    --scd-max-width: {{ section.settings.max_width }}px;
    --scd-card-gap: {{ section.settings.card_gap }}px;
    --scd-heading-color: {{ section.settings.heading_color }};
    --scd-text-color: {{ section.settings.text_color }};
    --scd-bg: {{ section.settings.background_color }};
    --scd-card-bg: {{ section.settings.card_background }};
    --scd-card-radius: {{ section.settings.card_radius }}px;
    --scd-image-ratio: {{ section.settings.image_ratio }};
    --scd-section-padding-top: {{ section.settings.padding_top }}px;
    --scd-section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .section-{{ section.id }}.service-community-discount {
    padding-top: var(--scd-section-padding-top);
    padding-bottom: var(--scd-section-padding-bottom);
    background: var(--scd-bg);
  }

  .section-{{ section.id }} .service-community-discount__inner {
    max-width: var(--scd-max-width);
    margin: 0 auto;
    color: var(--scd-text-color);
  }

  .section-{{ section.id }} .service-community-discount__heading {
    margin: 0 0 18px;
    color: var(--scd-heading-color);
    font-size: clamp(1.5rem, 2.2vw, 2rem);
    line-height: 1.2;
  }

  .section-{{ section.id }} .service-community-discount__intro {
    margin-bottom: 26px;
    color: var(--scd-text-color);
  }

  .section-{{ section.id }} .service-community-discount__intro p {
    margin: 0 0 14px;
    line-height: 1.6;
    font-size: 1.125rem;
  }

  .section-{{ section.id }} .service-community-discount__intro p:last-child {
    margin-bottom: 0;
  }

  .section-{{ section.id }} .service-community-discount__grid {
    display: grid;
    grid-template-columns: repeat(var(--scd-desktop-columns), minmax(0, 1fr));
    gap: var(--scd-card-gap);
  }

  .section-{{ section.id }} .service-community-discount__card {
    background: var(--scd-card-bg);
    border-radius: var(--scd-card-radius);
    overflow: hidden;
    color: inherit;
  }

  .section-{{ section.id }} .service-community-discount__card-link {
    display: block;
    color: inherit;
    text-decoration: none;
    height: 100%;
  }

  .section-{{ section.id }} .service-community-discount__media {
    aspect-ratio: var(--scd-image-ratio);
    background: rgba(0, 0, 0, 0.06);
    overflow: hidden;
  }

  .section-{{ section.id }} .service-community-discount__image,
  .section-{{ section.id }} .service-community-discount__image-placeholder {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .section-{{ section.id }} .service-community-discount__image-placeholder {
    background: linear-gradient(135deg, #dedede 0%, #f3f3f3 100%);
  }

  .section-{{ section.id }} .service-community-discount__content {
    padding: 14px 10px 8px;
    text-align: center;
  }

  .section-{{ section.id }} .service-community-discount__title {
    margin: 0 0 8px;
    color: var(--scd-heading-color);
    font-size: clamp(1.3rem, 2vw, 2rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  .section-{{ section.id }} .service-community-discount__description {
    color: var(--scd-text-color);
    font-size: 1.05rem;
    line-height: 1.4;
  }

  .section-{{ section.id }} .service-community-discount__description p {
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .section-{{ section.id }} .service-community-discount__grid {
      grid-template-columns: repeat(min(2, var(--scd-desktop-columns)), minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .section-{{ section.id }} .service-community-discount__inner {
      max-width: 100%;
    }

    .section-{{ section.id }} .service-community-discount__intro {
      margin-bottom: 20px;
    }

    .section-{{ section.id }} .service-community-discount__intro p {
      font-size: 1rem;
    }

    .section-{{ section.id }} .service-community-discount__grid {
      grid-template-columns: repeat(var(--scd-mobile-columns), minmax(0, 1fr));
      gap: 14px;
    }

    .section-{{ section.id }} .service-community-discount__content {
      padding: 10px 8px 6px;
    }

    .section-{{ section.id }} .service-community-discount__title {
      font-size: clamp(1.2rem, 6vw, 1.7rem);
      margin-bottom: 6px;
    }

    .section-{{ section.id }} .service-community-discount__description {
      font-size: 0.98rem;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Service Discount Grid",
  "tag": "section",
  "class": "section-service-community-discount",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Service Community Discount"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro text",
      "default": "<p>As a token of gratitude, we're proud to offer a 10% discount to service members and education professionals.</p><p>To claim your discount, contact services@ativafit.com and share documentation confirming your affiliation.</p><p>Once your information is verified, you'll receive a one-time promo code to use on ativafit.com.</p>"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Content max width",
      "min": 900,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1320
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "min": 1,
      "max": 2,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Card gap",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "default": "16 / 7",
      "options": [
        { "value": "16 / 7", "label": "Wide (16:7)" },
        { "value": "4 / 3", "label": "Landscape (4:3)" },
        { "value": "1 / 1", "label": "Square (1:1)" }
      ]
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "community_card",
      "name": "Community card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Military"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Include active duty, veterans, and dependents.</p>"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Optional card link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service Community Discount",
      "blocks": [
        {
          "type": "community_card",
          "settings": {
            "title": "Military",
            "description": "<p>Include active duty, veterans, and dependents.</p>"
          }
        },
        {
          "type": "community_card",
          "settings": {
            "title": "First Responders",
            "description": "<p>Include police officers, firefighters, and EMTs.</p>"
          }
        },
        {
          "type": "community_card",
          "settings": {
            "title": "Medical Professionals",
            "description": "<p>Include doctors, nurses, and healthcare staff.</p>"
          }
        },
        {
          "type": "community_card",
          "settings": {
            "title": "Educators",
            "description": "<p>Include pre-K, K-12 teachers, and professors.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
