{{ 'shop-gym-equipment-ativa.css' | asset_url | stylesheet_tag }}
<script src="{{ 'shop-gym-equipment-ativa.js' | asset_url }}" defer></script>

{%- liquid
  assign stagger = section.settings.stagger_ms | default: 80
  assign mobile_layout = section.settings.mobile_layout | default: 'carousel'
-%}

<section
  class="shop-gym-ativa"
  data-shop-gym-ativa
  data-mobile-layout="{{ mobile_layout }}"
  style="
    --sg-heading-color: {{ section.settings.heading_color }};
    --sg-card-bg: {{ section.settings.card_placeholder_bg }};
    --sg-accent: {{ section.settings.accent_color }};
  "
  aria-label="{{ section.settings.section_a11y_label | default: 'Equipment categories' | escape }}"
  {{ section.shopify_attributes }}>
  <div class="shop-gym-ativa__inner">
    {%- if section.settings.heading != blank -%}
      <h2
        class="shop-gym-ativa__heading shop-gym-ativa__reveal"
        style="--sg-reveal-delay: 0ms">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="shop-gym-ativa__grid shop-gym-ativa__grid--mobile-{{ mobile_layout }}" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'card' -%}
            <li
              class="shop-gym-ativa__item"
              style="--sg-stagger: {{ forloop.index0 | plus: 1 | times: stagger }}ms"
              {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a
                  class="shop-gym-ativa__card shop-gym-ativa__reveal"
                  style="--sg-reveal-delay: var(--sg-stagger, 0ms)"
                  href="{{ block.settings.link }}">
                  {%- if block.settings.image != blank -%}
                    {{
                      block.settings.image
                      | image_url: width: 900
                      | image_tag:
                        class: 'shop-gym-ativa__img',
                        widths: '375, 550, 700, 900',
                        sizes: '(min-width: 990px) 25vw, (min-width: 768px) 50vw, 100vw',
                        loading: 'lazy',
                        alt: block.settings.image.alt | default: block.settings.title | escape
                    }}
                  {%- else -%}
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'shop-gym-ativa__img shop-gym-ativa__placeholder' }}
                  {%- endif -%}

                  <div class="shop-gym-ativa__gradient" aria-hidden="true"></div>

                  <div class="shop-gym-ativa__content">
                    {%- if block.settings.title != blank -%}
                      <h3 class="shop-gym-ativa__card-title">{{ block.settings.title | escape }}</h3>
                    {%- endif -%}
                    <span class="shop-gym-ativa__cta">
                      {{- block.settings.cta_label | default: 'See products' | escape -}}
                      <span class="material-symbols-outlined shop-gym-ativa__cta-arrow" aria-hidden="true">arrow_forward</span>
                    </span>
                  </div>
                </a>
              {%- else -%}
                <div
                  class="shop-gym-ativa__card shop-gym-ativa__reveal"
                  style="--sg-reveal-delay: var(--sg-stagger, 0ms)"
                  role="group"
                  aria-label="{{ block.settings.title | escape }}">
                  {%- if block.settings.image != blank -%}
                    {{
                      block.settings.image
                      | image_url: width: 900
                      | image_tag:
                        class: 'shop-gym-ativa__img',
                        widths: '375, 550, 700, 900',
                        sizes: '(min-width: 990px) 25vw, (min-width: 768px) 50vw, 100vw',
                        loading: 'lazy',
                        alt: block.settings.image.alt | default: block.settings.title | escape
                    }}
                  {%- else -%}
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'shop-gym-ativa__img shop-gym-ativa__placeholder' }}
                  {%- endif -%}
                  <div class="shop-gym-ativa__gradient" aria-hidden="true"></div>
                  <div class="shop-gym-ativa__content">
                    {%- if block.settings.title != blank -%}
                      <h3 class="shop-gym-ativa__card-title">{{ block.settings.title | escape }}</h3>
                    {%- endif -%}
                    <span class="shop-gym-ativa__cta">
                      {{- block.settings.cta_label | default: 'See products' | escape -}}
                      <span class="material-symbols-outlined shop-gym-ativa__cta-arrow" aria-hidden="true">arrow_forward</span>
                    </span>
                  </div>
                </div>
              {%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>

      {%- if mobile_layout == 'carousel' -%}
        <div class="shop-gym-ativa__carousel-ui" data-shop-gym-carousel-ui hidden>
          <div class="shop-gym-ativa__dots" data-shop-gym-dots role="group" aria-label="Carousel navigation"></div>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Shop Home Gym Equipment",
  "tag": "section",
  "class": "shopify-section-shop-gym-equipment-ativa",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section title",
      "default": "Shop Home Gym Equipment"
    },
    {
      "type": "text",
      "id": "section_a11y_label",
      "label": "Region name (accessibility)",
      "default": "Equipment categories"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        {
          "value": "carousel",
          "label": "Carousel"
        },
        {
          "value": "grid",
          "label": "Grid (2 per row)"
        }
      ],
      "default": "carousel",
      "info": "On screens ≥768px the grid stays (2 columns, then 4). This option applies to mobile only."
    },
    {
      "type": "range",
      "id": "stagger_ms",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "ms",
      "label": "Delay between each card (animation)",
      "default": 80,
      "info": "0 = all at once. Honors “reduce motion” in system settings."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a1c1c"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "CTA / arrow color",
      "default": "#eb701f"
    },
    {
      "type": "color",
      "id": "card_placeholder_bg",
      "label": "Card background (placeholder)",
      "default": "#f2f2f2"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Category card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Strength Training"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card link",
          "info": "Makes the whole card clickable."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA text",
          "default": "See products"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop Home Gym Equipment",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Strength Training"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Cardio Training"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Flexibility Training"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Family Fun"
          }
        }
      ]
    }
  ]
}
{% endschema %}
