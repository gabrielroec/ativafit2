{% doc %}
  @prompt
    请为我生成一个首页 Section 模块，要求使用 HTML 和原生 CSS（或 Tailwind CSS，但需提取出核心配置变量）。
    
    1. 设计变量 (Design Tokens)： > 请在 CSS 开头定义以下变量，确保我可以通过修改这些变量直接控制全局样式：
    
    --radius: 控制图片和卡片的圆角大小。
    
    --primary-color: 主色调（用于按钮背景和价格）。
    
    --font-main: 主体字体族。
    
    --heading-size: 标题字号。
    
    --desc-size: 描述文字字号。
    
    2. 结构要求：
    
    Header: 居中对齐，包含标题和描述。
    
    Main Content: 下方两栏布局。左侧是一张占位大图（Aspect Ratio 建议 3:4）；右侧是 2x2 的产品网格。
    
    Product Card: 包含图片、标题、价格、以及一个“加入购物车”按钮。
    
    3. 响应式： 适配移动端，在大约 768px 以下时自动变为单栏堆叠布局。
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-products-{{ ai_gen_id }} {
    --radius: {{ block.settings.border_radius }}px;
    --primary-color: {{ block.settings.primary_color }};
    --font-main: {{ settings.text_font.family }}, {{ settings.text_font.fallback_families }};
    --heading-size: {{ block.settings.heading_size }}px;
    --desc-size: {{ block.settings.desc_size }}px;
    
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
    font-family: var(--font-main);
  }

  .ai-featured-products-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-featured-products-title-{{ ai_gen_id }} {
    font-size: var(--heading-size);
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px 0;
    font-weight: 600;
  }

  .ai-featured-products-desc-{{ ai_gen_id }} {
    font-size: var(--desc-size);
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-featured-products-main-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-featured-products-hero-{{ ai_gen_id }} {
    position: relative;
    aspect-ratio: 3 / 4;
    border-radius: var(--radius);
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-featured-products-hero-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-featured-products-hero-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-featured-products-hero-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-featured-products-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-product-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background }};
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-product-card-image-{{ ai_gen_id }} {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-product-card-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-product-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-product-card-content-{{ ai_gen_id }} {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex-grow: 1;
  }

  .ai-product-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    font-weight: 600;
    line-height: 1.3;
  }

  .ai-product-card-title-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
  }

  .ai-product-card-title-{{ ai_gen_id }} a:hover {
    color: var(--primary-color);
  }

  .ai-product-card-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: var(--primary-color);
    font-weight: 700;
    margin: 0;
  }

  .ai-product-card-button-{{ ai_gen_id }} {
    margin-top: auto;
    padding: 10px 16px;
    background-color: var(--primary-color);
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: calc(var(--radius) / 2);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
    text-align: center;
    text-decoration: none;
    display: block;
  }

  .ai-product-card-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    transform: scale(1.02);
  }

  .ai-product-card-empty-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    text-align: center;
    color: #999;
    font-size: 14px;
    font-style: italic;
  }

  @media screen and (max-width: 768px) {
    .ai-featured-products-{{ ai_gen_id }} {
      --heading-size: {{ block.settings.heading_size | times: 0.8 }}px;
      --desc-size: {{ block.settings.desc_size | times: 0.9 }}px;
    }

    .ai-featured-products-main-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-featured-products-hero-{{ ai_gen_id }} {
      aspect-ratio: 16 / 9;
    }

    .ai-featured-products-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<div class="ai-featured-products-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-featured-products-header-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-featured-products-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}
    {% if block.settings.description != blank %}
      <p class="ai-featured-products-desc-{{ ai_gen_id }}">{{ block.settings.description }}</p>
    {% endif %}
  </div>

  <div class="ai-featured-products-main-{{ ai_gen_id }}">
    <div class="ai-featured-products-hero-{{ ai_gen_id }}">
      {% if block.settings.hero_image %}
        <img
          src="{{ block.settings.hero_image | image_url: width: 1000 }}"
          alt="{{ block.settings.hero_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.hero_image.width }}"
          height="{{ block.settings.hero_image.height }}"
        >
      {% else %}
        <div class="ai-featured-products-hero-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-featured-products-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign product_key = 'product_' | append: i
          assign product = block.settings[product_key]
        %}

        <div class="ai-product-card-{{ ai_gen_id }}">
          {% if product != blank %}
            <div class="ai-product-card-image-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <a href="{{ product.url }}">
                  <img
                    src="{{ product.featured_image | image_url: width: 500 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    loading="lazy"
                    width="500"
                    height="500"
                  >
                </a>
              {% else %}
                <div class="ai-product-card-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-product-card-content-{{ ai_gen_id }}">
              <h3 class="ai-product-card-title-{{ ai_gen_id }}">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>
              <p class="ai-product-card-price-{{ ai_gen_id }}">
                {{ product.price | money }}
              </p>
              <a href="{{ product.url }}" class="ai-product-card-button-{{ ai_gen_id }}">
                {{ block.settings.button_text }}
              </a>
            </div>
          {% else %}
            <div class="ai-product-card-empty-{{ ai_gen_id }}">
              Select a product for slot {{ i }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "Featured Collection"
    },
    {
      "type": "inline_richtext",
      "id": "description",
      "label": "Description",
      "default": "Discover our handpicked selection of premium products"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Product 1"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Product 2"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Product 3"
    },
    {
      "type": "product",
      "id": "product_4",
      "label": "Product 4"
    },
    {
      "type": "inline_richtext",
      "id": "button_text",
      "label": "Button text",
      "default": "Add to Cart"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "desc_size",
      "label": "Description size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "product_title_size",
      "label": "Product title size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "product_price_size",
      "label": "Product price size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary color",
      "default": "#eb7122"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover",
      "default": "#d66420"
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
