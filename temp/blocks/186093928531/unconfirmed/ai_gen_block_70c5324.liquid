    },
    {
      "type": "color",
      "id": "sale_color",
      "label": "Price color",
      "default": "#eb7122"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "range",
