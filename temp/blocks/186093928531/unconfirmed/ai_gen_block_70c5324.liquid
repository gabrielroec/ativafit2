      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#999999"
    },
    {
      "type": "header",
      "content": "Banner"
    },
    {
      "type": "image_picker",
