      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "timer_label_color",
      "label": "Label color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "timer_label_size",
      "label": "Label size",
      "min": 8,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#ff6b00"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Button text size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Banner style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "close_button_color",
      "label": "Close button color",
      "default": "#999999"
    }
  ],
  "presets": [
    {
      "name": "Countdown banner"
    }
  ]
