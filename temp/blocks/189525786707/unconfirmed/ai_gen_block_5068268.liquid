      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "banner_cta_height_desktop",
      "label": "Button height (desktop)",
      "min": 40,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "banner_cta_height_mobile",
      "label": "Button height (mobile)",
      "min": 44,
      "max": 70,
      "step": 2,
      "unit": "px",
      "default": 54
