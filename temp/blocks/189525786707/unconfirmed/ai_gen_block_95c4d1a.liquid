    },
    {
      "type": "text",
      "id": "bundles_cta_text",
      "label": "Bundles button text",
      "default": "View Bundles"
    },
    {
      "type": "url",
      "id": "bundles_cta_link",
      "label": "Bundles button link"
    },
    {
      "type": "range",
      "id": "desktop_panel_width",
      "label": "Desktop panel width",
      "min": 50,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 75
    },
    {
      "type": "color",
      "id": "panel_bg_color",
      "label": "Panel background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "panel_border_radius",
      "label": "Panel border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Bundles text style"
    },
    {
      "type": "color",
      "id": "bundles_headline_color",
      "label": "Headline color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "bundles_headline_size",
      "label": "Desktop headline size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "mobile_bundles_headline_size",
      "label": "Mobile headline size",
      "min": 14,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "bundles_subtext_color",
      "label": "Subtext color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "bundles_subtext_size",
      "label": "Desktop subtext size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "mobile_bundles_subtext_size",
      "label": "Mobile subtext size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Bundles button style"
    },
    {
      "type": "color",
      "id": "bundles_button_bg",
      "label": "Button background",
      "default": "#eb7122"
    },
    {
      "type": "color",
      "id": "bundles_button_text",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 6
