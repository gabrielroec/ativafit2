    "image_tabs_cardio": {
      "type": "image-tabs",
      "blocks": {
        "tab_cardio_1": {
          "type": "tab",
          "settings": {
            "title": "Foldable & Space-Saving",
            "image": "shopify://shop_images/Bikes-1600x1200.webp",
            "text": "<p>Both the F8 and R8 are Ativafit folding exercise bikes that collapse in seconds, perfect for small apartments or shared spaces. Add the Gravity Weighted Vest for cardio on the go—walking, running, or bodyweight circuits.</p>"
          }
        },
        "tab_cardio_2": {
          "type": "tab",
          "settings": {
            "title": "Comfort for Every Rider",
            "image": "shopify://shop_images/Cardio-1600x1200.webp",
            "text": "<p>The R8 features a semi-recumbent design with a supportive backrest, ideal for low-impact cardio and anyone who wants maximum comfort. The F8 offers an upright ride with a health monitor and scan mode for tracking your session.</p>"
          }
        },
        "tab_cardio_3": {
          "type": "tab",
          "settings": {
            "title": "Smooth Magnetic Resistance",
            "image": "shopify://shop_images/Y8A2946_ca2ed324-ab74-4474-983b-3356fbffe70d.jpg",
            "text": "<p>Enjoy whisper-quiet workouts with our magnetic resistance system. Multiple levels let you go from gentle warm-ups to challenging cardio. Sturdy, easy to move, and built to last—whether you're a beginner or training regularly.</p>"
          }
        },
        "tab_cardio_4": {
          "type": "tab",
          "settings": {
            "title": "Resistance Bands & Weighted Vest",
            "image": "shopify://shop_images/r8_bike_selling_points.webp",
            "text": "<p>The R8 includes resistance bands for upper-body toning while you cycle. Pair your bike with the Gravity Adjustable Vest (2–22 lb) for extra intensity on rides, or use the vest alone for walking, running, and strength-and-cardio combos.</p>"
          }
        }
      },
      "block_order": [
        "tab_cardio_1",
        "tab_cardio_2",
        "tab_cardio_3",
        "tab_cardio_4"
      ],
      "settings": {
        "padding_top": 24,
        "padding_bottom": 24
      }
    },
