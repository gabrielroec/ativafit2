    "faq_accordion_cardio": {
      "type": "faq-accordion",
      "blocks": {
        "faq_item_1": {
          "type": "faq_item",
          "settings": {
            "question": "Is a stationary exercise bike good for weight loss?",
            "answer": "Yes! Both the R8 and F8 are excellent for home cardio and fat loss. The R8 adds resistance bands for upper-body toning while you cycle, and the F8's health monitor helps you track your effort. Pair with the Gravity Vest for extra calorie burn."
          }
        },
        "faq_item_2": {
          "type": "faq_item",
          "settings": {
            "question": "Which Ativafit bike is best for seniors?",
            "answer": "The R8 is the best choice for elderly users thanks to its semi-recumbent design and backrest, which offer stability and low-impact comfort. Assembly is straightforward, and the bike is sturdy and easy to move when needed."
          }
        },
        "faq_item_3": {
          "type": "faq_item",
          "settings": {
            "question": "Is the F8 or R8 better for small spaces?",
            "answer": "Both are foldable and space-saving. The F8 is the most compact option. The R8 takes a bit more room when in use but also folds for storage. Either fits well in apartments or corners."
          }
        },
        "faq_item_4": {
          "type": "faq_item",
          "settings": {
            "question": "What is the Gravity Weighted Vest for?",
            "answer": "The Gravity Adjustable Vest (2–22 lb) adds resistance to walking, running, bodyweight exercises, or even cycling. Adjustable iron sand weights and a tight fit make it ideal for cardio and strength-and-conditioning workouts at home or outdoors."
          }
        },
        "faq_item_5": {
          "type": "faq_item",
          "settings": {
            "question": "Do the bikes come with a warranty?",
            "answer": "Yes. We offer a standard one-year warranty. Sign up for AtivaPeople to get an extra year of coverage and member benefits."
          }
        }
      },
      "block_order": [
        "faq_item_1",
        "faq_item_2",
