    "faq_accordion_flexibility": {
      "type": "faq-accordion",
      "blocks": {
        "faq_item_1": {
          "type": "faq_item",
          "settings": {
            "question": "What are half balance balls used for?",
            "answer": "Half balance balls (also called balance hemispheres or BOSU-style tools) are used for balance training, core strength, stability, and flexibility. You can do squats, push-ups, planks, single-leg exercises, and stretching on them. They're great for home workouts and rehab."
          }
        },
        "faq_item_2": {
          "type": "faq_item",
          "settings": {
            "question": "Is the Crest or Ripple ball better for beginners?",
            "answer": "Both are beginner-friendly. The Crest Half Ball has a smooth top with resistance bands included—good for classic balance and strength work. The Ripple Massage Half Ball has a textured surface that can help with grip and massage; choose it if you like sensory feedback during exercises."
          }
        },
        "faq_item_3": {
          "type": "faq_item",
          "settings": {
            "question": "How do I inflate the balance ball?",
            "answer": "Use the included pump, or a standard balloon or fitness ball pump. Many users find a balloon blower or electric pump speeds things up. Inflate until firm but still slightly flexible for comfort and stability."
          }
        },
        "faq_item_4": {
          "type": "faq_item",
          "settings": {
            "question": "Can the whole family use them?",
            "answer": "Yes. Customers use them for solo workouts, with kids for sit-ups and push-ups, and for light rehab or active recovery. They're easy to move and store, so they work well in shared spaces."
          }
        },
        "faq_item_5": {
          "type": "faq_item",
          "settings": {
            "question": "Do Ativafit balance balls come with a warranty?",
            "answer": "Yes. We offer a standard warranty. Join AtivaPeople for extra coverage and member benefits."
          }
        }
      },
      "block_order": [
        "faq_item_1",
