    "image_tabs_flexibility": {
      "type": "image-tabs",
      "blocks": {
        "tab_flexibility_1": {
          "type": "tab",
          "settings": {
            "title": "Balance & Stability Training",
            "image": "shopify://shop_images/collection_banner-1600x900.webp",
            "text": "<p>Half balance balls are ideal for improving balance, core strength, and coordination. Use them for squats, push-ups, planks, and single-leg work. The skid-proof base and ridges keep you stable and secure during every rep.</p>"
          }
        },
        "tab_flexibility_2": {
          "type": "tab",
          "settings": {
            "title": "Easy to Inflate & Store",
            "image": "shopify://shop_images/all_collection-900x1200.webp",
            "text": "<p>Ativafit balance balls are quick to inflate with the included pump—or use a balloon pump for even faster setup. Deflate when you're done and store anywhere. Perfect for home gyms, travel, or small spaces.</p>"
          }
        },
        "tab_flexibility_3": {
          "type": "tab",
          "settings": {
            "title": "Crest Half Ball with Resistance Bands",
            "image": "shopify://shop_images/collection_banner-1600x900.webp",
            "text": "<p>The Crest Half Ball Balance Ball comes with resistance bands for extra versatility. Use the ball for balance and the bands for strength and flexibility—one piece of equipment, countless workouts for the whole family.</p>"
          }
        },
        "tab_flexibility_4": {
          "type": "tab",
          "settings": {
            "title": "Ripple Massage Half Ball",
            "image": "shopify://shop_images/all_collection-900x1200.webp",
            "text": "<p>The Ripple Massage Half Ball adds a textured surface for massage and sensory feedback during balance work. Great for recovery, foot and leg work, and anyone who wants both stability training and a gentle massage effect.</p>"
          }
        }
      },
      "block_order": [
        "tab_flexibility_1",
