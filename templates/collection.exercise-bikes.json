        "faq_1": {
          "type": "faq_item",
          "settings": {
            "question": "How do Ativafit adjustable dumbbells work?",
            "answer": "Ativafit dumbbells use a smart twist-dial system or glide-tech that lets you change weights in seconds. One handle holds multiple weight levels, so you can replace an entire rack with just one set."
          }
        },
        "faq_3": {
          "type": "faq_item",
          "settings": {
            "question": "Are your dumbbells safe and durable for heavy training?",
            "answer": "Yes. Our dumbbells are tested for stability and durability. The internal locking system keeps plates secure even during intense workouts."
          }
        },
        "faq_4": {
          "type": "faq_item",
          "settings": {
            "question": "Are your benches compatible with all dumbbell models?",
            "answer": "Yes. Both our Lite and Pro Adjustable Benches are compatible with all Ativafit dumbbells. The Pro Bench is recommended for 66lbs and 88lbs models due to its higher weight capacity."
          }
        },
        "faq_8": {
          "type": "faq_item",
          "settings": {
            "question": "Does the stand fit all Ativafit dumbbells?",
            "answer": "Yes. Our stand is designed to fit 27.5lbs, 66lbs and 88lbs adjustable dumbbells perfectly."
          }
        },
        "faq_11": {
          "type": "faq_item",
          "settings": {
            "question": "Do your products come with a warranty?",
            "answer": "Yes. All Ativafit dumbbells are covered by a 2-year limited warranty and have a 30-day return policy."
          }
