    "image_tabs_strength": {
      "type": "image-tabs",
      "blocks": {
        "tab_strength_1": {
          "type": "tab",
          "settings": {
            "title": "Empower Every Family Member",
            "image": "shopify://shop_images/Empower_Every_Family_Member.webp",
            "text": "<p>From the 27.5lb Spark to the 88lb Flare, the Ativafit strength range serves everyone. Build a shared home gym with adjustable dumbbells, benches, and stands where everyone from beginner to advanced can train together.</p>"
          }
        },
        "tab_strength_2": {
          "type": "tab",
          "settings": {
            "title": "Real Steel Feel & Durability",
            "image": "shopify://shop_images/Real_Steel_Feel_vs._Bulky_Plastic.webp",
            "text": "<p>Ativafit uses precision-machined solid steel plates and all-metal adjustment dials. Our dumbbells and benches are built for long-term use—delivering the dense, stable feel of professional equipment in a compact footprint.</p>"
          }
        },
        "tab_strength_3": {
          "type": "tab",
          "settings": {
            "title": "Compact Design, Full Range of Motion",
            "image": "shopify://shop_images/Precision_Progress_in_a_Compact_Design.webp",
            "text": "<p>Our adjustable dumbbells offer micro-adjustment levels and a compact design so you can progress safely without oversized frames limiting your movement. Pair them with our foldable benches and stands for a complete, space-saving setup.</p>"
          }
        },
        "tab_strength_4": {
          "type": "tab",
          "settings": {
            "title": "Benches, Stands & Recovery",
            "image": "shopify://shop_images/dumbbell_feature.webp",
            "text": "<p>Complete your strength corner with the Atlas Dumbbell Stand, Anchor and Apex Pro adjustable benches, and the Pulse Flex massage gun. Everything you need to train hard and recover well—all from Ativafit.</p>"
          }
        }
      },
      "block_order": [
        "tab_strength_1",
        "tab_strength_2",
        "tab_strength_3",
        "tab_strength_4"
      ],
      "disabled": true,
