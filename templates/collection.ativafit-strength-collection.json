    "faq_accordion_strength": {
      "type": "faq-accordion",
      "blocks": {
        "faq_item_1": {
          "type": "faq_item",
          "settings": {
            "question": "How do Ativafit adjustable dumbbells work?",
            "answer": "Ativafit dumbbells use a dial or glide system so you can change weight in seconds. Each handle holds multiple weight levels—replacing a full rack of traditional weights. Place the handle in the base, turn the dial to your desired setting, and lift."
          }
        },
        "faq_item_2": {
          "type": "faq_item",
          "settings": {
            "question": "Are your dumbbells safe and durable for heavy training?",
            "answer": "Yes. Every Ativafit dumbbell is tested for stability and long-term durability. Our internal locking system keeps weights secure during high-intensity workouts, so they're built to be the centerpiece of your home strength setup."
          }
        },
        "faq_item_3": {
          "type": "faq_item",
          "settings": {
            "question": "Are your benches compatible with all dumbbell models?",
            "answer": "Yes. Our Anchor and Apex Pro adjustable benches work with all Ativafit dumbbells. The Apex Pro is especially recommended for the 66lb and 88lb sets due to its reinforced frame and higher weight capacity."
          }
        },
        "faq_item_4": {
          "type": "faq_item",
          "settings": {
            "question": "Does the stand fit all Ativafit dumbbells?",
            "answer": "Yes. The Atlas Dumbbell Stand is designed to fit the 27.5lb, 66lb, and 88lb models. It keeps your weights organized and within easy reach for a clean, professional home gym."
          }
        },
        "faq_item_5": {
          "type": "faq_item",
          "settings": {
            "question": "Is the Strength Collection good for small spaces?",
            "answer": "Absolutely. Adjustable dumbbells, foldable benches, and a compact stand give you a full range of resistance and exercises in a small footprint—no need for multiple fixed-weight sets or a bulky rack."
          }
        }
      },
      "block_order": [
        "faq_item_1",
        "faq_item_2",
