    "unified_media_mention_xyz": {
      "type": "unified-media-mention",
      "blocks": {
        "mention_1": {
          "type": "mention",
          "settings": {
            "text": "<p>The Ativafit Adjustable Dumbbell Set are a space-saving piece of gym equipment that you can incorporate into your strength training routine. These \"dialtech Elites\" are great for both beginners and more advanced lifters who are tight on space or want to consolidate their gym equipment. </p>",
            "link": "https://www.garagegymreviews.com/ativafit-adjustable-dumbbell-review",
            "logo": "shopify://shop_images/garage_review_2081e3bb-bd05-4a3f-8931-d19950655a05.webp",
            "logo_asset": "ggr-new-site-logo.png",
            "logo_bg": false
          }
        },
        "mention_2": {
          "type": "mention",
          "settings": {
            "text": "<p>The Ativafit Adjustable Dumbbells feature a steel build that is more durable than adjustable dumbbells that utilize a hefty amount of plastic.</p>",
            "link": "https://barbend.com/ativafit-adjustable-dumbbells-review/",
            "logo": "shopify://shop_images/BarBend.jpg",
            "logo_asset": "barbend-logo.svg",
            "logo_bg": false
          }
        },
        "mention_3": {
          "type": "mention",
          "settings": {
            "text": "<p>Ativafit's 66 lb Adjustable Dumbbell is ready to support your weekly lifting routine right out of the box, with no setup required. Their storage trays secure them when fully stacked and hold unused plates when we select a lighter weight. Plus, we love their sleek, high-quality appearance.</p>",
            "link": "https://www.verywellfit.com/best-adjustable-dumbbells-4173456",
            "logo_asset": "verywell-fit-logo.png",
            "logo_bg": false
          }
        }
      },
      "block_order": [
        "mention_1",
        "mention_2",
        "mention_3"
      ],
      "settings": {
        "product": "66lbs",
        "title": "MEDIA MENTION",
        "bg_color": "#ffffff",
        "padding_top": 60,
