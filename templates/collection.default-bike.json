    "faq_accordion_bike": {
      "type": "faq-accordion",
      "blocks": {
        "faq_item_FnUALR": {
          "type": "faq_item",
          "settings": {
            "question": "​​Is a stationary exercise bike good for weight loss​?",
            "answer": "Yes! Riding a stationary exercise bike is one of the most effective ways to burn 400-600 calories per hour. Both our R8 and F8 are excellent foldable exercise bikes for fat loss. The R8 offers an added advantage with integrated resistance bands, allowing you to engage in a full-body workout to boost your weight loss results while you cycle."
          }
        },
        "faq_item_XMBiae": {
          "type": "faq_item",
          "settings": {
            "question": "Which Ativafit model is the best exercise bike for seniors?",
            "answer": "The Ativafit R8 is the recommended exercise bike for seniors and elderly users. Unlike a standard cycle, its 3-in-1 design includes a semi-recumbent setting and a supportive backrest, which offer superior stability and joint protection. It is widely considered the best exercise bike for older people who want a safe, low-impact workout at home."
          }
        },
        "faq_item_WVYipU": {
          "type": "faq_item",
          "settings": {
            "question": "Is the F8 or R8 better for small spaces?",
            "answer": "While both models feature a space-saving exercise bike foldaway design, the F8 is our most compact folding exercise bike. If you are looking for the best exercise bike for small spaces or apartment living, the F8’s streamlined frame makes it the premier choice for easy storage without sacrificing performance."
          }
        },
        "faq_item_77PGzK": {
          "type": "faq_item",
          "settings": {
            "question": "What is a recumbent exercise bike and who is it for?",
            "answer": "A recumbent exercise bike features a reclined seat and backrest to reduce spinal stress. The Ativafit R8 is the good recumbent exercise bike for home use because it combines the comfort of a reclined ride with the convenience of a foldable gym cycle. It’s ideal for anyone seeking a comfortable, long-duration cardio session or therapeutic exercise."
          }
        },
        "faq_item_mmxVTU": {
          "type": "faq_item",
          "settings": {
            "question": "Do the Ativafit foldable exercise bike comes with a warranty?",
            "answer": "Yes. We offer a standard one-year warranty."
          }
        }
      },
      "block_order": [
