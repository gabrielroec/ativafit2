    "image_tabs_bike": {
      "type": "image-tabs",
      "blocks": {
        "tab_bike_1": {
          "type": "tab",
          "settings": {
            "title": "Foldable & Space-Saving",
            "image": "shopify://shop_images/Bikes-1600x1200.webp",
            "text": "<p>Both the F8 and R8 are Ativafit folding exercise bike models that collapse in seconds, making them perfect for small apartments or shared spaces.</p>"
          }
        },
        "tab_bike_2": {
          "type": "tab",
          "settings": {
            "title": "Comfort for Every Rider",
            "image": "shopify://shop_images/Cardio-1600x1200.webp",
            "text": "<p>The R8 features a semi-recumbent design with a supportive backrest, making it the best exercise bike for elderly users or anyone seeking low-impact cardio with maximum comfort.</p>"
          }
        },
        "tab_bike_3": {
          "type": "tab",
          "settings": {
            "title": "Smooth Magnetic Resistance",
            "image": "shopify://shop_images/Y8A2946_ca2ed324-ab74-4474-983b-3356fbffe70d.jpg",
            "text": "<p>Enjoy whisper-quiet workouts with our magnetic resistance system. Multiple resistance levels let you customize intensity from gentle warm-ups to challenging cardio sessions.</p>"
          }
        },
        "tab_bike_4": {
          "type": "tab",
          "settings": {
            "title": "Built-in Resistance Bands",
            "image": "shopify://shop_images/r8_bike_selling_points.webp",
            "text": "<p>The R8 comes equipped with resistance bands for upper-body toning while you cycle, giving you a full-body workout in one compact machine.</p>"
          }
        }
      },
      "block_order": [
        "tab_bike_1",
        "tab_bike_2",
