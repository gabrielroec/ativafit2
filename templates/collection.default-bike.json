    "faq_accordion_bike": {
      "type": "faq-accordion",
      "blocks": {
        "faq_item_FnUALR": {
          "type": "faq_item",
          "settings": {
            "question": "​​Is a stationary exercise bike good for weight loss​?",
            "answer": "Yes! Both our R8 and F8 are excellent choices if you are looking for an Ativafit folding exercise bike for fat loss. The R8 offers an added advantage with resistance bands for upper-body toning while you cycle."
          }
        },
        "faq_item_XMBiae": {
          "type": "faq_item",
          "settings": {
            "question": "Which Ativafit bike is best for seniors?",
            "answer": "The Ativafit bike R8 is the recommended model for elderly users due to its semi-recumbent setting and backrest, which offer superior stability and joint protection."
          }
        },
        "faq_item_WVYipU": {
          "type": "faq_item",
          "settings": {
            "question": "Is the F8 or R8 better for small spaces?",
            "answer": "While both are Ativafit folding exercise bike models, the F8 is our most compact Ativafit bike, making it the premier choice for small spaces."
          }
        },
        "faq_item_MqRUQH": {
          "type": "faq_item",
          "settings": {
            "question": "Is riding a bike good exercise for weight loss?",
            "answer": "Yes, it's one of the best! Using an Ativafit exercise bike for fat loss allows you to burn 400-600 calories per hour. The R8 adds resistance bands to boost this even further."
          }
        },
        "faq_item_77PGzK": {
          "type": "faq_item",
          "settings": {
            "question": "What is a recumbent exercise bike and who is it for?",
            "answer": "It's a bike with a backrest and reclined seat. It is the best exercise bike for elderly users or anyone seeking a comfortable, low-impact cardio session."
          }
        },
        "faq_item_mmxVTU": {
          "type": "faq_item",
          "settings": {
            "question": "Do the Ativafit foldable exercise bike comes with a warranty?",
            "answer": "Yes. We offer a standard one-year warranty, plus an extra year when you sign up for our Ativa People program."
          }
        }
      },
