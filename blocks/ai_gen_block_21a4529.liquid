{% doc %}
  @prompt
    请为我编写一个响应式的电商倒计时组件（HTML/CSS/JS）。
    
    1. 视觉参考： > 风格参考 Ativafit 官网。结构为：上方是一个居中的标题“ENDS IN”，中间是倒计时数字（天：时：分：秒），数字下方是对应的单位标签（DAYS, HOURS, MINUTES, SECONDS）。
    
    2. 核心开发要求（可调节性）：
    请务必使用 CSS 变量 (:root variables) 来管理所有视觉属性，确保我可以通过修改变量值直接调整：
    
    字体 (Font): --timer-font-family (支持设置自定义字体，默认使用现代无衬线体)。
    
    数字 (Digits): --timer-digit-size (大小), --timer-digit-color (颜色), --timer-digit-weight (粗细)。
    
    单位标签 (Labels): --timer-label-size (字号), --timer-label-color (颜色)。
    
    间距 (Spacing): --timer-gap (数字块之间的距离), --timer-section-margin (上下边距)。
    
    3. 技术细节：
    
    字体对齐： 数字必须使用 font-variant-numeric: tabular-nums; 或等宽字体，防止秒数跳动时组件宽度发生晃动。
    
    逻辑控制： 倒计时目标时间应在 JS 中易于修改（例如设置一个 targetDate 变量）。
    
    响应式： 在移动端（屏幕宽度 < 768px）时，自动缩小字号以适应屏幕。
    
    4. 输出格式： > 请提供简洁、现代的 HTML 结构和干净的 CSS 代码。, 冒号底部和数字底部对齐, 在布局上，请确保数字和中间的分隔冒号（:）在垂直方向上都依据基线（baseline）对齐。这样可以保证冒号的底部和数字的底部在同一条水平线上，防止冒号偏高。
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-countdown-timer-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
    text-align: center;
  }

  .ai-countdown-timer__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_margin }}px 0;
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
    text-transform: uppercase;
  }

  .ai-countdown-timer__digits-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: baseline;
    gap: {{ block.settings.digit_gap }}px;
    margin-bottom: {{ block.settings.label_margin }}px;
  }

  .ai-countdown-timer__block-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ai-countdown-timer__number-{{ ai_gen_id }} {
    font-family: {{ block.settings.digit_font.family }}, {{ block.settings.digit_font.fallback_families }};
    font-weight: {{ block.settings.digit_font.weight }};
    font-size: {{ block.settings.digit_size }}px;
    color: {{ block.settings.digit_color }};
    line-height: 1;
    font-variant-numeric: tabular-nums;
    min-width: 2ch;
    text-align: center;
  }

  .ai-countdown-timer__separator-{{ ai_gen_id }} {
    font-family: {{ block.settings.digit_font.family }}, {{ block.settings.digit_font.fallback_families }};
    font-weight: {{ block.settings.digit_font.weight }};
    font-size: {{ block.settings.digit_size }}px;
    color: {{ block.settings.digit_color }};
    line-height: 1;
    margin: 0 {{ block.settings.separator_spacing }}px;
  }

  .ai-countdown-timer__label-{{ ai_gen_id }} {
    font-family: {{ block.settings.label_font.family }}, {{ block.settings.label_font.fallback_families }};
    font-weight: {{ block.settings.label_font.weight }};
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    margin-top: {{ block.settings.label_spacing }}px;
    letter-spacing: {{ block.settings.label_letter_spacing }}px;
    text-transform: uppercase;
  }

  .ai-countdown-timer__expired-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.expired_color }};
    display: none;
  }

  .ai-countdown-timer__expired-{{ ai_gen_id }}.active {
    display: block;
  }

  @media screen and (max-width: 767px) {
    .ai-countdown-timer__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.7);
    }

    .ai-countdown-timer__number-{{ ai_gen_id }},
    .ai-countdown-timer__separator-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.digit_size }}px * 0.6);
    }

    .ai-countdown-timer__label-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.label_size }}px * 0.7);
    }

    .ai-countdown-timer__digits-{{ ai_gen_id }} {
      gap: calc({{ block.settings.digit_gap }}px * 0.5);
    }

    .ai-countdown-timer__separator-{{ ai_gen_id }} {
      margin: 0 calc({{ block.settings.separator_spacing }}px * 0.5);
    }
  }
{% endstyle %}

<countdown-timer-{{ ai_gen_id }}
  class="ai-countdown-timer-{{ ai_gen_id }}"
  data-end-date="{{ block.settings.end_date }}"
  data-end-time="{{ block.settings.end_time }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.title != blank %}
    <h2 class="ai-countdown-timer__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
  {% endif %}

  <div class="ai-countdown-timer__content-{{ ai_gen_id }}">
    <div class="ai-countdown-timer__digits-{{ ai_gen_id }}">
      <div class="ai-countdown-timer__block-{{ ai_gen_id }}">
        <span class="ai-countdown-timer__number-{{ ai_gen_id }}" data-days>00</span>
        <span class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.days_label }}</span>
      </div>

      {% if block.settings.show_separator %}
        <span class="ai-countdown-timer__separator-{{ ai_gen_id }}">:</span>
      {% endif %}

      <div class="ai-countdown-timer__block-{{ ai_gen_id }}">
        <span class="ai-countdown-timer__number-{{ ai_gen_id }}" data-hours>00</span>
        <span class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.hours_label }}</span>
      </div>

      {% if block.settings.show_separator %}
        <span class="ai-countdown-timer__separator-{{ ai_gen_id }}">:</span>
      {% endif %}

      <div class="ai-countdown-timer__block-{{ ai_gen_id }}">
        <span class="ai-countdown-timer__number-{{ ai_gen_id }}" data-minutes>00</span>
        <span class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.minutes_label }}</span>
      </div>

      {% if block.settings.show_separator %}
        <span class="ai-countdown-timer__separator-{{ ai_gen_id }}">:</span>
      {% endif %}

      <div class="ai-countdown-timer__block-{{ ai_gen_id }}">
        <span class="ai-countdown-timer__number-{{ ai_gen_id }}" data-seconds>00</span>
        <span class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.seconds_label }}</span>
      </div>
    </div>

    {% if block.settings.expired_message != blank %}
      <div class="ai-countdown-timer__expired-{{ ai_gen_id }}">
        {{ block.settings.expired_message }}
      </div>
    {% endif %}
  </div>
</countdown-timer-{{ ai_gen_id }}>

<script>
  (function() {
    class CountdownTimer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.endDate = this.dataset.endDate;
        this.endTime = this.dataset.endTime;
        this.interval = null;
      }

      connectedCallback() {
        this.daysElement = this.querySelector('[data-days]');
        this.hoursElement = this.querySelector('[data-hours]');
        this.minutesElement = this.querySelector('[data-minutes]');
        this.secondsElement = this.querySelector('[data-seconds]');
        this.expiredElement = this.querySelector('.ai-countdown-timer__expired-{{ ai_gen_id }}');
        this.digitsContainer = this.querySelector('.ai-countdown-timer__digits-{{ ai_gen_id }}');

        this.startCountdown();
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }

      startCountdown() {
        const targetDate = this.getTargetDate();

        if (!targetDate) {
          this.showExpired();
          return;
        }

        this.updateCountdown(targetDate);
        this.interval = setInterval(() => {
          this.updateCountdown(targetDate);
        }, 1000);
      }

      getTargetDate() {
        if (!this.endDate) {
          return null;
        }

        const timeString = this.endTime || '23:59';
        const dateTimeString = this.endDate + 'T' + timeString + ':00';
        const targetDate = new Date(dateTimeString);

        if (isNaN(targetDate.getTime())) {
          return null;
        }

        return targetDate;
      }

      updateCountdown(targetDate) {
        const now = new Date().getTime();
        const distance = targetDate.getTime() - now;

        if (distance < 0) {
          this.showExpired();
          clearInterval(this.interval);
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        this.daysElement.textContent = String(days).padStart(2, '0');
        this.hoursElement.textContent = String(hours).padStart(2, '0');
        this.minutesElement.textContent = String(minutes).padStart(2, '0');
        this.secondsElement.textContent = String(seconds).padStart(2, '0');
      }

      showExpired() {
        if (this.digitsContainer) {
          this.digitsContainer.style.display = 'none';
        }
        if (this.expiredElement) {
          this.expiredElement.classList.add('active');
        }
      }
    }

    customElements.define('countdown-timer-{{ ai_gen_id }}', CountdownTimer{{ ai_gen_id }});
  })();
</script>

