{% doc %}
  @prompt
    请使用 HTML 和 Tailwind CSS 编写一个名为 "New Arrivals" 的首页 Section，要求高度还原图片中的 UI 风格。
    
    1. 全局样式变量 (需易于调整)：
    
    
    
    使用 CSS 变量定义：--main-radius (圆角), --brand-red (价格/Sale色), --font-base (无衬线字体)。
    
    2. 顶部导航 (Header)：
    
    
    
    左侧：大标题 "New Arrivals" + 灰色小字描述。
    
    
    
    3. 核心布局 (Main Layout)：
    
    
    
    桌面端 (Desktop)： 采用 Flex  布局。左侧为一个固定比例的 Banner；右侧是4个 横向网格产品列表。
    
    手机端 (Mobile)： >   - 标题和描述居左对齐。
    
    左侧 Banner 变为全宽 放在最上方。
    
    下方产品改为 2个 横向网格产品列表。横向滑动(Overflow-x-scroll) 出另外两个产品。
    
    4. 产品卡片细节 (Product Card)：
    
    
    
    图片容器： 浅灰色背景 (#F3F3F3)，产品居中，整体大圆角。
    
    
    
    文字排版： 顶部是分类小字（全大写），中间是粗体标题，底部是价格（红色现价 + 灰色划线原价）。, 桌面端 (Desktop) 结构重构：
    
    左右对齐： 保持左 Banner 和右产品区的高度完全一致。
    
    滑动容器 (Right Column)： 右侧不再是简单的网格，而是一个 overflow-x-hidden 的容器。
    
    2-Column View： 在视口中，右侧一次只展示 2 个 产品卡片。
    
    滑动逻辑： 其余 2 个产品隐藏在容器右侧。下方展示 Slide Bar ，手机端也要加上slide bar
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-new-arrivals-{{ ai_gen_id }} {
    --main-radius: {{ block.settings.border_radius }}px;
    --brand-red: {{ block.settings.sale_color }};
    --font-base: {{ block.settings.heading_font.family }}, sans-serif;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    display: block;
  }

  .ai-new-arrivals-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-new-arrivals-header-{{ ai_gen_id }} {
    margin-bottom: 30px;
  }

  .ai-new-arrivals-title-{{ ai_gen_id }} {
    font-family: var(--font-base);
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    color: {{ block.settings.title_color }};
    margin: 0 0 8px 0;
    line-height: 1.2;
  }

  .ai-new-arrivals-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-new-arrivals-main-{{ ai_gen_id }} {
    display: flex;
    gap: 20px;
    align-items: stretch;
  }

  .ai-new-arrivals-banner-{{ ai_gen_id }} {
    flex: 0 0 calc(40% - 10px);
    background-color: #F3F3F3;
    border-radius: var(--main-radius);
    overflow: hidden;
    position: relative;
  }

  .ai-new-arrivals-banner-link-{{ ai_gen_id }} {
    display: block !important;
    width: 100% !important;
    height: 100% !important;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
  }

  .ai-new-arrivals-banner-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  .ai-new-arrivals-banner-link-{{ ai_gen_id }}:hover img {
    transform: scale(1.04);
  }

  .ai-new-arrivals-banner-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #F3F3F3;
    transition: transform 0.35s ease;
  }

  .ai-new-arrivals-banner-link-{{ ai_gen_id }}:hover .ai-new-arrivals-banner-placeholder-{{ ai_gen_id }} {
    transform: scale(1.04);
  }

  .ai-new-arrivals-banner-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-new-arrivals-products-wrapper-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-new-arrivals-products-container-{{ ai_gen_id }} {
    flex: 1;
    overflow: hidden;
    position: relative;
    touch-action: pan-y;
    user-select: none;
    -webkit-user-select: none;
  }

  .ai-new-arrivals-products-container-{{ ai_gen_id }} img {
    -webkit-user-drag: none;
    user-select: none;
    pointer-events: auto;
  }

  .ai-new-arrivals-products-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, calc(50% - 10px));
    gap: 20px;
    transition: transform 0.4s ease;
    height: 100%;
  }

  .ai-new-arrivals-product-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .ai-new-arrivals-product-image-{{ ai_gen_id }} {
    background-color: #F3F3F3;
    border-radius: var(--main-radius);
    overflow: hidden;
    margin-bottom: 12px;
    position: relative;
    padding-bottom: 100%;
  }

  .ai-new-arrivals-product-discount-badge-{{ ai_gen_id }} {
    position: absolute;
    top: 10px;
    left: 10px;
    padding: 6px 12px;
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    background: #eb701f;
    border-radius: 999px;
    line-height: 1;
    z-index: 1;
  }

  .ai-new-arrivals-product-image-{{ ai_gen_id }} img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-new-arrivals-product-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-new-arrivals-product-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-new-arrivals-product-category-{{ ai_gen_id }} {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: {{ block.settings.category_color }};
    margin-bottom: 6px;
    font-weight: 500;
  }

  .ai-new-arrivals-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: 700;
    color: {{ block.settings.product_title_color }};
    margin-bottom: 8px;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-new-arrivals-product-price-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-new-arrivals-price-current-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: 700;
    color: var(--brand-red);
  }

  .ai-new-arrivals-price-original-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size | minus: 2 }}px;
    color: {{ block.settings.original_price_color }};
    text-decoration: line-through;
  }

  .ai-new-arrivals-slider-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
  }

  .ai-new-arrivals-slider-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_inactive_color }};
    border: none;
    padding: 0;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-new-arrivals-slider-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    width: {{ block.settings.dot_size | times: 2 }}px;
    border-radius: {{ block.settings.dot_size | divided_by: 2 }}px;
  }

  .ai-new-arrivals-slider-dot-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.dot_active_color }};
    opacity: 0.7;
  }

  @media screen and (max-width: 768px) {
    .ai-new-arrivals-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px 16px {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }

    .ai-new-arrivals-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-new-arrivals-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-new-arrivals-main-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 24px;
    }

    .ai-new-arrivals-banner-{{ ai_gen_id }} {
      flex: none;
      width: 100%;
      min-height: 250px;
    }

    .ai-new-arrivals-products-{{ ai_gen_id }} {
      grid-template-columns: repeat(4, calc(50% - 8px));
      gap: 16px;
    }

    .ai-new-arrivals-product-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.product_title_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<ai-new-arrivals-{{ ai_gen_id }} class="ai-new-arrivals-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-new-arrivals-container-{{ ai_gen_id }}">
    <div class="ai-new-arrivals-header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-new-arrivals-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.description != blank %}
        <p class="ai-new-arrivals-description-{{ ai_gen_id }}">{{ block.settings.description }}</p>
      {% endif %}
    </div>

    {%- assign banner_link = block.settings.banner_image_link | default: '/collections/deals' -%}
    <div class="ai-new-arrivals-main-{{ ai_gen_id }}">
      <div class="ai-new-arrivals-banner-{{ ai_gen_id }}">
        <a href="{{ banner_link }}" class="ai-new-arrivals-banner-link-{{ ai_gen_id }}">
        {% if block.settings.banner_image %}
          <img
            src="{{ block.settings.banner_image | image_url: width: 800 }}"
            alt="{{ block.settings.banner_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.banner_image.width }}"
            height="{{ block.settings.banner_image.height }}"
          >
        {% else %}
          <div class="ai-new-arrivals-banner-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
        </a>
      </div>

      <div class="ai-new-arrivals-products-wrapper-{{ ai_gen_id }}">
        <div class="ai-new-arrivals-products-container-{{ ai_gen_id }}">
          <div class="ai-new-arrivals-products-{{ ai_gen_id }}" data-slider-track>
            {% for i in (1..4) %}
              {% liquid
                assign product_key = 'product_' | append: i
                assign product = block.settings[product_key]
              %}

              {% if product != blank %}
                <a href="{{ product.url }}" class="ai-new-arrivals-product-card-{{ ai_gen_id }}">
                  <div class="ai-new-arrivals-product-image-{{ ai_gen_id }}">
                    {% if product.featured_image %}
                      <img
                        src="{{ product.featured_image | image_url: width: 500 }}"
                        alt="{{ product.featured_image.alt | escape }}"
                        loading="lazy"
                        width="500"
                        height="500"
                      >
                    {% else %}
                      <div class="ai-new-arrivals-product-placeholder-{{ ai_gen_id }}">
                        {{ 'product-apparel-1' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                    {% assign card_variant = product.selected_or_first_available_variant %}
                    {% assign compare_price = card_variant.compare_at_price %}
                    {% assign price = card_variant.price %}
                    {% if compare_price != blank and compare_price > price and compare_price > 0 %}
                      {% assign discount_cents = compare_price | minus: price %}
                      {% assign discount_percent = discount_cents | times: 100 | divided_by: compare_price %}
                      <span class="ai-new-arrivals-product-discount-badge-{{ ai_gen_id }}" aria-hidden="true">{{ discount_percent }}% OFF</span>
                    {% endif %}
                  </div>

                  <div class="ai-new-arrivals-product-info-{{ ai_gen_id }}">
                    {% if product.type != blank %}
                      <div class="ai-new-arrivals-product-category-{{ ai_gen_id }}">{{ product.type }}</div>
                    {% endif %}

                    <h3 class="ai-new-arrivals-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>

                    <div class="ai-new-arrivals-product-price-{{ ai_gen_id }}">
                      <span class="ai-new-arrivals-price-current-{{ ai_gen_id }}">
                        {{ product.price | money }}
                      </span>
                      {% if product.compare_at_price > product.price %}
                        <span class="ai-new-arrivals-price-original-{{ ai_gen_id }}">
                          {{ product.compare_at_price | money }}
                        </span>
                      {% endif %}
                    </div>
                  </div>
                </a>
              {% else %}
                <div class="ai-new-arrivals-product-card-{{ ai_gen_id }}">
                  <div class="ai-new-arrivals-product-image-{{ ai_gen_id }}">
                    <div class="ai-new-arrivals-product-placeholder-{{ ai_gen_id }}">
                      {{ 'product-apparel-1' | placeholder_svg_tag }}
                    </div>
                  </div>
                  <div class="ai-new-arrivals-product-info-{{ ai_gen_id }}">
                    <div class="ai-new-arrivals-product-category-{{ ai_gen_id }}">Category</div>
                    <h3 class="ai-new-arrivals-product-title-{{ ai_gen_id }}">Product {{ i }}</h3>
                    <div class="ai-new-arrivals-product-price-{{ ai_gen_id }}">
                      <span class="ai-new-arrivals-price-current-{{ ai_gen_id }}">$99.00</span>
                      <span class="ai-new-arrivals-price-original-{{ ai_gen_id }}">$129.00</span>
                    </div>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        <div class="ai-new-arrivals-slider-controls-{{ ai_gen_id }}" data-slider-controls>
          <button class="ai-new-arrivals-slider-dot-{{ ai_gen_id }} active" data-slide="0" aria-label="Go to slide 1"></button>
          <button class="ai-new-arrivals-slider-dot-{{ ai_gen_id }}" data-slide="1" aria-label="Go to slide 2"></button>
        </div>
      </div>
    </div>
  </div>
</ai-new-arrivals-{{ ai_gen_id }}>

<script>
  (function() {
    class AiNewArrivals{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.totalSlides = 2;
      }

      connectedCallback() {
        this.sliderTrack = this.querySelector('[data-slider-track]');
        this.dots = this.querySelectorAll('.ai-new-arrivals-slider-dot-{{ ai_gen_id }}');
        
        if (!this.sliderTrack || !this.dots.length) return;

        this.setupSlider();
        this.setupTouchEvents();
      }

      setupSlider() {
        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            this.goToSlide(index);
          });
        });
      }

      setupTouchEvents() {
        let startX = 0;
        let startY = 0;
        let currentX = 0;
        let isDragging = false;

        this.sliderTrack.addEventListener('touchstart', (e) => {
          startX = e.touches[0].clientX;
          startY = e.touches[0].clientY;
          currentX = startX;
          isDragging = true;
        }, { passive: true });

        this.sliderTrack.addEventListener('touchmove', (e) => {
          if (!isDragging) return;
          const x = e.touches[0].clientX;
          const y = e.touches[0].clientY;
          const isHorizontal = Math.abs(x - startX) > Math.abs(y - startY);
          if (isHorizontal && Math.abs(x - startX) > 10) {
            e.preventDefault();
          }
          currentX = x;
        }, { passive: false });

        this.sliderTrack.addEventListener('touchend', () => {
          if (!isDragging) return;
          isDragging = false;

          const diff = startX - currentX;
          
          if (Math.abs(diff) > 50) {
            if (diff > 0 && this.currentSlide < this.totalSlides - 1) {
              this.goToSlide(this.currentSlide + 1);
            } else if (diff < 0 && this.currentSlide > 0) {
              this.goToSlide(this.currentSlide - 1);
            }
          }
        });

        let mouseStartX = 0;
        let mouseCurrentX = 0;
        let isMouseDragging = false;
        const DRAG_THRESHOLD = 5;

        this.sliderTrack.addEventListener('mousedown', (e) => {
          e.preventDefault();
          mouseStartX = e.clientX;
          mouseCurrentX = e.clientX;
          isMouseDragging = true;
          this._swipeWasDrag = false;
          this.sliderTrack.style.cursor = 'grabbing';
        });

        this.sliderTrack.addEventListener('mousemove', (e) => {
          if (!isMouseDragging) return;
          mouseCurrentX = e.clientX;
          if (Math.abs(mouseCurrentX - mouseStartX) > DRAG_THRESHOLD) {
            this._swipeWasDrag = true;
          }
        });

        this.sliderTrack.addEventListener('mouseup', () => {
          if (!isMouseDragging) return;
          isMouseDragging = false;
          this.sliderTrack.style.cursor = 'grab';

          const diff = mouseStartX - mouseCurrentX;
          
          if (Math.abs(diff) > 50) {
            if (diff > 0 && this.currentSlide < this.totalSlides - 1) {
              this.goToSlide(this.currentSlide + 1);
            } else if (diff < 0 && this.currentSlide > 0) {
              this.goToSlide(this.currentSlide - 1);
            }
          }
        });

        this.sliderTrack.addEventListener('mouseleave', () => {
          if (isMouseDragging) {
            isMouseDragging = false;
            this.sliderTrack.style.cursor = 'grab';
          }
        });

        this.sliderTrack.addEventListener('click', (e) => {
          if (this._swipeWasDrag) {
            e.preventDefault();
            e.stopPropagation();
            this._swipeWasDrag = false;
          }
        }, true);

        this.sliderTrack.style.cursor = 'grab';
      }

      goToSlide(index) {
        this.currentSlide = index;
        const offset = index * -100;
        this.sliderTrack.style.transform = `translateX(${offset}%)`;

        this.dots.forEach((dot, i) => {
          if (i === index) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('ai-new-arrivals-{{ ai_gen_id }}', AiNewArrivals{{ ai_gen_id }});
  })();
</script>

