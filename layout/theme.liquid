    {%- comment -%} Cart Drawer - Novo (Shopify 2.0) {%- endcomment -%}
    {%- comment -%} CSS e JS são carregados pela própria section cart-drawer.liquid {%- endcomment -%}
    <script>
      window.shopifyCountryCode = '{{ localization.country.iso_code | default: "" }}';
      /* Geolocation only fetched on demand — first cart-drawer open or first add-to-cart.
         Saves a DNS+TLS handshake to ipapi.co for visitors that never open the cart. */
      (function(){
        var fetched = false;
        function ensureCountry() {
          if (fetched) return;
          fetched = true;
          fetch('https://ipapi.co/json/')
            .then(function(r){ return r.json(); })
            .then(function(d){
              if (d && d.country_code) {
                window.shopifyCountryCode = d.country_code;
                if (window.cartDrawer && window.cartDrawer.isOpen) window.cartDrawer.loadCartData();
              }
            })
            .catch(function(){});
        }
        document.addEventListener('cart:open', ensureCountry, { once: true, passive: true });
        document.addEventListener('product:added', ensureCountry, { once: true, passive: true });
      })();
    </script>

