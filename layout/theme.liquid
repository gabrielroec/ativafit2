    {%- comment -%} Bundle Builder Title Converter Script (INP + CLS optimized) {%- endcomment -%}
    <script>
      (function() {
        'use strict';
        var idle = window.requestIdleCallback || function(cb) { setTimeout(cb, 50); };
        var pending = false;

        function processBundleElements() {
          pending = false;
          document.querySelectorAll('.bndlr-product-title:not(h3)').forEach(function(el) {
            var h3 = document.createElement('h3');
            ['href','target','title','class'].forEach(function(a) { if (el.hasAttribute(a)) h3.setAttribute(a, el.getAttribute(a)); });
            h3.classList.add('bndlr-product-title-h3');
            h3.innerHTML = el.innerHTML;
            el.parentNode.replaceChild(h3, el);
          });
          document.querySelectorAll('.bndlr-bundle-title').forEach(function(el) {
            if (el.tagName === 'H2' && el.textContent.trim() === '') el.remove();
          });
        }

        function scheduleProcess() {
          if (!pending) { pending = true; idle(processBundleElements); }
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', scheduleProcess);
        } else {
          scheduleProcess();
        }
        window.addEventListener('load', scheduleProcess);

        /* Observer escopado: observa só quando um container bndlr existir no DOM,
           e auto-desconecta após 10s de quiescência ou 30s absolutos para não rodar
           forever em todas as mutations do body. */
        var observer;
        var lastActivity = Date.now();
        function startObserver() {
          var target = document.querySelector('[class*="bndlr"], .bundler-app, #bndlr-app') || document.body;
          if (!target) return;
          observer = new MutationObserver(function(mutations) {
            for (var i = 0; i < mutations.length; i++) {
              var added = mutations[i].addedNodes;
              for (var j = 0; j < added.length; j++) {
                var n = added[j];
                if (n.nodeType === 1 && (n.classList && (n.classList.contains('bndlr-product') || n.classList.contains('bndlr-bundle-title')) ||
                    (n.querySelector && (n.querySelector('.bndlr-product-title') || n.querySelector('.bndlr-bundle-title'))))) {
                  lastActivity = Date.now();
                  scheduleProcess();
                  return;
                }
              }
            }
          });
          observer.observe(target, { childList: true, subtree: true });

          /* Kill switch — desconecta após 30s ou 10s de inatividade */
          var killTimer = setInterval(function() {
            if (!observer) { clearInterval(killTimer); return; }
            if (Date.now() - lastActivity > 10000) {
              try { observer.disconnect(); } catch(e) {}
              observer = null;
              clearInterval(killTimer);
            }
          }, 2000);
          setTimeout(function() {
            if (observer) { try { observer.disconnect(); } catch(e) {} observer = null; }
            clearInterval(killTimer);
          }, 30000);
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', startObserver);
        } else {
          startObserver();
        }
      })();
    </script>

    {%- comment -%} Bundle Builder Selector Fix Script (INP-optimized) {%- endcomment -%}
    <script>
      (function() {
        'use strict';
        var emptyNL = document.createDocumentFragment().querySelectorAll('*');
        var origQSA = Element.prototype.querySelectorAll;
        var origQS = Element.prototype.querySelector;

        Element.prototype.querySelectorAll = function(s) {
          if (typeof s === 'string' && s.indexOf('#sizzle') !== -1) {
            var clean = s.replace(/#sizzle\S*/g, '').trim();
            if (clean) { try { return origQSA.call(this, clean); } catch(e) {} }
            return emptyNL;
          }
          return origQSA.call(this, s);
        };

        Element.prototype.querySelector = function(s) {
          if (typeof s === 'string' && s.indexOf('#sizzle') !== -1) {
            var clean = s.replace(/#sizzle\S*/g, '').trim();
            if (clean) { try { return origQS.call(this, clean); } catch(e) {} }
              return null;
            }
          return origQS.call(this, s);
        };
      })();
    </script>

    {%- comment -%} Ativafit Brand Name Corrector Script (INP + CLS optimized)
      Observer escopado + auto-disconnect após 10s inatividade ou 30s totais.
      TODO: migrar para substituição server-side (Liquid filter) para zerar custo client.
    {%- endcomment -%}
    <script>
      (function() {
        'use strict';
        var re = /ativa\s+fit/gi;
        var SKIP = {SCRIPT:1,STYLE:1,NOSCRIPT:1,TEXTAREA:1,SVG:1};
        var idle = window.requestIdleCallback || function(cb){setTimeout(cb,80);};
        var pending = false;

        function fixNode(root) {
          if (!root) return;
          var walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, null);
          var node;
          while ((node = walker.nextNode())) {
            if (SKIP[node.parentElement && node.parentElement.tagName]) continue;
            if (re.test(node.textContent)) {
              node.textContent = node.textContent.replace(re, 'Ativafit');
            }
          }
        }

        function processBody() { pending = false; fixNode(document.body); }
        function schedule() { if (!pending) { pending = true; idle(processBody); } }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', schedule);
        } else {
          schedule();
        }
        window.addEventListener('load', schedule);

        /* Observer + kill switch escopados */
        var observer;
        var lastActivity = Date.now();
        function startObserver() {
          observer = new MutationObserver(function(muts) {
            for (var i = 0; i < muts.length; i++) {
              if (muts[i].addedNodes.length) {
                lastActivity = Date.now();
                schedule();
                return;
              }
            }
          });
          observer.observe(document.body || document.documentElement, { childList: true, subtree: true });

          var killTimer = setInterval(function() {
            if (!observer) { clearInterval(killTimer); return; }
            if (Date.now() - lastActivity > 10000) {
              try { observer.disconnect(); } catch(e) {}
              observer = null;
              clearInterval(killTimer);
            }
          }, 2000);
          setTimeout(function() {
            if (observer) { try { observer.disconnect(); } catch(e) {} observer = null; }
            clearInterval(killTimer);
          }, 30000);
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', startObserver);
        } else {
          startObserver();
        }
      })();
    </script>

