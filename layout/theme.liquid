    <script>
      window.shopifyCountryCode = '{{ localization.country.iso_code | default: "" }}';
      /* Geolocation deferred to after load to avoid blocking main thread */
      window.addEventListener('load', function() {
        setTimeout(function() {
      fetch('https://ipapi.co/json/')
            .then(function(r) { return r.json(); })
            .then(function(d) {
              if (d.country_code) {
                window.shopifyCountryCode = d.country_code;
                if (window.cartDrawer && window.cartDrawer.isOpen) window.cartDrawer.loadCartData();
              }
            })
            .catch(function() {});
        }, 2000);
        });
    </script>

