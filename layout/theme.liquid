    <style>
      @font-face {
        font-family: "Barlow Fallback";
        src: local("Arial");
        size-adjust: 101.8%;
        ascent-override: 90%;
        descent-override: 25%;
        line-gap-override: 0%;
      }
      @font-face {
        font-family: "Barlow Condensed Fallback";
        src: local("Arial Narrow"), local("Arial");
        size-adjust: 88%;
        ascent-override: 100%;
        descent-override: 25%;
        line-gap-override: 0%;
      }
      @font-face {
        font-family: "Inter Fallback";
        src: local("Arial");
        size-adjust: 107%;
        ascent-override: 90%;
        descent-override: 22%;
        line-gap-override: 0%;
      }
    </style>

